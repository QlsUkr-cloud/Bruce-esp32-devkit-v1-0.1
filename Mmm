function updateStats(){fetch('/data').then(r=>r.json()).then(d=>{document.getElementById('deauth').innerText=d.deauth||0;document.getElementById('beacon').innerText=d.beacon||0;document.getElementById('rssi').innerText=d.rssi||-50;document.getElementById('clients').innerText=d.clients||0;});}
