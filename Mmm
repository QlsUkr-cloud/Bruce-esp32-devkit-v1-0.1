// ============================================================================
void saveData() {
    EEPROM.begin(4096);
    String data = "===PASS===\n" + savedPasswords + "\n===HAND===\n" + savedHandshakes + "\n";
    for (int i = 0; i < data.length() && i < 4095; i++) EEPROM.write(i, data[i]);
    EEPROM.write(data.length(), 0);
    EEPROM.commit();
    EEPROM.end();
}

void loadData() {
    EEPROM.begin(4096);
    String loaded = "";
    for (int i = 0; i < 4096; i++) { char c = EEPROM.read(i); if (c == 0) break; loaded += c; }
    int p = loaded.indexOf("===PASS===\n");
    int h = loaded.indexOf("===HAND===\n");
    if (p != -1 && h != -1) {
        savedPasswords = loaded.substring(p + 11, h - 1);
        savedHandshakes = loaded.substring(h + 11);
    }
    EEPROM.end();
}

void addPassword(const String& pwd) {
    savedPasswords += "[PASS] " + pwd + "\n";
    saveData();
}

void addHandshake(const String& hs) {
    savedHandshakes += "[HANDSHAKE] " + hs + "\n";
    saveData();
}

void clearData() {
    savedPasswords = "";
    savedHandshakes = "";
    saveData();
    showMessage("Data cleared", 1000);
}

