bool checkButton(int pin) {
  if (digitalRead(pin) == LOW && (millis() - lastButtonTime) > 200) {
    lastButtonTime = millis();
    return true;
  }
  return false;
}

void drawTopBar() {
  unsigned long sec = (millis() - uptimeStart) / 1000;
  int h = (sec / 3600) % 24, m = (sec / 60) % 60, s = sec % 60;
  char buf[16];
  sprintf(buf, "%02d:%02d:%02d", h, m, s);
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(2, 8);
  display.print(buf);
  display.drawRect(118, 1, 8, 5, SSD1306_WHITE);
  display.fillRect(126, 2, 2, 3, SSD1306_WHITE);
  display.fillRect(119, 2, 5, 3, SSD1306_WHITE);
  display.setCursor(90, 8);
  display.print(String(lastRSSI) + "dB");
  display.drawLine(0, 14, 128, 14, SSD1306_WHITE);
}

