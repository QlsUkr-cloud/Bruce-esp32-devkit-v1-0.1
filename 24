// ==================== SETUP ====================
void setup() {
  Serial.begin(115200);
  pinMode(BTN_UP,INPUT_PULLUP);
  pinMode(BTN_DOWN,INPUT_PULLUP);
  pinMode(BTN_OK,INPUT_PULLUP);
  pinMode(BTN_LEFT,INPUT_PULLUP);
  pinMode(BTN_RIGHT,INPUT_PULLUP);
  pinMode(BTN_BACK,INPUT_PULLUP);
  
  Wire.begin(OLED_SDA, OLED_SCL);
  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("OLED not found!");
    while(1);
  }
  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);
  
  uptimeStart = millis();
  bootAnimation();
  
  WiFi.mode(WIFI_AP_STA);
  esp_wifi_set_promiscuous(true);
  esp_wifi_set_promiscuous_rx_cb(handshakeCallback);
  
  drawMainMenu();
  showMessage("READY",1500);
}

// ==================== LOOP ====================
void loop() {
  if(webRunning) server.handleClient();
  lastRSSI = WiFi.RSSI();
  
  if(!inSubMenu){
    if(checkButton(BTN_LEFT)){
      currentModule = (currentModule-1+moduleCount)%moduleCount;
      drawMainMenu();
    }
    if(checkButton(BTN_RIGHT)){
      currentModule = (currentModule+1)%moduleCount;
      drawMainMenu();
    }
    if(checkButton(BTN_OK)||checkButton(BTN_DOWN)){
      inSubMenu = true;
      currentSubItem = 0;
      switch(currentModule){
        case 0: drawSubMenu("WiFi",wifiSub,wifiSize,0); break;
        case 1: drawSubMenu("BLE",bleSub,bleSize,0); break;
        case 2: drawSubMenu("NRF24",nrfSub,nrfSize,0); break;
        case 3: drawSubMenu("Settings",settingsSub,settingsSize,0); break;
      }
    }
  } else {
    int sz = (currentModule==0?wifiSize:(currentModule==1?bleSize:(currentModule==2?nrfSize:settingsSize)));
    if(checkButton(BTN_UP)){
      currentSubItem = (currentSubItem-1+sz)%sz;
    }
    if(checkButton(BTN_DOWN)){
      currentSubItem = (currentSubItem+1)%sz;
    }
    if(checkButton(BTN_UP)||checkButton(BTN_DOWN)){
      switch(currentModule){
        case 0: drawSubMenu("WiFi",wifiSub,sz,currentSubItem); break;
        case 1: drawSubMenu("BLE",bleSub,sz,currentSubItem); break;
        case 2: drawSubMenu("NRF24",nrfSub,sz,currentSubItem); break;
        case 3: drawSubMenu("Settings",settingsSub,sz,currentSubItem); break;
      }
    }
    if(checkButton(BTN_OK)){
      executeAction();
      inSubMenu = false;
      drawMainMenu();
    }
    if(checkButton(BTN_BACK)){
      inSubMenu = false;
      drawMainMenu();
    }
  }
  delay(20);
}
