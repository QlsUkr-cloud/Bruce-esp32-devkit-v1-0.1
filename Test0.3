void setup() {
    Serial.begin(115200);
    
    pinMode(BTN_UP, INPUT_PULLUP);
    pinMode(BTN_DOWN, INPUT_PULLUP);
    pinMode(BTN_OK, INPUT_PULLUP);
    pinMode(BTN_LEFT, INPUT_PULLUP);
    pinMode(BTN_RIGHT, INPUT_PULLUP);
    pinMode(BTN_BACK, INPUT_PULLUP);
    
    initDisplay();
    loadFromEEPROM();
    initRFID();
    initIR();
    initNRF();
    
    for (int x = 128; x >= 0; x -= 8) {
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_logisoso24_tr);
        u8g2.drawStr(x + 4, 32, "DIY");
        u8g2.setFont(u8g2_font_7x13B_tr);
        u8g2.drawStr(x + 4, 48, "BRUCE");
        u8g2.sendBuffer();
        delay(10);
    }
    
    WiFi.mode(WIFI_AP_STA);
    esp_wifi_set_promiscuous(true);
    esp_wifi_set_promiscuous_rx_cb(handshakeSnifferCallback);
    
    drawMainMenu();
    showMessage("DIY BRUCE v6.0 READY", 1500);
}

void loop() {
    if (currentModule == 0) {
        // Main menu navigation
        if (checkButton(BTN_LEFT)) {
            menuIndex = (menuIndex - 1 + 6) % 6;
            drawMainMenu();
        }
        if (checkButton(BTN_RIGHT)) {
            menuIndex = (menuIndex + 1) % 6;
            drawMainMenu();
        }
        if (checkButton(BTN_OK) || checkButton(BTN_DOWN)) {
            currentModule = 1;
            subIndex = 0;
            switch (menuIndex) {
                case 0: drawWiFiMenu(); break;
                case 1: drawBLEMenu(); break;
                case 2: drawNRFMenu(); break;
                case 5: drawSettingsMenu(); break;
                default: drawWiFiMenu(); break;
            }
        }
    } else {
        // Submenu navigation
        int size = 0;
        switch (menuIndex) {
            case 0: size = 8; break;
            case 1: size = 8; break;
            case 2: size = 3; break;
            case 5: size = 5; break;
            default: size = 8; break;
        }
        
        if (checkButton(BTN_UP)) {
            subIndex = (subIndex - 1 + size) % size;
            switch (menuIndex) {
                case 0: drawWiFiMenu(); break;
                case 1: drawBLEMenu(); break;
                case 2: drawNRFMenu(); break;
                case 5: drawSettingsMenu(); break;
                default: drawWiFiMenu(); break;
            }
        }
        if (checkButton(BTN_DOWN)) {
            subIndex = (subIndex + 1) % size;
            switch (menuIndex) {
                case 0: drawWiFiMenu(); break;
                case 1: drawBLEMenu(); break;
                case 2: drawNRFMenu(); break;
                case 5: drawSettingsMenu(); break;
                default: drawWiFiMenu(); break;
            }
        }
        if (checkButton(BTN_OK)) {
            switch (menuIndex) {
                case 0: executeWiFiAction(); break;
                case 1: executeBLEAction(); break;
                case 2: executeNRFAction(); break;
                case 5: executeSettingsAction(); break;
            }
            currentModule = 0;
            drawMainMenu();
        }
        if (checkButton(BTN_BACK)) {
            currentModule = 0;
            drawMainMenu();
        }
    }
    delay(20);
}
