void handleRoot() { server.send(200, "text/html", index_html); }
void handleData() {
    String json = "{\\"deauth\\":" + String(deauthPackets) + ",\\"beacon\\":" + String(beaconPackets) + ",\\"rssi\\":" + String(lastRSSI) + ",\\"uptime\\":" + String(millis()/1000) + "}";
    server.send(200, "application/json", json);
