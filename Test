struct MenuItem { const char* name; const unsigned char* icon; };
MenuItem modules[] = {{"WiFi", wifi_bits}, {"BLE", ble_bits}, {"NRF24", nrf_bits}, {"RFID", rfid_bits}, {"IR", ir_bits}, {"Settings", settings_bits}};
const int MODULE_COUNT = 6;
int moduleIdx = 0;

const char* wifiSub[] = {"SCAN","DEAUTH","BEACON","EVIL","HANDSHAKE","JAMMER","CLEAR","WEB ON","REBOOT"};
const int WIFI_SIZE = 9;
const char* bleSub[] = {"SCAN","APPLE","SAMSUNG","ANDROID","WINDOWS","IPHONE","AIRPODS","SPAM ALL","JAMMER","STOP"};
const int BLE_SIZE = 10;
const char* nrfSub[] = {"SCAN","JAMMER","SET CH","STOP"};
const int NRF_SIZE = 4;
const char* rfidSub[] = {"READ","WRITE","LIST"};
const int RFID_SIZE = 3;
const char* irSub[] = {"POWER","VOL+","VOL-"};
const int IR_SIZE = 3;
const char* settSub[] = {"WEB ON","WEB OFF","CLEAR","INFO","REBOOT"};
const int SETT_SIZE = 5;

int subIdx = 0;
enum State { S_MENU, S_SUBMENU };
State curState = S_MENU;

void drawMainMenu() {
    u8g2.clearBuffer(); drawTopBar();
    u8g2.drawXBM(48, 16, 32, 32, modules[moduleIdx].icon);
    u8g2.setFont(u8g2_font_9x15B_tr);
    u8g2.drawStr(4, 36, "<"); u8g2.drawStr(114, 36, ">");
    u8g2.setFont(u8g2_font_7x13B_tr);
    int nw = u8g2.getStrWidth(modules[moduleIdx].name);
    u8g2.drawStr((128 - nw)/2, 58, modules[moduleIdx].name);
    u8g2.sendBuffer();
}
void drawSubMenu(const char* title, const char* items[], int size, int selected) {
    u8g2.clearBuffer(); drawTopBar();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr((128 - u8g2.getStrWidth(title))/2, 10, title);
    for(int i = 0; i < size; i++) {
        int y = 24 + i * 10;
        if(i == selected) { u8g2.drawBox(0, y-8, 128, 10); u8g2.setDrawColor(0); u8g2.drawStr(14, y, items[i]); u8g2.setDrawColor(1); }
        else { u8g2.drawStr(14, y, items[i]); }
    }
    u8g2.drawHLine(0, 55, 128);
    u8g2.setFont(u8g2_font_5x7_tr);
    u8g2.drawStr(2, 63, "UP/DN=вибір OK=вхід BACK=меню");
    u8g2.sendBuffer();
}
void executeAction() {
    switch(moduleIdx) {
        case 0: switch(subIdx) { case 0: scanWiFi(); break; case 1: startWiFiDeauth(); break; case 2: startWiFiBeacon(); break; case 3: startEvilTwin(); break; case 4: startHandshakeSniffer(); break; case 5: startWiFiJammer(); break; case 6: clearAllData(); break; case 7: startWebServer(); break; case 8: rebootDevice(); break; } break;
        case 1: switch(subIdx) { case 0: scanBLE(); break; case 1: startBLEAppleJuice(); break; case 2: startBLESamsung(); break; case 3: startBLEAndroid(); break; case 4: startBLEWindows(); break; case 5: startBLEiPhone(); break; case 6: startBLEAirPods(); break; case 7: startBLESpamAll(); break; case 8: startBLEJammer(); break; case 9: stopBLEJammer(); break; } break;
        case 2: switch(subIdx) { case 0: scanNRF(); break; case 1: startNRFJammer(); break; case 2: setNRFChannel(); break; case 3: stopNRFJammer(); break; } break;
        case 3: switch(subIdx) { case 0: readRFID(); break; case 1: writeRFID(); break; } break;
        case 4: switch(subIdx) { case 0: sendIRPower(); break; case 1: sendIRVolumeUp(); break; case 2: sendIRVolumeDown(); break; } break;
        case 5: switch(subIdx) { case 0: startWebServer(); break; case 1: stopWebServer(); break; case 2: clearAllData(); break; case 3: showMsg("DIY BRUCE v5.0", 1500); break; case 4: rebootDevice(); break; } break;
    }
}

