void setup() {
    Serial.begin(115200);
    pinMode(BTN_UP, INPUT_PULLUP); pinMode(BTN_DOWN, INPUT_PULLUP); pinMode(BTN_OK, INPUT_PULLUP);
    pinMode(BTN_LEFT, INPUT_PULLUP); pinMode(BTN_RIGHT, INPUT_PULLUP); pinMode(BTN_BACK, INPUT_PULLUP);
    Wire.begin(21, 22);
    u8g2.begin(); u8g2.setContrast(200);
    SPI.begin(RFID_SCK, RFID_MISO, RFID_MOSI, RFID_SS);
    initRFID(); initIR(); initNRF();
    loadFromEEPROM();
    for(int x = 128; x >= 0; x -= 8) { u8g2.clearBuffer(); u8g2.setFont(u8g2_font_logisoso24_tr); u8g2.drawStr(x+4, 32, "DIY"); u8g2.setFont(u8g2_font_7x13B_tr); u8g2.drawStr(x+4, 48, "BRUCE"); u8g2.sendBuffer(); delay(10); }
    delay(500);
    WiFi.mode(WIFI_AP_STA);
    esp_wifi_set_promiscuous(true);
    esp_wifi_set_promiscuous_rx_cb(handshakeSnifferCallback);
    curState = S_MENU; drawMainMenu();
    showMsg("DIY BRUCE v5.0 готовий", 1500);
}
void loop() {
    if(webRunning) server.handleClient();
    switch(curState) {
        case S_MENU:
            if(btn(BTN_LEFT)) { moduleIdx = (moduleIdx - 1 + MODULE_COUNT) % MODULE_COUNT; drawMainMenu(); }
            else if(btn(BTN_RIGHT)) { moduleIdx = (moduleIdx + 1) % MODULE_COUNT; drawMainMenu(); }
            else if(btn(BTN_OK) || btn(BTN_DOWN)) {
                curState = S_SUBMENU; subIdx = 0;
                const char** items; int size;
                switch(moduleIdx) {
                    case 0: items = wifiSub; size = WIFI_SIZE; break;
                    case 1: items = bleSub; size = BLE_SIZE; break;
                    case 2: items = nrfSub; size = NRF_SIZE; break;
                    case 3: items = rfidSub; size = RFID_SIZE; break;
                    case 4: items = irSub; size = IR_SIZE; break;
                    default: items = settSub; size = SETT_SIZE; break;
                }
                drawSubMenu(modules[moduleIdx].name, items, size, subIdx);
            }
            break;
        case S_SUBMENU:
            int size; const char** items;
            switch(moduleIdx) {
                case 0: items = wifiSub; size = WIFI_SIZE; break;
                case 1: items = bleSub; size = BLE_SIZE; break;
                case 2: items = nrfSub; size = NRF_SIZE; break;
                case 3: items = rfidSub; size = RFID_SIZE; break;
                case 4: items = irSub; size = IR_SIZE; break;
                default: items = settSub; size = SETT_SIZE; break;
            }
            if(btn(BTN_UP)) { subIdx = (subIdx - 1 + size) % size; drawSubMenu(modules[moduleIdx].name, items, size, subIdx); }
            else if(btn(BTN_DOWN)) { subIdx = (subIdx + 1) % size; drawSubMenu(modules[moduleIdx].name, items, size, subIdx); }
            else if(btn(BTN_OK)) { executeAction(); curState = S_MENU; drawMainMenu(); }
            else if(btn(BTN_BACK)) { curState = S_MENU; drawMainMenu(); }
            break;
    }
    delay(20);
}
