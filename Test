// ==================== NRF24 ФУНКЦІЇ ====================
void initNRF() {
    if(!radio.begin()) { nrfOK = false; showMsg("NRF24 не знайдено!", 1500); return; }
    radio.setChannel(nrfCh); radio.setPALevel(RF24_PA_LOW); radio.setDataRate(RF24_1MBPS); radio.setAutoAck(false);
    nrfOK = true; showMsg("NRF24 готовий", 1000);
}
void scanNRF() {
    if(!nrfOK) { showMsg("NRF24 не підключено!", 1000); return; }
    int active = 0;
    for(int ch = 0; ch <= 125; ch++) {
        radio.setChannel(ch); radio.startListening(); delayMicroseconds(200);
        if(radio.testCarrier()) active++;
        radio.stopListening();
    }
    radio.setChannel(nrfCh);
    char buf[32]; sprintf(buf, "Активних: %d", active);
    showMsg(buf, 1500);
}
void startNRFJammer() {
    if(!nrfOK) { showMsg("NRF24 не підключено!", 1000); return; }
    nrfJamActive = true; radio.stopListening();
    showMsg("NRF JAMMER запущено", 1000);
    while(nrfJamActive) {
        for(int ch = 0; ch <= 125 && nrfJamActive; ch++) {
            radio.setChannel(ch);
            uint8_t junk[32]; for(int i = 0; i < 32; i++) junk[i] = random(256);
            radio.write(&junk, 32);
        }
        u8g2.clearBuffer(); drawTopBar();
        u8g2.setFont(u8g2_font_helvB08_tr);
        u8g2.drawStr(15, 30, "NRF JAMMER");
        u8g2.drawStr(5, 60, "BACK - Зупинити");
        u8g2.sendBuffer();
        if(btn(BTN_BACK)) nrfJamActive = false;
        delay(5);
    }
    radio.setChannel(nrfCh); showMsg("NRF JAMMER зупинено", 1000);
}
void stopNRFJammer() { nrfJamActive = false; }
void setNRFChannel() {
    while(true) {
        u8g2.clearBuffer(); drawTopBar();
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(35, 15, "NRF Канал");
        u8g2.setFont(u8g2_font_logisoso24_tr);
        char buf[8]; sprintf(buf, "%d", nrfCh);
        int w = u8g2.getStrWidth(buf);
        u8g2.drawStr((128-w)/2, 48, buf);
        u8g2.drawStr(5, 30, "<"); u8g2.drawStr(110, 30, ">");
        u8g2.setFont(u8g2_font_5x7_tr);
        u8g2.drawStr(2, 63, "LR=зміна OK=зберегти BACK");
        u8g2.sendBuffer();
        if(btn(BTN_LEFT) && nrfCh > 0) nrfCh--;
        else if(btn(BTN_RIGHT) && nrfCh < 125) nrfCh++;
        else if(btn(BTN_OK)) { if(nrfOK) radio.setChannel(nrfCh); showMsg("Канал збережено!", 1000); break; }
        else if(btn(BTN_BACK)) break;
        delay(50);
    }
}

