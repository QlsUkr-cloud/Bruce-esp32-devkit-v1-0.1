void readRFID() {
    showMsg("Піднесіть картку...", 1000);
    if(!rfid.PICC_IsNewCardPresent()) { showMsg("Немає картки", 1000); return; }
    if(!rfid.PICC_ReadCardSerial()) { showMsg("Помилка читання", 1000); return; }
    String uid = "";
    for(byte i = 0; i < rfid.uid.size; i++) { uid += String(rfid.uid.uidByte[i], HEX); if(i < rfid.uid.size-1) uid += ":"; }
    lastRFIDUID = uid;
    savedRFIDUIDs += uid + "\\n";
    saveToEEPROM();
    char buf[64]; sprintf(buf, "UID: %s", uid.c_str());
    showMsg(buf, 2000);
    rfid.PICC_HaltA();
}
