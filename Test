// ==================== СИСТЕМНІ ФУНКЦІЇ ====================
bool btn(int pin) {
    if(digitalRead(pin) == LOW && millis() - lastBtnTime > debounceDelay) {
        lastBtnTime = millis(); return true;
    }
    return false;
}

void drawTopBar() {
    char buf[16];
    unsigned long seconds = millis() / 1000;
    int h = (seconds / 3600) % 24, m = (seconds / 60) % 60, s = seconds % 60;
    snprintf(buf, sizeof(buf), "%02d:%02d:%02d", h, m, s);
    u8g2.setFont(u8g2_font_6x13_tr);
    u8g2.drawStr(2, 9, buf);
    u8g2.drawFrame(114, 1, 12, 6);
    u8g2.drawBox(126, 3, 2, 2);
    u8g2.drawBox(115, 2, 9, 4);
    u8g2.setCursor(55, 9); u8g2.print("67%");
    u8g2.setCursor(100, 9); u8g2.print(String(lastRSSI) + "dB");
    u8g2.drawLine(0, 10, 128, 10);
}

void showMsg(const char* msg, int delayMs) {
    u8g2.clearBuffer(); drawTopBar();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(10, 35, msg);
    u8g2.sendBuffer();
    delay(delayMs);
}

void saveToEEPROM() {
    EEPROM.begin(4096);
    String allData = "===PASSWORDS===\\n" + capturedPasswords + "\\n===HANDSHAKES===\\n" + handshakes + "\\n===RFID===\\n" + savedRFIDUIDs + "\\n===END===\\n";
    for(int i = 0; i < allData.length() && i < 4095; i++) EEPROM.write(i, allData[i]);
    EEPROM.write(allData.length(), 0);
    EEPROM.commit(); EEPROM.end();
}

void loadFromEEPROM() {
    EEPROM.begin(4096);
    String loaded = "";
    for(int i = 0; i < 4096; i++) { char c = char(EEPROM.read(i)); if(c == 0) break; loaded += c; }
    int passStart = loaded.indexOf("===PASSWORDS===\\n"), handStart = loaded.indexOf("===HANDSHAKES===\\n"), rfidStart = loaded.indexOf("===RFID===\\n");
    if(passStart != -1 && handStart != -1) {
        capturedPasswords = loaded.substring(passStart + 16, handStart - 1);
        handshakes = loaded.substring(handStart + 16, rfidStart - 1);
        savedRFIDUIDs = loaded.substring(rfidStart + 9, loaded.indexOf("===END===\\n") - 1);
    }
    EEPROM.end();
}

void clearAllData() { capturedPasswords = ""; handshakes = ""; savedRFIDUIDs = ""; saveToEEPROM(); showMsg("Всі дані очищено!", 1000); }
void rebootDevice() { showMsg("Перезавантаження...", 1000); delay(500); ESP.restart(); }

