STORAGE_CPP = '''#include "StorageModule.h"
#include "DisplayModule.h"

String storagePasswords = "";
String storageHandshakes = "";

void storageInit() {
    EEPROM.begin(4096);
}

void storageSave() {
    String allData = "===PASSWORDS_START===\\n" + storagePasswords + 
                     "===PASSWORDS_END===\\n" +
                     "===HANDSHAKES_START===\\n" + storageHandshakes + 
                     "===HANDSHAKES_END===\\n";
    
    for (int i = 0; i < allData.length() && i < 4095; i++) {
        EEPROM.write(i, allData[i]);
    }
    EEPROM.write(allData.length(), 0);
    EEPROM.commit();
}

void storageLoad() {
    storagePasswords = "";
    storageHandshakes = "";
    
    String loaded = "";
    for (int i = 0; i < 4096; i++) {
        char c = char(EEPROM.read(i));
        if (c == 0) break;
        loaded += c;
    }
    
    int passStart = loaded.indexOf("===PASSWORDS_START===\\n");
    int passEnd = loaded.indexOf("===PASSWORDS_END===\\n");
    int handStart = loaded.indexOf("===HANDSHAKES_START===\\n");
    int handEnd = loaded.indexOf("===HANDSHAKES_END===\\n");
    
    if (passStart != -1 && passEnd != -1) {
        storagePasswords = loaded.substring(passStart + 23, passEnd);
    }
    if (handStart != -1 && handEnd != -1) {
        storageHandshakes = loaded.substring(handStart + 24, handEnd);
    }
}

void storageAddPassword(const String& password) {
    storagePasswords += "[PASS] " + password + " | Time: " + String(millis() / 1000) + "s\\n";
    storageSave();
}

void storageAddHandshake(const String& handshake) {
    storageHandshakes += handshake;
    storageSave();
}

void storageClear() {
    storagePasswords = "";
    storageHandshakes = "";
    storageSave();
    displayShowMessage("Storage cleared", 1000);
}

void storageFormat() {
    for (int i = 0; i < 4096; i++) {
        EEPROM.write(i, 0);
    }
    EEPROM.commit();
    storagePasswords = "";
    storageHandshakes = "";
    displayShowMessage("Storage formatted", 1000);
}
'''

