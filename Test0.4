DISPLAY_CPP = '''#include "DisplayModule.h"
#include "Icons.h"

U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2(U8G2_R0, U8X8_PIN_NONE, 21, 22);
unsigned long displayLastDebounce = 0;
const unsigned long displayDebounceDelay = 200;

extern int wifiLastRSSI;

void displayInit() {
    Wire.begin(21, 22);
    u8g2.begin();
    u8g2.setContrast(200);
    u8g2.setFlipMode(0);
}

void displayDrawTopBar() {
    char buf[16];
    unsigned long seconds = millis() / 1000;
    int h = (seconds / 3600) % 24;
    int m = (seconds / 60) % 60;
    int s = seconds % 60;
    snprintf(buf, sizeof(buf), "%02d:%02d:%02d", h, m, s);
    
    u8g2.setFont(u8g2_font_6x13_tr);
    u8g2.drawStr(2, 9, buf);
    u8g2.drawFrame(114, 1, 12, 6);
    u8g2.drawBox(126, 3, 2, 2);
    u8g2.drawBox(115, 2, 9, 4);
    u8g2.setCursor(55, 9);
    u8g2.print("67%");
    u8g2.setCursor(100, 9);
    u8g2.print(String(wifiLastRSSI) + "dB");
    u8g2.drawLine(0, 10, 128, 10);
}

void displayShowMessage(const char* msg, int delayMs) {
    u8g2.clearBuffer();
    displayDrawTopBar();
    u8g2.setFont(u8g2_font_6x10_tr);
    
    int len = strlen(msg);
    if (len <= 21) {
        u8g2.drawStr((128 - u8g2.getStrWidth(msg)) / 2, 35, msg);
    } else {
        char line1[22], line2[22];
        strncpy(line1, msg, 21);
        line1[21] = '\\0';
        strncpy(line2, msg + 21, 21);
        line2[21] = '\\0';
        u8g2.drawStr((128 - u8g2.getStrWidth(line1)) / 2, 30, line1);
        u8g2.drawStr((128 - u8g2.getStrWidth(line2)) / 2, 45, line2);
    }
    
    u8g2.sendBuffer();
    delay(delayMs);
}

bool displayCheckButton(int pin) {
    if (digitalRead(pin) == LOW && (millis() - displayLastDebounce) > displayDebounceDelay) {
        displayLastDebounce = millis();
        return true;
    }
    return false;
}

void displayDrawMainMenu(int menuIndex) {
    u8g2.clearBuffer();
    displayDrawTopBar();
    
    const char* menuItems[] = {"WiFi", "BLE", "NRF24", "RFID", "IR", "Settings"};
    const unsigned char* icons[] = {wifi_icon, ble_icon, nrf_icon, rfid_icon, ir_icon, settings_icon};
    int count = 6;
    
    u8g2.drawXBM(48, 16, 32, 32, icons[menuIndex]);
    u8g2.setFont(u8g2_font_9x15B_tr);
    u8g2.drawStr(4, 36, "<");
    u8g2.drawStr(114, 36, ">");
    u8g2.setFont(u8g2_font_7x13B_tr);
    
    int w = u8g2.getStrWidth(menuItems[menuIndex]);
    u8g2.drawStr((128 - w) / 2, 58, menuItems[menuIndex]);
    u8g2.sendBuffer();
}

void displayDrawSubMenu(const char* title, const char* items[], int size, int selected) {
    u8g2.clearBuffer();
    displayDrawTopBar();
    u8g2.setFont(u8g2_font_6x10_tr);
    
    int titleW = u8g2.getStrWidth(title);
    u8g2.drawStr((128 - titleW) / 2, 10, title);
    
    for (int i = 0; i < size; i++) {
        int y = 24 + i * 10;
        if (i == selected) {
            u8g2.drawBox(0, y - 8, 128, 10);
            u8g2.setDrawColor(0);
            u8g2.drawStr(14, y, items[i]);
            u8g2.setDrawColor(1);
        } else {
            u8g2.drawStr(14, y, items[i]);
        }
    }
    
    u8g2.drawHLine(0, 55, 128);
    u8g2.setFont(u8g2_font_5x7_tr);
    u8g2.drawStr(2, 63, "UP/DOWN=select OK=enter BACK=menu");
    u8g2.sendBuffer();
}

void displayBootAnimation() {
    for (int x = 128; x >= 0; x -= 8) {
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_logisoso24_tr);
        u8g2.drawStr(x + 4, 32, "DIY");
        u8g2.setFont(u8g2_font_7x13B_tr);
        u8g2.drawStr(x + 4, 48, "BRUCE");
        u8g2.sendBuffer();
        delay(10);
    }
    delay(500);
}
