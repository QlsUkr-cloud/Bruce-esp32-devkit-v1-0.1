def create_project():
    base = PROJECT_NAME
    if os.path.exists(base):
        shutil.rmtree(base)
    
    # Create directories
    os.makedirs(os.path.join(base, "src"))
    os.makedirs(os.path.join(base, "include"))
    os.makedirs(os.path.join(base, "lib", "WiFi"))
    os.makedirs(os.path.join(base, "lib", "BLE"))
    os.makedirs(os.path.join(base, "lib", "Display"))
    os.makedirs(os.path.join(base, "lib", "Storage"))
    
    # Write files
    with open(os.path.join(base, "platformio.ini"), "w") as f:
        f.write(PLATFORMIO_INI)
    
    with open(os.path.join(base, "include", "Icons.h"), "w") as f:
        f.write(ICONS_H)
    
    with open(os.path.join(base, "lib", "WiFi", "WiFiModule.h"), "w") as f:
        f.write(WIFI_H)
    with open(os.path.join(base, "lib", "WiFi", "WiFiModule.cpp"), "w") as f:
        f.write(WIFI_CPP)
    
    with open(os.path.join(base, "lib", "BLE", "BLEModule.h"), "w") as f:
        f.write(BLE_H)
    with open(os.path.join(base, "lib", "BLE", "BLEModule.cpp"), "w") as f:
        f.write(BLE_CPP)
    
