STORAGE_H = '''#ifndef STORAGE_MODULE_H
#define STORAGE_MODULE_H

#include <Arduino.h>
#include <EEPROM.h>

extern String storagePasswords;
extern String storageHandshakes;

void storageInit();
void storageSave();
void storageLoad();
void storageAddPassword(const String& password);
void storageAddHandshake(const String& handshake);
void storageClear();
void storageFormat();

