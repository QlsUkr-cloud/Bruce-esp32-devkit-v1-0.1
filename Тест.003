</div>
<h3>CAPTURED PASSWORDS</h3>
<pre id="passList">Loading...</pre>
<h3>CAPTURED HANDSHAKES</h3>
<pre id="handList">Loading...</pre>
<h3>SYSTEM INFO</h3>
<pre id="sysInfo">Loading...</pre>
</div>
</div>
<script>
var rssiHistory=[];
var logDiv=document.getElementById('log');
function addLog(msg){var d=document.createElement('div');d.className='log-entry';d.innerHTML='<span class="log-time">['+new Date().toLocaleTimeString()+']</span> '+msg;logDiv.appendChild(d);logDiv.scrollTop=logDiv.scrollHeight;}
function runCmd(cmd){addLog('CMD: '+cmd);fetch('/cmd?c='+encodeURIComponent(cmd)).then(r=>r.text()).then(t=>{addLog('RESP: '+t);if(cmd==='view_pass')updatePassList();if(cmd==='view_hand')updateHandList();if(cmd==='sysinfo')updateSysInfo();if(cmd==='ble_scan')document.getElementById('bleResult').innerText=t;if(cmd==='nrf_scan')document.getElementById('nrfResult').innerText=t;if(cmd==='rfid_read')document.getElementById('rfidResult').innerText=t;if(cmd==='ir_power'||cmd==='ir_bavis'||cmd==='ir_samsung')document.getElementById('irResult').innerText=t;});}
function updateData(){fetch('/data').then(r=>r.json()).then(d=>{document.getElementById('deauthCount').innerText=d.deauth||0;document.getElementById('beaconCount').innerText=d.beacon||0;document.getElementById('rssiValue').innerText=d.rssi||-50;document.getElementById('uptime').innerText=d.uptime||0;if(d.rssi){rssiHistory.push(d.rssi);if(rssiHistory.length>50)rssiHistory.shift();drawChart();}}).catch(e=>console.log(e));}
function drawChart(){var canvas=document.getElementById('rssiChart');if(!canvas)return;var ctx=canvas.getContext('2d');var w=canvas.clientWidth,h=canvas.clientHeight;canvas.width=w;canvas.height=h;ctx.fillStyle='#070b1a';ctx.fillRect(0,0,w,h);if(rssiHistory.length<2)return;var step=w/(rssiHistory.length-1);ctx.beginPath();for(var i=0;i<rssiHistory.length;i++){var x=i*step;var y=h-((rssiHistory[i]+90)/70)*h;if(i===0)ctx.moveTo(x,y);else ctx.lineTo(x,y);}ctx.strokeStyle='#ff6b35';ctx.lineWidth=2.5;ctx.stroke();}
function updatePassList(){fetch('/cmd?c=view_pass').then(r=>r.text()).then(t=>document.getElementById('passList').innerText=t||'(empty)');}
function updateHandList(){fetch('/cmd?c=view_hand').then(r=>r.text()).then(t=>document.getElementById('handList').innerText=t||'(empty)');}
function updateSysInfo(){fetch('/cmd?c=sysinfo').then(r=>r.text()).then(t=>document.getElementById('sysInfo').innerText=t);}
setInterval(updateData,1000);setInterval(updatePassList,5000);setInterval(updateHandList,5000);updateSysInfo();
document.querySelectorAll('.tab').forEach(tab=>{tab.addEventListener('click',()=>{document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));tab.classList.add('active');document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('active'));document.getElementById(tab.dataset.tab).classList.add('active');if(tab.dataset.tab==='settings'){updatePassList();updateHandList();updateSysInfo();}});});
window.onload=function(){addLog('DIY BRUCE v8.0 READY');updatePassList();updateHandList();updateSysInfo();};
</script>
</body>
</html>
'''

