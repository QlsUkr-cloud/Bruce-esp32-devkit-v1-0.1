INDEX_HTML = '''<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>DIY BRUCE v8.0 - FULL CONTROL</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{background:linear-gradient(135deg,#0a0a1a 0%,#0a0a1a 100%);font-family:'Segoe UI','Roboto',monospace;color:#e0e0e0;padding:16px;min-height:100vh;}
.header{background:linear-gradient(135deg,#1a1f2e,#0f1420);border-radius:28px;padding:20px;margin-bottom:20px;text-align:center;border:1px solid rgba(255,107,53,0.3);}
h1{font-size:2rem;background:linear-gradient(135deg,#ff6b35,#ff3a00);-webkit-background-clip:text;background-clip:text;color:transparent;}
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:12px;margin-bottom:20px;}
.stat-card{background:rgba(16,21,46,0.8);backdrop-filter:blur(10px);border-radius:20px;padding:16px;text-align:center;border:1px solid rgba(255,107,53,0.2);}
.stat-value{font-size:28px;font-weight:bold;color:#ff6b35;}
.stat-label{font-size:12px;opacity:0.7;margin-top:8px;}
.tabs{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;background:rgba(0,0,0,0.3);padding:8px;border-radius:60px;}
.tab{padding:10px 20px;border-radius:40px;cursor:pointer;transition:all 0.2s;font-weight:600;background:transparent;color:#aaa;}
.tab.active{background:#ff6b35;color:white;box-shadow:0 4px 15px rgba(255,107,53,0.3);}
.tab-content{display:none;animation:fadeIn 0.3s;}
.tab-content.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.card{background:rgba(16,21,46,0.8);backdrop-filter:blur(10px);border-radius:24px;padding:20px;margin-bottom:20px;border:1px solid rgba(255,255,255,0.05);}
.btn-group{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:20px;}
button{background:linear-gradient(135deg,#1e2a47,#151e36);border:none;padding:12px 20px;border-radius:40px;color:white;font-weight:600;cursor:pointer;transition:all 0.2s;font-size:14px;border:1px solid rgba(255,255,255,0.05);}
button:active{transform:scale(0.96);}
.btn-primary{background:linear-gradient(135deg,#ff6b35,#ff3a00);}
.btn-danger{background:linear-gradient(135deg,#b91c1c,#8b0000);}
.btn-success{background:linear-gradient(135deg,#28a745,#1e7e34);}
.btn-warning{background:linear-gradient(135deg,#ffc107,#e0a800);color:#1a1a2e;}
canvas{background:rgba(7,11,26,0.8);border-radius:20px;width:100%;height:200px;margin:20px 0;}
.log{background:rgba(7,11,26,0.9);height:250px;overflow-y:auto;font-family:'Courier New',monospace;font-size:12px;padding:16px;border-radius:20px;border:1px solid rgba(255,107,53,0.2);}
.log-entry{padding:4px 0;border-bottom:1px solid rgba(255,255,255,0.05);}
.log-time{color:#ff6b35;margin-right:10px;}
pre{background:rgba(7,11,26,0.9);padding:16px;border-radius:20px;overflow-x:auto;font-size:12px;font-family:'Courier New',monospace;white-space:pre-wrap;word-wrap:break-word;border:1px solid rgba(255,107,53,0.2);}
iframe{width:100%;height:500px;border:none;border-radius:20px;background:white;}
@media(max-width:600px){body{padding:10px;}button{padding:8px 14px;font-size:12px;}.stat-value{font-size:24px;}}
</style>
</head>
<body>
<div class="header"><h1>DIY BRUCE v8.0</h1><p>Professional Security Testing Tool</p></div>
<div class="stats-grid">
<div class="stat-card"><div class="stat-value" id="deauthCount">0</div><div class="stat-label">DEAUTH PKT</div></div>
<div class="stat-card"><div class="stat-value" id="beaconCount">0</div><div class="stat-label">BEACON PKT</div></div>
