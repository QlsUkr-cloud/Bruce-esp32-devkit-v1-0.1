platform = espressif32@6.5.0
board = esp32dev
framework = arduino
monitor_speed = 115200
upload_speed = 921600

build_flags =
    -DCORE_DEBUG_LEVEL=0
    -DARDUINO_USB_MODE=1
    -DARDUINO_USB_CDC_ON_BOOT=0

lib_deps =
    olikraus/U8g2@^2.35.15
    nrf24/RF24@^1.4.11
    h2zero/NimBLE-Arduino@^1.4.1
    miguelbalboa/MFRC522@^1.4.6
    crankyoldgit/IRremoteESP8266@^2.8.6
'''

