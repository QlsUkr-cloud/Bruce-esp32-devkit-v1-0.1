PORTAL_HTML = '''<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Google Sign In</title><style>
body{font-family:Roboto;text-align:center;padding:20px;background:#fff;}
.logo{font-size:56px;font-weight:bold;color:#4285F4;margin-top:50px;}
.form-box{max-width:400px;margin:0 auto;padding:20px;}
input{width:100%;padding:14px;margin:10px 0;border:1px solid #ddd;border-radius:24px;font-size:16px;}
button{background:#4285F4;color:white;border:none;padding:12px;border-radius:24px;width:100%;cursor:pointer;font-size:16px;}
button:hover{background:#357ae8;}
