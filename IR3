#include <IRremote.h>

#define IR_PIN 22  // СПРОБУЙТЕ 22, 23, 24, 25

IRrecv irrecv(IR_PIN);

void setup() {
  Serial.begin(115200);
  delay(1000);
  
  Serial.println("=================================");
  Serial.println("IR RECEIVER TEST - MEGA 2560");
  Serial.println("=================================");
  Serial.print("Підключення до піна: ");
  Serial.println(IR_PIN);
  Serial.println("");
  
  // Запускаємо IR приймач
  irrecv.enableIRIn();
  
  Serial.println("✅ IR приймач запущено!");
  Serial.println("📡 Натискайте кнопки на пульті");
  Serial.println("=================================");
  Serial.println("");
  
  pinMode(13, OUTPUT);
  digitalWrite(13, HIGH);
  delay(500);
  digitalWrite(13, LOW);
}

void loop() {
  // Постійно виводимо крапку, щоб знати що програма працює
  static unsigned long lastPrint = 0;
  if (millis() - lastPrint > 5000) {
    Serial.print(".");
    lastPrint = millis();
  }
  
  if (irrecv.decode()) {
    digitalWrite(13, HIGH);
    
    Serial.println("");
    Serial.println("!!! СИГНАЛ ОТРИМАНО !!!");
    Serial.print("HEX: 0x");
    Serial.println(irrecv.decodedIRData.decodedRawData, HEX);
    Serial.print("Bits: ");
    Serial.println(irrecv.decodedIRData.numberOfBits);
    Serial.println("");
    
    digitalWrite(13, LOW);
    irrecv.resume();
    delay(200);
  }
}
