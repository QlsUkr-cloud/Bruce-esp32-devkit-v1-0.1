        int size = moduleIdx==0?WIFI_SIZE:(moduleIdx==1?BLE_SIZE:(moduleIdx==2?NRF_SIZE:SETT_SIZE));
        drawSubMenu(modules[moduleIdx].name, items, size, subIdx);
    }
}

void loopSub() {
    int size = moduleIdx==0?WIFI_SIZE:(moduleIdx==1?BLE_SIZE:(moduleIdx==2?NRF_SIZE:SETT_SIZE));
    const char** items = moduleIdx==0?wifiSub:(moduleIdx==1?bleSub:(moduleIdx==2?nrfSub:settSub));
    if (btn(BTN_UP)) { subIdx = (subIdx - 1 + size) % size; drawSubMenu(modules[moduleIdx].name, items, size, subIdx); }
    else if (btn(BTN_DOWN)) { subIdx = (subIdx + 1) % size; drawSubMenu(modules[moduleIdx].name, items, size, subIdx); }
    else if (btn(BTN_OK)) { enterAction(); }
    else if (btn(BTN_BACK)) { curState = S_MENU; drawMainMenu(); }
}

