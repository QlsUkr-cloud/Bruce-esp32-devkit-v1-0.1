// ==================== NRF24 АТАКИ ====================
void nrfScan() {
    if (!radio.isChipConnected()) { showMessage("NRF24 NOT FOUND!", 1000); return; }
    int active = 0;
    showMessage("NRF SCAN...", 500);
    for (int ch = 0; ch <= 125; ch++) {
        radio.setChannel(ch);
        radio.startListening();
        delayMicroseconds(200);
        if (radio.testCarrier()) active++;
        radio.stopListening();
    }
    char buf[32];
    sprintf(buf, "ACTIVE: %d", active);
    showMessage(buf, 1500);
    radio.setChannel(nrfCh);
}
void nrfJam() {
    if (!radio.isChipConnected()) { showMessage("NRF24 NOT FOUND!", 1000); return; }
    nrfJamActive = true;
    radio.setAutoAck(false);
    radio.setPayloadSize(32);
    showMessage("NRF JAMMER", 1000);
    while (nrfJamActive) {
        for (int ch = 0; ch < 125 && nrfJamActive; ch++) {
            radio.setChannel(ch);
            uint8_t junk[32];
            for (int i = 0; i < 32; i++) junk[i] = random(256);
            radio.stopListening();
            radio.write(&junk, 32);
            if (btn(BTN_BACK)) nrfJamActive = false;
            delay(1);
        }
    }
    radio.stopListening();
    radio.setChannel(nrfCh);
    showMessage("NRF JAM STOPPED", 1000);
}
void nrfSend() {
    if (!radio.isChipConnected()) { showMessage("NRF24 NOT FOUND!", 1000); return; }
    radio.stopListening();
    byte addr[6] = "00001";
    radio.openWritingPipe(addr);
    char msg[] = "HELLO";
    radio.write(msg, sizeof(msg));
    showMessage("SENT: HELLO", 1000);
}
