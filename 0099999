void setup() {
    Serial.begin(115200);
    pinMode(BTN_UP, INPUT_PULLUP); pinMode(BTN_DOWN, INPUT_PULLUP); pinMode(BTN_OK, INPUT_PULLUP);
    pinMode(BTN_LEFT, INPUT_PULLUP); pinMode(BTN_RIGHT, INPUT_PULLUP); pinMode(BTN_BACK, INPUT_PULLUP);
    Wire.begin(21, 22);
    u8g2.begin();
    u8g2.setContrast(200);
    SPI.begin(18, 19, 23, NRF_CSN);
    radio.begin();
    if (radio.isChipConnected()) { radio.setChannel(76); radio.setPALevel(RF24_PA_LOW); nrfOK = true; }
    loadData();
    uptimeStart = millis();
    for (int x = 128; x >= 0; x -= 8) {
        u8g2.clearBuffer();
        u8g2.setFont(u8g2_font_logisoso24_tr);
        u8g2.drawStr(x + 4, 32, "DIY");
        u8g2.setFont(u8g2_font_7x13B_tr);
        u8g2.drawStr(x + 4, 48, "BRUCE");
        u8g2.sendBuffer();
        delay(10);
    }
    delay(500);
    drawMainMenu();
    esp_wifi_set_promiscuous(true);
    esp_wifi_set_promiscuous_rx_cb(handshakeSniffer);
    WiFi.mode(WIFI_AP_STA);
}

// ==================== LOOP ====================
void loop() {
    if (webRunning) { dnsServer.processNextRequest(); server.handleClient(); }
    if (WiFi.softAPgetStationNum() > 0) lastRSSI = WiFi.RSSI();
    if (!inSubMenu) {
        if (btn(BTN_LEFT)) { currentModule = (currentModule - 1 + moduleCount) % moduleCount; drawMainMenu(); }
        else if (btn(BTN_RIGHT)) { currentModule = (currentModule + 1) % moduleCount; drawMainMenu(); }
        else if (btn(BTN_OK) || btn(BTN_DOWN)) {
            inSubMenu = true;
            currentSub = 0;
            switch (currentModule) {
                case 0: drawSubMenu("WiFi", wifiSub, wifiSize, 0); break;
                case 1: drawSubMenu("BLE", bleSub, bleSize, 0); break;
                case 2: drawSubMenu("NRF24", nrfSub, nrfSize, 0); break;
                case 3: drawSubMenu("IR", irSub, irSize, 0); break;
                case 4: drawSubMenu("Tools", toolsSub, toolsSize, 0); break;
                case 5: drawSubMenu("Settings", settingsSub, settingsSize, 0); break;
            }
        }
    } else {
        int sz = (currentModule==0?wifiSize:currentModule==1?bleSize:currentModule==2?nrfSize:currentModule==3?irSize:currentModule==4?toolsSize:settingsSize);
        if (btn(BTN_UP)) currentSub = (currentSub - 1 + sz) % sz;
        if (btn(BTN_DOWN)) currentSub = (currentSub + 1) % sz;
        if (btn(BTN_UP) || btn(BTN_DOWN)) {
            switch (currentModule) {
                case 0: drawSubMenu("WiFi", wifiSub, sz, currentSub); break;
                case 1: drawSubMenu("BLE", bleSub, sz, currentSub); break;
                case 2: drawSubMenu("NRF24", nrfSub, sz, currentSub); break;
                case 3: drawSubMenu("IR", irSub, sz, currentSub); break;
                case 4: drawSubMenu("Tools", toolsSub, sz, currentSub); break;
                case 5: drawSubMenu("Settings", settingsSub, sz, currentSub); break;
            }
        }
        if (btn(BTN_OK)) { executeAction(); inSubMenu = false; drawMainMenu(); }
        if (btn(BTN_BACK)) { inSubMenu = false; drawMainMenu(); }
    }
    delay(20);
}
