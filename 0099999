void setBrightness() {
    while (true) {
        u8g2.clearBuffer();
        drawTopBar();
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(40, 10, "BRIGHTNESS");
        u8g2.drawFrame(8, 32, 112, 12);
        u8g2.drawBox(8, 32, contrast * 112 / 255, 12);
        char buf[8];
        sprintf(buf, "%d%%", contrast * 100 / 255);
        u8g2.setFont(u8g2_font_6x10_tr);
        int w = u8g2.getStrWidth(buf);
        u8g2.drawStr((128 - w) / 2, 52, buf);
        u8g2.drawStr(8, 30, "<");
        u8g2.drawStr(110, 30, ">");
        u8g2.drawStr(2, 62, "LR=change  OK=save  BACK=exit");
        u8g2.sendBuffer();
        if (btn(BTN_LEFT) && contrast > 10) contrast -= 10;
        else if (btn(BTN_RIGHT) && contrast < 255) contrast += 10;
        else if (btn(BTN_OK)) {
            EEPROM.begin(32);
            EEPROM.write(1, contrast);
            EEPROM.commit();
            EEPROM.end();
            u8g2.setContrast(contrast);
            showMessage("SAVED!", 1000);
            break;
        } else if (btn(BTN_BACK)) break;
        delay(50);
    }
}
