void drawSubMenu(const char* title, const char* items[], int size, int selected) {
    u8g2.clearBuffer();
    drawTopBar();
    u8g2.drawBox(0, 11, 128, 12);
    u8g2.setDrawColor(0);
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(2, 21, title);
    u8g2.setDrawColor(1);
    u8g2.drawLine(0, 23, 128, 23);
    int start = 0;
    if (selected >= 2) start = selected - 2;
    if (start + 4 > size) start = size - 4;
    if (start < 0) start = 0;
    for (int i = start; i < start + 4 && i < size; i++) {
        int y = 26 + (i - start) * 10;
        if (i == selected) {
            u8g2.drawBox(0, y-8, 128, 10);
            u8g2.setDrawColor(0);
            u8g2.drawXBM(2, y-6, 12, 12, folder_12);
            u8g2.drawXBM(16, y-6, 12, 12, scan_12);
            u8g2.setCursor(30, y);
            u8g2.print(items[i]);
            u8g2.setDrawColor(1);
        } else {
            u8g2.drawXBM(2, y-6, 12, 12, folder_12);
            u8g2.drawXBM(16, y-6, 12, 12, scan_12);
            u8g2.setCursor(30, y);
            u8g2.print(items[i]);
        }
    }
    u8g2.sendBuffer();
}

