void setNRFCh() {
    while (true) {
        u8g2.clearBuffer();
        drawTopBar();
        u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(40, 10, "NRF CHANNEL");
        u8g2.setFont(u8g2_font_logisoso24_tr);
        char buf[8];
        sprintf(buf, "%d", nrfCh);
        int w = u8g2.getStrWidth(buf);
        u8g2.drawStr((128 - w) / 2, 46, buf);
        u8g2.drawStr(8, 30, "<");
        u8g2.drawStr(110, 30, ">");
        u8g2.drawStr(2, 62, "LR=change  OK=save  BACK=exit");
        u8g2.sendBuffer();
        if (btn(BTN_LEFT) && nrfCh > 0) nrfCh--;
        else if (btn(BTN_RIGHT) && nrfCh < 125) nrfCh++;
        else if (btn(BTN_OK)) {
            EEPROM.begin(32);
            EEPROM.write(0, nrfCh);
            EEPROM.commit();
            EEPROM.end();
            if (radio.isChipConnected()) radio.setChannel(nrfCh);
            showMessage("SAVED!", 1000);
            break;
        } else if (btn(BTN_BACK)) break;
        delay(50);
    }
}
