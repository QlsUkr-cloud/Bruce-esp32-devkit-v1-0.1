bool checkButton(int pin) {
    if (digitalRead(pin) == LOW && (millis() - lastButtonTime) > 200) {
        lastButtonTime = millis();
        return true;
    }
    return false;
}

void drawTopBar() {
    char buf[16];
    unsigned long sec = (millis() - uptimeStart) / 1000;
    int h = (sec / 3600) % 24;
    int m = (sec / 60) % 60;
    int s = sec % 60;
    sprintf(buf, "%02d:%02d:%02d", h, m, s);
    u8g2.setFont(u8g2_font_6x13_tr);
    u8g2.drawStr(2, 9, buf);
    u8g2.setCursor(100, 9);
    u8g2.print(String(lastRSSI) + "dB");
    u8g2.drawLine(0, 10, 128, 10);
}

void showMessage(const char* msg, int delayMs) {
    u8g2.clearBuffer();
    drawTopBar();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(10, 35, msg);
    u8g2.sendBuffer();
    delay(delayMs);
}

