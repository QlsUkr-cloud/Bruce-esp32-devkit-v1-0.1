void scanBLE() {
    showMessage("Scanning BLE...", 500);
    BLEDevice::init("");
    BLEScan* pScan = BLEDevice::getScan();
    pScan->setActiveScan(true);
    BLEScanResults* results = pScan->start(5, false);
    bleCount = results->getCount();
    char buf[32]; sprintf(buf, "Found: %d", bleCount);
    showMessage(buf, 1500);
    pScan->clearResults();
    BLEDevice::deinit();
}

void sendBLE(const char* name, const uint8_t* data, int len) {
    BLEDevice::init("ESP_SPAM");
    BLEAdvertising* pAdv = BLEDevice::getAdvertising();
    BLEAdvertisementData advData;
    advData.setFlags(0x06);
    if (name != NULL && strlen(name) > 0) advData.setName(name);
    if (data != NULL && len > 0) advData.setManufacturerData(data, len);
    pAdv->setAdvertisementData(advData);
    pAdv->start();
    delay(50);
    pAdv->stop();
    BLEDevice::deinit();
}

