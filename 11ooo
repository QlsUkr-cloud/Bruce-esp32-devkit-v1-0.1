<script>
var logDiv=document.getElementById('log');
function addLog(msg){var d=document.createElement('div');d.innerHTML='['+new Date().toLocaleTimeString()+'] '+msg;logDiv.appendChild(d);logDiv.scrollTop=logDiv.scrollHeight;}
function runCmd(cmd){addLog('CMD: '+cmd);fetch('/cmd?c='+encodeURIComponent(cmd)).then(r=>r.text()).then(t=>{addLog('RESP: '+t);if(cmd==='view_pass')updatePass();if(cmd==='view_hand')updateHand();if(cmd==='scan')updateNetworks();updateStats();});}
function updateStats(){fetch('/data').then(r=>r.json()).then(d=>{document.getElementById('deauthCount').innerText=d.deauth||0;document.getElementById('beaconCount').innerText=d.beacon||0;document.getElementById('rssiValue').innerText=d.rssi||-50;document.getElementById('clientsCount').innerText=d.clients||0;document.getElementById('uptime').innerText=d.uptime||0;});}
function updatePass(){fetch('/cmd?c=view_pass').then(r=>r.text()).then(t=>document.getElementById('passList').innerText=t||'(empty)');}
function updateHand(){fetch('/cmd?c=view_hand').then(r=>r.text()).then(t=>document.getElementById('handList').innerText=t||'(empty)');}
function updateNetworks(){fetch('/cmd?c=list_networks').then(r=>r.text()).then(t=>document.getElementById('networksList').innerText=t||'(empty)');}
function updateSys(){fetch('/cmd?c=sysinfo').then(r=>r.text()).then(t=>document.getElementById('sysInfo').innerText=t);}
setInterval(updateStats,1000);updatePass();updateHand();updateNetworks();updateSys();
document.querySelectorAll('.tab').forEach(tab=>{tab.addEventListener('click',()=>{document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));tab.classList.add('active');document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('active'));document.getElementById(tab.dataset.tab).classList.add('active');if(tab.dataset.tab==='passwords')updatePass();if(tab.dataset.tab==='handshakes')updateHand();if(tab.dataset.tab==='networks')updateNetworks();if(tab.dataset.tab==='settings')updateSys();});});
window.onload=function(){addLog('DIY BRUCE v12.0 READY');updatePass();updateHand();updateNetworks();updateSys();};
</script>
</body></html>
)rawliteral";

