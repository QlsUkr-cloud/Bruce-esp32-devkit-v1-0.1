class MyCallbacks : public BLEAdvertisedDeviceCallbacks { void onResult(BLEAdvertisedDevice d) override { bleFound++; lastBLERSSI = d.getRSSI(); } };

void bleScan() {
    bleFound = 0; showMessage("BLE SCAN...", 500);
    BLEDevice::init("");
    pBLEScan = BLEDevice::getScan();
    pBLEScan->setAdvertisedDeviceCallbacks(new MyCallbacks());
    pBLEScan->setActiveScan(true);
    BLEScanResults res = pBLEScan->start(5, false);
    bleFound = res.getCount();
    char buf[32]; sprintf(buf, "Found: %d", bleFound);
    showSuccess("BLE SCAN DONE", buf);
    pBLEScan->clearResults();
    BLEDevice::deinit();
}

void sendBLESpam(const char* name, const uint8_t* data, int len) {
    BLEDevice::init("SPAM");
    BLEAdvertising* pAdv = BLEDevice::getAdvertising();
    BLEAdvertisementData adv;
    adv.setFlags(0x06);
    if (name) adv.setName(name);
    if (data && len > 0) adv.setManufacturerData(std::string((char*)data, len));
    pAdv->setAdvertisementData(adv);
    pAdv->start(); delay(50); pAdv->stop();
    BLEDevice::deinit();
}

