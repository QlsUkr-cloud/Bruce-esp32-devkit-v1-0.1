void drawSubMenu() {
    int size; const char** items; const char* title;
    switch (currentModule) {
        case 0: title = "WiFi"; items = wifiSub; size = wifiSize; break;
        case 1: title = "BLE"; items = bleSub; size = bleSize; break;
        case 2: title = "NRF24"; items = nrfSub; size = nrfSize; break;
        case 3: title = "IR TV"; items = irSub; size = irSize; break;
        case 4: title = "Tools"; items = toolsSub; size = toolsSize; break;
        default: title = "Settings"; items = settingsSub; size = settingsSize; break;
    }
    if (currentSubIndex < subScroll) subScroll = currentSubIndex;
    if (currentSubIndex >= subScroll + SUB_VISIBLE) subScroll = currentSubIndex - SUB_VISIBLE + 1;
    u8g2.clearBuffer(); drawTopBar();
    u8g2.drawBox(0, 11, 128, 12);
    u8g2.setDrawColor(0);
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(2, 21, title);
    u8g2.setDrawColor(1);
    u8g2.drawLine(0, 23, 128, 23);
    for (int i = 0; i < SUB_VISIBLE && (subScroll + i) < size; i++) {
        int idx = subScroll + i;
        int y = 26 + i * 10;
        if (idx == currentSubIndex) {
            u8g2.drawBox(0, y-8, 128, 10);
            u8g2.setDrawColor(0);
            u8g2.drawXBM(2, y-6, 12, 12, folder_12);
            u8g2.drawXBM(16, y-6, 12, 12, scan_12);
            u8g2.setCursor(30, y);
            u8g2.print(items[idx]);
            u8g2.setDrawColor(1);
        } else {
            u8g2.drawXBM(2, y-6, 12, 12, folder_12);
            u8g2.drawXBM(16, y-6, 12, 12, scan_12);
            u8g2.setCursor(30, y);
            u8g2.print(items[idx]);
        }
    }
    if (size > SUB_VISIBLE) {
        int bh = max(5, (39 * SUB_VISIBLE) / size);
        int by = 23 + (subScroll * (39 - bh)) / max(1, size - SUB_VISIBLE);
        u8g2.drawBox(124, by, 3, bh);
    }
    u8g2.sendBuffer();
}

void executeAction() {
    switch (currentModule) {
        case 0:
            switch (currentSubIndex) {
                case 0: scanWiFi(); break; case 1: startDeauth(); break; case 2: startBeacon(); break;
                case 3: startHandshake(); break; case 4: startWiFiJammer(); break; case 5: startEvil(); break;
                case 6: startWebServer(); break; case 7: selectWiFiNetwork(); break; case 8: deauthByMAC(); break;
                case 9: stopWiFiJammer(); stopDeauth(); stopBeacon(); showMessage("ALL STOPPED", 1000); break;
                case 10: showMessage("WiFi INFO", 1000); break; case 11: reboot(); break;
            } break;
        case 1:
            switch (currentSubIndex) {
                case 0: bleScan(); break; case 1: bleApple(); break; case 2: bleSamsung(); break;
                case 3: bleAndroid(); break; case 4: bleWindows(); break; case 5: bleAll(); break;
                case 6: startBLEJammer(); break; case 7: showMessage("BLE INFO", 1000); break;
                case 8: stopBLEJammer(); break; case 9: reboot(); break;
            } break;
        case 2:
            switch (currentSubIndex) {
                case 0: nrfScan(); break; case 1: startNRFJammer(); break; case 2: nrfInfo(); break;
                case 3: stopNRFJammer(); break; case 4: reboot(); break;
            } break;
        case 3:
            switch (currentSubIndex) {
                case 0: irSamsung(); break; case 1: irLG(); break; case 2: irSony(); break;
                case 3: irPanasonic(); break; case 4: irPhilips(); break; case 5: irBravis(); break;
                case 6: irToshiba(); break; case 7: irPower(); break; case 8: irVolUp(); break;
                case 9: irVolDown(); break; case 10: irChUp(); break; case 11: irChDown(); break;
                case 12: irMute(); break; case 13: showMessage("IR STOP", 500); break; case 14: reboot(); break;
            } break;
        case 4:
            switch (currentSubIndex) {
                case 0: toolsKeyboard(); break; case 1: showMessage("TOOLS INFO", 1000); break; case 2: reboot(); break;
            } break;
        case 5:
            switch (currentSubIndex) {
                case 0: setBrightness(); break; case 1: startWebServer(); break; case 2: stopWebServer(); break;
                case 3: showSuccess("PASSWORDS", capturedPasswords.length() ? capturedPasswords.substring(0, 50).c_str() : "None"); break;
                case 4: showSuccess("HANDSHAKES", handshakes.length() ? handshakes.substring(0, 50).c_str() : "None"); break;
                case 5: capturedPasswords = ""; handshakes = ""; saveData(); showMessage("DATA CLEARED", 1000); break;
                case 6: showSuccess("DIY BRUCE v25.0", "WiFi | BLE | NRF | IR | JAMMER"); break; case 7: reboot(); break;
            } break;
    }
}

