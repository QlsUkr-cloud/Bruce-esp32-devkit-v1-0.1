void scanBLE(){
    showMsg("BLE Scan...",500);
    BLEDevice::init("");
    BLEScan* s=BLEDevice::getScan();
    s->setActiveScan(true);
    int c=s->start(5,false)->getCount();
    char b[32];sprintf(b,"Found: %d",c);
    showMsg(b,1500);
    s->clearResults();BLEDevice::deinit();
}

void sendBLE(const char* name,const uint8_t* data,int len){
    BLEDevice::init("SPAM");
    BLEAdvertising* adv=BLEDevice::getAdvertising();
    BLEAdvertisementData d;d.setFlags(0x06);
    if(name&&strlen(name)>0)d.setName(name);
    if(data&&len>0)d.setManufacturerData(data,len);
    adv->setAdvertisementData(d);
    adv->start();delay(50);adv->stop();
    BLEDevice::deinit();
}
