void saveToEEPROM() {
    EEPROM.begin(4096);
    String data = "===PASSWORDS===\\n" + capturedPasswords + "\\n===HANDSHAKES===\\n" + capturedHandshakes + "\\n";
    for (int i = 0; i < data.length() && i < 4095; i++) {
        EEPROM.write(i, data[i]);
    }
    EEPROM.write(data.length(), 0);
    EEPROM.commit();
    EEPROM.end();
}

void loadFromEEPROM() {
    EEPROM.begin(4096);
    String loaded = "";
    for (int i = 0; i < 4096; i++) {
        char c = char(EEPROM.read(i));
        if (c == 0) break;
        loaded += c;
    }
    int passStart = loaded.indexOf("===PASSWORDS===\\n");
    int handStart = loaded.indexOf("===HANDSHAKES===\\n");
    if (passStart != -1 && handStart != -1) {
        capturedPasswords = loaded.substring(passStart + 15, handStart - 1);
        capturedHandshakes = loaded.substring(handStart + 16);
    }
    EEPROM.end();
}

void clearAllData() {
    capturedPasswords = "";
    capturedHandshakes = "";
    saveToEEPROM();
    showMessage("All data cleared", 1000);
}

