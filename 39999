RF24 radio(4, 5);
bool nrfOK = false;
uint8_t nrfCh = 76;
bool nrfJamActive = false;

void scanNRF() {
    if(!radio.isChipConnected()){ showMsg("NRF24 NOT FOUND!"); return; }
    int active=0; showMsg("NRF SCAN...");
    for(int ch=0;ch<=125;ch++){
        radio.setChannel(ch); radio.startListening(); delayMicroseconds(200);
        if(radio.testCarrier()) active++;
        radio.stopListening();
    }
    radio.setChannel(nrfCh); char buf[32]; sprintf(buf,"ACTIVE: %d",active); showMsg(buf);
}

void startNRFJammer() {
    if(!radio.isChipConnected()){ showMsg("NRF24 NOT FOUND!"); return; }
    nrfJamActive=true; radio.setAutoAck(false); radio.setPayloadSize(32);
    showMsg("NRF JAM STARTED");
    while(nrfJamActive){
        for(int ch=0;ch<125 && nrfJamActive;ch++){
            radio.setChannel(ch); uint8_t junk[32];
            for(int i=0;i<32;i++) junk[i]=random(256);
            radio.stopListening(); radio.write(&junk,32); delay(1);
        }
        if(btn(26)) nrfJamActive=false;
    }
    radio.stopListening(); radio.setChannel(nrfCh);
}

void startNRFSend() {
    while(true){
        u8g2.clearBuffer(); u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5,30,"NRF24 Sender"); char buf[20]; sprintf(buf,"CH: %d",nrfCh);
        u8g2.drawStr(5,45,buf); u8g2.setFont(u8g2_font_5x7_tr);
        u8g2.drawStr(2,63,"OK=send BACK=exit"); u8g2.sendBuffer();
        if(btn(12)){
            if(radio.isChipConnected()){
                radio.stopListening(); byte addr[6]="00001"; radio.openWritingPipe(addr);
                char msg[]="HELLO"; radio.write(msg,sizeof(msg)); showMsg("SENT!");
            }
        }
        if(btn(26)) break;
        delay(50);
    }
}

void startNRFInfo() {
    u8g2.clearBuffer(); drawTopBar(); u8g2.setFont(u8g2_font_6x10_tr);
    char buf[32]; sprintf(buf, "Status: %s", radio.isChipConnected()?"OK":"ERROR");
    u8g2.drawStr(5,30,buf); sprintf(buf, "CH: %d", nrfCh); u8g2.drawStr(5,45,buf);
    u8g2.sendBuffer(); while (!btn(26)) delay(50);
}
void setNRFChannel() {
    while(true){
        u8g2.clearBuffer(); drawTopBar();
