# ==================== STORAGE.CPP ====================
STORAGE_CPP = '''#include "Storage.h"
#include <U8g2lib.h>

extern String capturedPasswords;
extern String handshakes;
extern void showMsg(const char* msg, int delayMs);

void savePasswordsToEEPROM() {
    EEPROM.begin(4096);
    String allData = "PASSWORDS:\\n" + capturedPasswords + "\\nHANDSHAKES:\\n" + handshakes;
    for (int i = 0; i < allData.length() && i < 4096; i++) EEPROM.write(i, allData[i]);
    EEPROM.write(allData.length(), 0);
    EEPROM.commit();
}

void loadPasswordsFromEEPROM() {
    EEPROM.begin(4096);
    String loaded = "";
    for (int i = 0; i < 4096; i++) { char c = char(EEPROM.read(i)); if (c == 0) break; loaded += c; }
    int passIdx = loaded.indexOf("PASSWORDS:\\n");
    int handIdx = loaded.indexOf("HANDSHAKES:\\n");
    if (passIdx != -1) capturedPasswords = loaded.substring(passIdx + 11, handIdx);
    if (handIdx != -1) handshakes = loaded.substring(handIdx + 11);
}

void formatStorage() {
    EEPROM.begin(4096);
    for (int i = 0; i < 4096; i++) EEPROM.write(i, 0);
    EEPROM.commit();
    capturedPasswords = "";
    handshakes = "";
    showMsg("FORMATTED!");
}
