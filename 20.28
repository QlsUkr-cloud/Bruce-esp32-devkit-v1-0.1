INDEX_HTML = '''<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DIY BRUCE v25 - Потужний мультитул</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        *{margin:0;padding:0;box-sizing:border-box;}
        body{background:linear-gradient(135deg,#0a0a1a 0%,#0f0f2a 100%);color:#eee;font-family:'Segoe UI',monospace;padding:16px;min-height:100vh;}
        .header{text-align:center;margin-bottom:24px;padding:16px;background:linear-gradient(135deg,#1a1a3a,#0a0a1a);border-radius:24px;border:1px solid #ff6b35;}
        .header h1{color:#ff6b35;font-size:1.8em;letter-spacing:2px;}
        .header .sub{font-size:0.8em;color:#888;margin-top:5px;}
        .stats{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px;}
        .stat-card{background:linear-gradient(135deg,#10152e,#0a0f1a);border-radius:16px;padding:12px;text-align:center;border-left:3px solid #ff6b35;}
        .stat-value{font-size:24px;font-weight:bold;color:#ff6b35;}
        .stat-label{font-size:10px;color:#888;margin-top:4px;}
        .tabs{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:20px;overflow-x:auto;padding-bottom:8px;}
        .tab{background:#1e2a47;padding:8px 14px;border-radius:20px;cursor:pointer;font-size:12px;white-space:nowrap;transition:0.2s;}
        .tab.active{background:#ff6b35;color:#fff;box-shadow:0 0 10px rgba(255,107,53,0.5);}
        .tab-content{display:none;animation:fadeIn 0.3s;}
        .tab-content.active{display:block;}
        @keyframes fadeIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
        .btn-group{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px;}
        button{background:#1e2a47;border:none;padding:8px 16px;border-radius:20px;color:white;cursor:pointer;font-size:12px;font-weight:bold;transition:0.2s;}
        button:hover{transform:scale(1.02);filter:brightness(1.1);}
        .btn-primary{background:#ff6b35;}
        .btn-danger{background:#b91c1c;}
        .btn-success{background:#28a745;}
        .btn-warning{background:#ffc107;color:#000;}
        .btn-info{background:#17a2b8;}
        .log{background:#070b1a;height:200px;overflow:auto;padding:12px;border-radius:16px;font-size:10px;font-family:monospace;border:1px solid #2a2a3e;}
        canvas{background:#070b1a;border-radius:16px;margin:15px 0;padding:8px;width:100%;height:300px;}
        pre{background:#070b1a;padding:12px;border-radius:16px;overflow:auto;max-height:300px;font-size:10px;border:1px solid #2a2a3e;}
        .tv-remote{display:flex;flex-direction:column;align-items:center;gap:12px;margin:20px 0;}
        .tv-row{display:flex;justify-content:center;gap:15px;}
        .tv-btn{background:#1e2a47;padding:15px 20px;border-radius:50px;font-size:20px;width:70px;}
        .tv-btn-center{background:#ff6b35;}
        .keyboard{background:#1a1a3a;border-radius:16px;padding:15px;margin-top:15px;}
        .key-row{display:flex;justify-content:center;gap:5px;margin-bottom:5px;}
        .key{background:#2a2a4a;padding:10px 12px;border-radius:8px;cursor:pointer;font-size:12px;text-align:center;min-width:35px;}
        .key:hover{background:#ff6b35;}
        .key-space{min-width:150px;}
        .key-enter{background:#28a745;min-width:60px;}
        .key-del{background:#b91c1c;min-width:60px;}
        .input-display{background:#070b1a;padding:12px;border-radius:12px;margin-bottom:15px;font-size:14px;word-break:break-all;border:1px solid #ff6b35;}
        @media (max-width:480px){.stats{grid-template-columns:repeat(2,1fr);}.tab{padding:6px 10px;font-size:10px;}button{padding:6px 12px;font-size:10px;}.tv-btn{padding:10px 15px;width:55px;font-size:16px;}}
    </style>
</head>
<body>
<div class="header"><h1>⚡ DIY BRUCE v25.0</h1><div class="sub">Professional Multi-Tool | WiFi | BLE | NRF | IR | JAMMER</div></div>
<div class="stats">
    <div class="stat-card"><div class="stat-value" id="deauth">0</div><div class="stat-label">DEAUTH</div></div>
    <div class="stat-card"><div class="stat-value" id="beacon">0</div><div class="stat-label">BEACON</div></div>
    <div class="stat-card"><div class="stat-value" id="rssi">-50</div><div class="stat-label">RSSI</div></div>
    <div class="stat-card"><div class="stat-value" id="uptime">0</div><div class="stat-label">UPTIME</div></div>
    <div class="stat-card"><div class="stat-value" id="status">●</div><div class="stat-label">STATUS</div></div>
</div>
<div class="tabs" id="tabs">
    <div class="tab active" data-tab="wifi">📡 WiFi</div>
    <div class="tab" data-tab="ble">🔵 BLE</div>
    <div class="tab" data-tab="nrf">📻 NRF24</div>
    <div class="tab" data-tab="ir">🔫 IR TV</div>
    <div class="tab" data-tab="jammer">⚠️ JAMMER</div>
    <div class="tab" data-tab="handshake">🤝 HANDSHAKE</div>
    <div class="tab" data-tab="passwords">🔑 PASSWORDS</div>
    <div class="tab" data-tab="graph">📊 GRAPHS</div>
    <div class="tab" data-tab="tv">📺 TV REMOTE</div>
    <div class="tab" data-tab="keyboard">⌨️ KEYBOARD</div>
    <div class="tab" data-tab="evil">🎭 EVIL</div>
    <div class="tab" data-tab="packets">📦 PACKETS</div>
    <div class="tab" data-tab="settings">⚙️ SETTINGS</div>
</div>

<div id="wifi" class="tab-content active">
    <div class="btn-group">
        <button class="btn-primary" onclick="runCmd('scan')">🔍 SCAN</button>
        <button class="btn-warning" onclick="runCmd('deauth')">⚠️ DEAUTH</button>
        <button class="btn-danger" onclick="runCmd('deauth_stop')">🛑 STOP</button>
        <button class="btn-primary" onclick="runCmd('beacon')">📶 BEACON</button>
        <button class="btn-primary" onclick="runCmd('handshake')">🤝 HANDSHAKE</button>
        <button class="btn-success" onclick="runCmd('connect')">🔗 CONNECT</button>
        <button class="btn-primary" onclick="runCmd('deauth_mac')">🎯 DEAUTH MAC</button>
    </div>
    <div class="log" id="log">Ready...</div>
</div>

<div id="ble" class="tab-content">
    <div class="btn-group">
        <button class="btn-primary" onclick="runCmd('blescan')">🔍 SCAN</button>
        <button class="btn-primary" onclick="runCmd('bleapple')">🍎 APPLE</button>
        <button class="btn-primary" onclick="runCmd('blesamsung')">📱 SAMSUNG</button>
        <button class="btn-primary" onclick="runCmd('bleandroid')">🤖 ANDROID</button>
        <button class="btn-primary" onclick="runCmd('blewindows')">💻 WINDOWS</button>
