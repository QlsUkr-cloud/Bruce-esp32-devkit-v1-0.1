IR_CODES_H = '''#ifndef IR_CODES_H
#define IR_CODES_H

#include <IRsend.h>

// ==================== SAMSUNG TV КОДИ ====================
const uint16_t SAMSUNG_POWER[] = {4500,4500,560,1690,560,560,560,1690,560,560,560,560,560,1690,560,1690,560,1690,560,560};
const uint16_t SAMSUNG_POWER_LEN = 20;

const uint16_t SAMSUNG_VOL_UP[] = {4500,4500,560,1690,560,560,560,1690,560,560,560,1690,560,560,560,1690,560,1690,560,560,560,1690,560,560,560,560,560,1690,560,1690,560,1690,560,560};
const uint16_t SAMSUNG_VOL_UP_LEN = 34;

const uint16_t SAMSUNG_VOL_DOWN[] = {4500,4500,560,1690,560,560,560,1690,560,560,560,1690,560,1690,560,560,560,1690,560,560,560,1690,560,1690,560,560,560,1690,560,1690,560,1690,560,560};
const uint16_t SAMSUNG_VOL_DOWN_LEN = 34;

// ==================== LG TV КОДИ ====================
const uint16_t LG_POWER[] = {9000,4500,560,1690,560,560,560,1690,560,560,560,560,560,1690,560,1690,560,1690,560,560,560,4500};
const uint16_t LG_POWER_LEN = 22;

// ==================== SONY TV КОДИ ====================
const uint16_t SONY_POWER[] = {2400,600,1200,600,600,600,600,1200,600,600,600,1200,600,2400};
const uint16_t SONY_POWER_LEN = 14;

// ==================== BRAVIS TV КОДИ ====================
const uint16_t BRAVIS_POWER[] = {9000,4500,560,1690,560,560,560,560,560,1690,560,560,560,1690,560,1690,560,560};
const uint16_t BRAVIS_POWER_LEN = 18;

// ==================== PHILIPS TV КОДИ ====================
const uint16_t PHILIPS_POWER[] = {3000,3000,560,1690,560,560,560,1690,560,560};
const uint16_t PHILIPS_POWER_LEN = 10;

// ==================== ФУНКЦІЇ ВІДПРАВКИ IR ====================
inline void irSendSamsungPower(IRsend &irsend) { irsend.sendRaw(SAMSUNG_POWER, SAMSUNG_POWER_LEN, 38000); }
inline void irSendSamsungVolUp(IRsend &irsend) { irsend.sendRaw(SAMSUNG_VOL_UP, SAMSUNG_VOL_UP_LEN, 38000); }
inline void irSendSamsungVolDown(IRsend &irsend) { irsend.sendRaw(SAMSUNG_VOL_DOWN, SAMSUNG_VOL_DOWN_LEN, 38000); }
inline void irSendLG(IRsend &irsend) { irsend.sendRaw(LG_POWER, LG_POWER_LEN, 38000); }
inline void irSendSony(IRsend &irsend) { irsend.sendRaw(SONY_POWER, SONY_POWER_LEN, 38000); }
inline void irSendBravis(IRsend &irsend) { irsend.sendRaw(BRAVIS_POWER, BRAVIS_POWER_LEN, 38000); }
inline void irSendPhilips(IRsend &irsend) { irsend.sendRaw(PHILIPS_POWER, PHILIPS_POWER_LEN, 38000); }

#endif
'''

# ============================================================================
# data/index.html (КРАСИВИЙ ВЕБ-САЙТ 13 СТОРІНОК)
