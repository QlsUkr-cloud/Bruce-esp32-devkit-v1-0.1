INTERFACE_H = '''#ifndef INTERFACE_H
#define INTERFACE_H

#include "display.h"
#include "CONFIG.h"

#define MENU_ITEM_COUNT 6

static const unsigned char PROGMEM image_DOTsel_bits[] = {0x60,0xf0,0xf0,0x60};
static const unsigned char PROGMEM image_DOT_bits[] = {0x60,0x90,0x90,0x60};

extern const unsigned char PROGMEM wifi_40[];
extern const unsigned char PROGMEM ble_40[];
extern const unsigned char PROGMEM nrf_40[];
extern const unsigned char PROGMEM ir_40[];
extern const unsigned char PROGMEM tools_40[];
extern const unsigned char PROGMEM settings_40[];

constexpr int16_t MAIN_MENU_DOT_START_Y = 6;
constexpr int16_t MAIN_MENU_DOT_STEP_Y = 8;

inline void drawMainMenuDots(DisplayType &display) {
  for (byte i = 0; i < MENU_ITEM_COUNT; i++) {
    display.drawBitmap(122, MAIN_MENU_DOT_START_Y + (i * MAIN_MENU_DOT_STEP_Y), 4, 4, image_DOT_bits);
  }
}

inline int16_t getMainMenuDotY(byte menuIndex) {
  return MAIN_MENU_DOT_START_Y + (menuIndex * MAIN_MENU_DOT_STEP_Y);
}

inline void drawMainMenuSelectedDot(DisplayType &display, int16_t y) {
  display.drawBitmap(122, y, 4, 4, image_DOTsel_bits);
}

inline void drawMainMenuPage(DisplayType &display, byte menuIndex, int16_t yOffset = 0) {
  display.setFont(u8g2_font_7x13B_tr);
  
  if (menuIndex == 0) {
    display.drawXBM(48, 14 + yOffset, 32, 32, wifi_40);
    display.setCursor(59, 25 + yOffset);
    display.print("WiFi");
  } else if (menuIndex == 1) {
    display.drawXBM(48, 14 + yOffset, 32, 32, ble_40);
    display.setCursor(62, 25 + yOffset);
    display.print("BLE");
  } else if (menuIndex == 2) {
    display.drawXBM(48, 14 + yOffset, 32, 32, nrf_40);
    display.setCursor(52, 25 + yOffset);
    display.print("NRF24");
  } else if (menuIndex == 3) {
    display.drawXBM(48, 14 + yOffset, 32, 32, ir_40);
    display.setCursor(69, 25 + yOffset);
    display.print("IR");
  } else if (menuIndex == 4) {
    display.drawXBM(48, 14 + yOffset, 32, 32, tools_40);
    display.setCursor(55, 25 + yOffset);
    display.print("Tools");
  } else if (menuIndex == 5) {
    display.drawXBM(48, 14 + yOffset, 32, 32, settings_40);
    display.setCursor(46, 25 + yOffset);
    display.print("Config");
  }
}

#endif
'''

# ============================================================================
# include/ir_codes.h (IR коди для різних TV)
