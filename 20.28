#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
DIY BRUCE v25.0 - ПОВНА ФІНАЛЬНА ВЕРСІЯ
Генерує проєкт з усіма функціями, іконками, меню та веб-сайтом
Запустіть: python3 create_diy_bruce_full.py
"""

import os
import shutil

PROJECT_NAME = "DIY_BRUCE_FULL"

# ============================================================================
# platformio.ini
# ============================================================================
PLATFORMIO_INI = '''[env:esp32dev]
platform = espressif32@6.6.0
board = esp32dev
framework = arduino
monitor_speed = 115200
upload_speed = 921600
board_build.filesystem = littelfs

build_flags =
    -DCORE_DEBUG_LEVEL=0
    -Os

lib_deps =
    olikraus/U8g2@^2.35.15
    nRF24/RF24@^1.4.11
    h2zero/NimBLE-Arduino@^2.3.9
    crankyoldgit/IRremoteESP8266@^2.8.6
'''

