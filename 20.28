        <div class="key-row"><div class="key" onclick="addKey('q')">q</div><div class="key" onclick="addKey('w')">w</div><div class="key" onclick="addKey('e')">e</div><div class="key" onclick="addKey('r')">r</div><div class="key" onclick="addKey('t')">t</div><div class="key" onclick="addKey('y')">y</div><div class="key" onclick="addKey('u')">u</div><div class="key" onclick="addKey('i')">i</div><div class="key" onclick="addKey('o')">o</div><div class="key" onclick="addKey('p')">p</div></div>
        <div class="key-row"><div class="key" onclick="addKey('a')">a</div><div class="key" onclick="addKey('s')">s</div><div class="key" onclick="addKey('d')">d</div><div class="key" onclick="addKey('f')">f</div><div class="key" onclick="addKey('g')">g</div><div class="key" onclick="addKey('h')">h</div><div class="key" onclick="addKey('j')">j</div><div class="key" onclick="addKey('k')">k</div><div class="key" onclick="addKey('l')">l</div></div>
        <div class="key-row"><div class="key" onclick="addKey('z')">z</div><div class="key" onclick="addKey('x')">x</div><div class="key" onclick="addKey('c')">c</div><div class="key" onclick="addKey('v')">v</div><div class="key" onclick="addKey('b')">b</div><div class="key" onclick="addKey('n')">n</div><div class="key" onclick="addKey('m')">m</div></div>
        <div class="key-row"><div class="key key-space" onclick="addKey(' ')">SPACE</div><div class="key key-enter" onclick="sendText()">ENTER</div><div class="key key-del" onclick="delKey()">DEL</div><div class="key key-enter" onclick="clearKey()">CLEAR</div></div>
