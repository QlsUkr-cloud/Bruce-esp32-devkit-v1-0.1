void irLG() { irSendLG(irsend); showMessage("LG TV", 500); }
void irSony() { irSendSony(irsend); showMessage("SONY TV", 500); }
void irBravis() { irSendBravis(irsend); showMessage("BRAVIS TV", 500); }
void irPhilips() { irSendPhilips(irsend); showMessage("PHILIPS TV", 500); }
void irPower() { irSendSamsungPower(irsend); showMessage("POWER", 500); }
void irVolUp() { irSendSamsungVolUp(irsend); showMessage("VOL+", 500); }
void irVolDown() { irSendSamsungVolDown(irsend); showMessage("VOL-", 500); }
void irChUp() { irSendSamsungChUp(irsend); showMessage("CH+", 500); }
void irChDown() { irSendSamsungChDown(irsend); showMessage("CH-", 500); }
