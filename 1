#include <Arduino.h>
#include <U8g2lib.h>
#include <Wire.h>

U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2(U8G2_R0, U8X8_PIN_NONE, 21, 22);

void setup() {
    Serial.begin(115200);
    Wire.begin(21, 22);
    u8g2.begin();
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.clearBuffer();
    u8g2.drawStr(10, 35, "DIY BRUCE v5.0");
    u8g2.sendBuffer();
    Serial.println("ESP32 OK");
}

void loop() {
    delay(1000);
}
