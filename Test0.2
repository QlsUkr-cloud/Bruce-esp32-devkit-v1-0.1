STORAGE_H = '''#ifndef STORAGE_MODULE_H
#define STORAGE_MODULE_H

#include <Arduino.h>
#include <EEPROM.h>

extern String capturedPasswords;
extern String handshakes;

void saveData();
void loadData();
void clearData();
void formatStorage();

#endif
'''

STORAGE_CPP = '''#include "StorageModule.h"
#include "DisplayModule.h"

String capturedPasswords = "";
String handshakes = "";

void saveData() {
    EEPROM.begin(4096);
    String allData = "===PASS===\\n" + capturedPasswords + "\\n===HAND===\\n" + handshakes + "\\n===END===\\n";
    for(int i = 0; i < allData.length() && i < 4095; i++) {
        EEPROM.write(i, allData[i]);
    }
    EEPROM.write(allData.length(), 0);
    EEPROM.commit();
    EEPROM.end();
}

void loadData() {
    EEPROM.begin(4096);
    String loaded = "";
    for(int i = 0; i < 4096; i++) {
        char c = char(EEPROM.read(i));
        if(c == 0) break;
        loaded += c;
    }
    int passStart = loaded.indexOf("===PASS===\\n");
    int handStart = loaded.indexOf("===HAND===\\n");
    if(passStart != -1 && handStart != -1) {
        capturedPasswords = loaded.substring(passStart + 11, handStart - 1);
        handshakes = loaded.substring(handStart + 11, loaded.indexOf("===END===\\n") - 1);
    }
    EEPROM.end();
}

void clearData() {
    capturedPasswords = "";
    handshakes = "";
    saveData();
    showMsg("Data cleared", 1000);
}

void formatStorage() {
    EEPROM.begin(4096);
    for(int i = 0; i < 4096; i++) {
        EEPROM.write(i, 0);
    }
    EEPROM.commit();
    EEPROM.end();
    capturedPasswords = "";
    handshakes = "";
    showMsg("Storage formatted", 1000);
}
'''

