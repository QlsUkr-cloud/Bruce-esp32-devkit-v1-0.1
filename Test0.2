        u8g2.drawStr(5, 60, "BACK - Stop");
        u8g2.sendBuffer();
        if(btn(BTN_BACK)) evilActive = false;
        delay(100);
    }
    dnsServer.stop();
    WiFi.softAPdisconnect(true);
    showMsg("EVIL PORTAL stopped", 1000);
}

