// ============================================================================
void nrfScan() { if (!radio.begin()) { showError("NRF24 NOT FOUND!", ""); return; } int active = 0; showMessage("NRF SCAN...", 500); for (int ch = 0; ch <= 125; ch++) { radio.setChannel(ch); radio.startListening(); delayMicroseconds(200); if (radio.testCarrier()) active++; radio.stopListening(); } char buf[32]; sprintf(buf, "Active: %d", active); showSuccess("NRF SCAN DONE", buf); }
void startNRFJammer() { if (!radio.begin()) { showError("NRF24 NOT FOUND!", ""); return; } nrfJamActive = true; radio.setAutoAck(false); radio.setPayloadSize(32); showSuccess("NRF JAMMER STARTED", "Press BACK to stop"); while (nrfJamActive) { for (int ch = 0; ch < 125 && nrfJamActive; ch++) { radio.setChannel(ch); uint8_t junk[32]; for (int i = 0; i < 32; i++) junk[i] = random(256); radio.stopListening(); radio.write(&junk, 32); if (checkButton(BTN_BACK)) nrfJamActive = false; delay(1); } } radio.stopListening(); showSuccess("NRF JAMMER STOPPED", ""); }
void stopNRFJammer() { nrfJamActive = false; }
void nrfInfo() { u8g2.clearBuffer(); drawTopBar(); u8g2.setFont(u8g2_font_6x10_tr); char buf[32]; sprintf(buf, "Status: %s", radio.begin() ? "OK" : "ERROR"); u8g2.drawStr(5, 30, buf); sprintf(buf, "Channel: %d", nrfCh); u8g2.drawStr(5, 45, buf); u8g2.sendBuffer(); while (!checkButton(BTN_BACK)) delay(50); }

