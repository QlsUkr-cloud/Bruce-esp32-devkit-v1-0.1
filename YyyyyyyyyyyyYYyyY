bool checkButton(int pin) {
    if (digitalRead(pin) == LOW && (millis() - lastBtnTime) > DEBOUNCE_DELAY) {
        lastBtnTime = millis();
        return true;
    }
    return false;
}

void drawTopBar() {
    char buf[16];
    unsigned long sec = (millis() - uptimeStart) / 1000;
    int h = (sec / 3600) % 24, m = (sec / 60) % 60, s = sec % 60;
    sprintf(buf, "%02d:%02d:%02d", h, m, s);
    u8g2.setFont(u8g2_font_6x13_tr);
    u8g2.drawStr(2, 9, buf);
    u8g2.drawFrame(114, 1, 12, 6);
    u8g2.drawBox(126, 3, 2, 2);
    u8g2.drawBox(115, 2, 9, 4);
    u8g2.setCursor(55, 9);
    u8g2.print("75%");
    u8g2.setCursor(100, 9);
    u8g2.print(String(lastRSSI) + "dB");
    if (evilActive) u8g2.drawStr(70, 9, "E");
    else if (webRunning) u8g2.drawStr(70, 9, "W");
    u8g2.drawLine(0, 10, 128, 10);
}

