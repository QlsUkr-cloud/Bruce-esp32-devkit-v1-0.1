void saveData() {
    EEPROM.begin(EEPROM_SIZE);
    String data = "===PASS===\\n" + capturedPasswords + "\\n===HAND===\\n" + handshakes + "\\n";
    for (int i = 0; i < data.length() && i < EEPROM_SIZE - 1; i++) EEPROM.write(i, data[i]);
    EEPROM.write(data.length(), 0);
    EEPROM.commit();
    EEPROM.end();
}

void loadData() {
    EEPROM.begin(EEPROM_SIZE);
    String loaded = "";
    for (int i = 0; i < EEPROM_SIZE; i++) { char c = char(EEPROM.read(i)); if (c == 0) break; loaded += c; }
    int p = loaded.indexOf("===PASS===\\n");
    int h = loaded.indexOf("===HAND===\\n");
    if (p != -1 && h != -1) {
        capturedPasswords = loaded.substring(p + 11, h - 1);
        handshakes = loaded.substring(h + 11);
    }
    EEPROM.end();
}

