        case 0:
            switch (currentSub) {
                case 0: wifiScan(); break; case 1: startDeauth(); break;
                case 2: startBeacon(); break; case 3: startEvil(); break;
                case 4: startHandshake(); break; case 5: startJammer(); break;
                case 6: startWebServer(); break; case 7: clearData(); break;
                case 8: showMessage("INFO",1000); break; case 9: reboot(); break;
            } break;
        case 1: bleScan(); break;
        case 2: nrfScan(); break;
        case 3: rfidRead(); break;
        case 4: irPower(); break;
        case 5: toolsKeyboard(); break;
        case 6: startWebServer(); break;
    }
}

