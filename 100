[env:esp32dev]
platform = espressif32@6.6.0
board = esp32dev
framework = arduino
monitor_speed = 115200
upload_speed = 921600
board_build.filesystem = littelfs

build_flags =
    -DCORE_DEBUG_LEVEL=0
    -Os
    -DARDUINO_USB_MODE=1
    -DARDUINO_USB_CDC_ON_BOOT=0

lib_deps =
    olikraus/U8g2@^2.35.15
    nRF24/RF24@^1.4.11
    h2zero/NimBLE-Arduino@^2.3.9
