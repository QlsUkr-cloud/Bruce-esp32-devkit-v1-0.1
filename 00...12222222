</style></head><body><h1>⚡ DIY BRUCE v23.0</h1>
<div class="stats"><div class="stat-card"><div class="stat-value" id="deauth">0</div><div>DEAUTH</div></div><div class="stat-card"><div class="stat-value" id="beacon">0</div><div>BEACON</div></div><div class="stat-card"><div class="stat-value" id="rssi">-50</div><div>RSSI</div></div><div class="stat-card"><div class="stat-value" id="uptime">0</div><div>UPTIME</div></div></div>
<div class="tabs" id="tabs"><div class="tab active" data-tab="wifi">📡 WiFi</div><div class="tab" data-tab="ble">🔵 BLE</div><div class="tab" data-tab="nrf">📻 NRF24</div><div class="tab" data-tab="graph">📊 GRAPH</div><div class="tab" data-tab="tv">📺 TV</div><div class="tab" data-tab="evil">🎭 EVIL</div><div class="tab" data-tab="hand">🤝 HANDSHAKE</div><div class="tab" data-tab="pass">🔑 PASSWORDS</div><div class="tab" data-tab="settings">⚙️ SETTINGS</div></div>
<div id="wifi" class="tab-content active"><div class="btn-group"><button class="btn-primary" onclick="run('scan')">🔍 SCAN</button><button class="btn-primary" onclick="run('deauth')">⚠️ DEAUTH</button><button class="btn-danger" onclick="run('deauth_stop')">🛑 STOP</button><button class="btn-primary" onclick="run('beacon')">📶 BEACON</button><button class="btn-primary" onclick="run('handshake')">🤝 HANDSHAKE</button><button class="btn-primary" onclick="run('jam')">⚠️ JAMMER</button><button class="btn-primary" onclick="run('connect')">🔗 CONNECT</button><button class="btn-primary" onclick="run('deauth_mac')">🎯 DEAUTH MAC</button></div><div class="log" id="log">Ready...</div></div>
