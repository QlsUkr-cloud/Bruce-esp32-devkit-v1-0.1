<div id="nrf" class="tab-content"><div class="btn-group"><button onclick="run('nrf_scan')">🔍 SCAN</button><button onclick="run('nrf_jam')">⚠️ JAM</button><button onclick="run('nrf_send')">📤 SEND</button></div><pre id="nrfResult"></pre></div>
<div id="graph" class="tab-content"><canvas id="rssiChart"></canvas><canvas id="bleChart" style="margin-top:20px;"></canvas><canvas id="channelChart" style="margin-top:20px;"></canvas></div>
